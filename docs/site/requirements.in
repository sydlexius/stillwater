# Top-level docs build dependencies. Source-of-truth for the lockfile compiler.
#
# Regenerate the hash-pinned lockfile (docs/site/requirements.txt) after
# editing this file. Use Python 3.12 to match the version pinned in
# .github/workflows/pages.yml (`python-version: '3.12'`); the resolver
# resolves against the target interpreter, so a different version can in
# principle pick different transitive pins via PEP 508 markers or wheel
# availability.
#
# Canonical regen command (uv, which produces this lockfile):
#
#   uv pip compile --generate-hashes --python-version 3.12 \
#     docs/site/requirements.in -o docs/site/requirements.txt
#
# (`--python-version 3.12` targets 3.12 without needing it installed.)
# The pip-tools equivalent is `pip-compile --generate-hashes`.
#
# The lockfile feeds `pip install --require-hashes -r docs/site/requirements.txt`
# in .github/workflows/pages.yml so a typosquat or compromised PyPI release
# cannot substitute a different artifact under the same version string
# (OpenSSF Scorecard PinnedDependenciesID).
properdocs==1.6.7
mkdocs-material==9.7.6
mkdocs-awesome-pages-plugin==2.10.1
mkdocs-git-revision-date-localized-plugin==1.5.3
mkdocs-redirects==1.2.3
