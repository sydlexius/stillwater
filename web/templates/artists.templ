package templates

import (
	"context"
	"fmt"
	"net/url"
	"sort"
	"strconv"
	"strings"

	"github.com/sydlexius/stillwater/internal/artist"
	img "github.com/sydlexius/stillwater/internal/image"
	"github.com/sydlexius/stillwater/internal/library"
	"github.com/sydlexius/stillwater/web/components"
)

// Filter trigger button class sets. Used in both the class attribute (via
// templ.KV) and data-* attributes so the template is the single source of truth.
const (
	filterTriggerActive  = "border-blue-500 bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-600"
	filterTriggerNeutral = "border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
	filterTriggerBadge   = "sw-filter-trigger-badge ml-0.5 inline-flex h-4 w-4 items-center justify-center rounded-full bg-blue-600 text-[10px] font-bold text-white dark:bg-blue-400 dark:text-gray-900"
)

// LibrarySourceInfo holds display metadata for an imported library's source.
type LibrarySourceInfo struct {
	Source         string // "emby", "jellyfin", "lidarr"
	ConnectionName string // human-readable connection name
}

// ArtistListData holds the data for the artist list page.
type ArtistListData struct {
	Artists          []artist.Artist
	Libraries        []library.Library
	LibrarySources   map[string]LibrarySourceInfo       // library ID -> source info (only for non-manual)
	ComplianceMap    map[string]artist.ComplianceStatus // artist ID -> compliance status
	PlatformPresence map[string]artist.PlatformPresence // artist ID -> platform badges
	Pagination       components.PaginationData
	Search           string
	Sort             string
	Order            string
	Filter           string
	// Filters holds the flyout multi-filter state (key -> "include" or "exclude").
	// Keys: missing_meta, missing_images, missing_mbid, excluded, locked,
	// type_person, type_group, type_orchestra, library_{id}.
	Filters     map[string]string
	LibraryID   string
	View        string // "table" or "grid"
	ProfileName string // Active platform profile name for image terminology
	// IDs reflects the active "Show selected" filter (#1227). When non-empty
	// the list is restricted to these artist IDs and the toolbar renders a
	// dismissible chip plus a "Show all" link to clear it. The slice is
	// preserved across pagination so paging through a large selection
	// (>1 page) keeps the filter active.
	IDs []string
}

// complianceDotClass returns the Tailwind background class for a compliance indicator dot.
func complianceDotClass(status artist.ComplianceStatus) string {
	switch status {
	case artist.ComplianceError:
		return "bg-red-500"
	case artist.ComplianceWarning:
		return "bg-yellow-500"
	default:
		return "bg-green-500"
	}
}

// complianceDotTitle returns a tooltip string for the compliance indicator.
func complianceDotTitle(ctx context.Context, status artist.ComplianceStatus) string {
	switch status {
	case artist.ComplianceError:
		return t(ctx, "artists.compliance.error")
	case artist.ComplianceWarning:
		return t(ctx, "artists.compliance.warning")
	default:
		return t(ctx, "artists.compliance.compliant")
	}
}

// complianceAvailable returns whether compliance data was successfully loaded.
// A nil map means the query failed or was skipped; dots should be hidden.
func complianceAvailable(m map[string]artist.ComplianceStatus) bool {
	return m != nil
}

// artistCompliance looks up an artist's compliance status from the map,
// defaulting to compliant if not found (artist has no active violations).
func artistCompliance(id string, m map[string]artist.ComplianceStatus) artist.ComplianceStatus {
	if s, ok := m[id]; ok {
		return s
	}
	return artist.ComplianceCompliant
}

// artistSourceInfo returns the LibrarySourceInfo for an artist, or a zero value if manual/unknown.
// Only returns source info for pathless artists -- an artist with a filesystem path is
// filesystem-backed regardless of which library it belongs to.
func artistSourceInfo(a artist.Artist, sources map[string]LibrarySourceInfo) LibrarySourceInfo {
	if sources == nil || a.LibraryID == "" || a.Path != "" {
		return LibrarySourceInfo{}
	}
	return sources[a.LibraryID]
}

// artistHasFilesystem returns true when the artist holds at least one
// filesystem-library membership. Replaced the prior path-based
// heuristic, which gave false positives for connection-only artists whose
// path was set by Emby / Jellyfin populates.
func artistHasFilesystem(pp artist.PlatformPresence) bool {
	return pp.HasFilesystem
}

// lidarrTooltip returns the tooltip text for a Lidarr platform badge.
// Uses the connection name from src if available.
func lidarrTooltip(ctx context.Context, src LibrarySourceInfo) string {
	if src.Source == "lidarr" && src.ConnectionName != "" {
		return tf(ctx, "artists.badge.managed_by", src.ConnectionName)
	}
	return tf(ctx, "artists.badge.managed_by", "Lidarr")
}

// embyTooltip returns the tooltip text for an Emby platform badge.
func embyTooltip(ctx context.Context, src LibrarySourceInfo) string {
	if src.Source == "emby" && src.ConnectionName != "" {
		return tf(ctx, "artists.badge.present_in", src.ConnectionName)
	}
	return tf(ctx, "artists.badge.present_in", "Emby")
}

// jellyfinTooltip returns the tooltip text for a Jellyfin platform badge.
func jellyfinTooltip(ctx context.Context, src LibrarySourceInfo) string {
	if src.Source == "jellyfin" && src.ConnectionName != "" {
		return tf(ctx, "artists.badge.present_in", src.ConnectionName)
	}
	return tf(ctx, "artists.badge.present_in", "Jellyfin")
}

// artistBadge holds the platform name and tooltip for a single badge.
type artistBadge struct {
	Platform string
	Tooltip  string
}

// computeArtistBadges returns the ordered list of platform badges for an artist.
// Badge order: Filesystem, Lidarr, Emby, Jellyfin (discovery source first, then platforms).
func computeArtistBadges(ctx context.Context, a artist.Artist, sources map[string]LibrarySourceInfo, platforms map[string]artist.PlatformPresence) []artistBadge {
	src := artistSourceInfo(a, sources)
	pp := artistPlatformPresence(a.ID, platforms)
	var badges []artistBadge
	if artistHasFilesystem(pp) {
		badges = append(badges, artistBadge{"filesystem", tf(ctx, "artists.badge.found_in", a.Path)})
	}
	if pp.HasLidarr || src.Source == "lidarr" {
		badges = append(badges, artistBadge{"lidarr", lidarrTooltip(ctx, src)})
	}
	if pp.HasEmby || src.Source == "emby" {
		badges = append(badges, artistBadge{"emby", embyTooltip(ctx, src)})
	}
	if pp.HasJellyfin || src.Source == "jellyfin" {
		badges = append(badges, artistBadge{"jellyfin", jellyfinTooltip(ctx, src)})
	}
	return badges
}

// artistPlatformPresence looks up an artist's platform presence from the map,
// returning a zero value (no platforms) if the artist is not found.
func artistPlatformPresence(id string, m map[string]artist.PlatformPresence) artist.PlatformPresence {
	if m == nil {
		return artist.PlatformPresence{}
	}
	return m[id]
}

// libraryDropdownLabel returns the display label for a library in the dropdown.
// For imported libraries it appends the connection name in parentheses, unless
// the library name already ends with that same parenthetical (which would
// otherwise double the connection-name suffix). An empty ConnectionName on an
// otherwise-imported source falls back to the bare library name rather than
// rendering an empty " ()" parenthetical.
func libraryDropdownLabel(lib library.Library, sources map[string]LibrarySourceInfo) string {
	if sources == nil {
		return lib.Name
	}
	info, ok := sources[lib.ID]
	if !ok || info.Source == "" || info.ConnectionName == "" {
		return lib.Name
	}
	suffix := " (" + info.ConnectionName + ")"
	if strings.HasSuffix(lib.Name, suffix) {
		return lib.Name
	}
	return lib.Name + suffix
}

// sortLabel returns a short display label for the sort field.
func sortLabel(ctx context.Context, sort string) string {
	switch sort {
	case "sort_name":
		return t(ctx, "artists.sort.sort_name")
	case "type":
		return t(ctx, "artists.sort.type")
	case "origin":
		return t(ctx, "artists.sort.origin")
	case "health_score":
		return t(ctx, "artists.sort.health")
	case "updated_at":
		return t(ctx, "artists.sort.updated")
	case "created_at":
		return t(ctx, "artists.sort.added")
	default:
		return t(ctx, "artists.sort.name")
	}
}


// orderLabel returns a short label for the sort order.
func orderLabel(ctx context.Context, order string) string {
	if order == "desc" {
		return t(ctx, "artists.order.desc")
	}
	return t(ctx, "artists.order.asc")
}

// filterState returns the flyout state string for a given filter key.
// Returns "include", "exclude", or "neutral".
func filterState(filters map[string]string, key string) string {
	if filters == nil {
		return "neutral"
	}
	if s, ok := filters[key]; ok && (s == "include" || s == "exclude") {
		return s
	}
	return "neutral"
}

// libraryWhitelistActive reports whether the per-library filter is in
// whitelist mode (issue #1217): true when at least one library_<id> filter
// key is set to "include". In whitelist mode every library pill not set to
// Include is "out of scope" and rendered dimmed.
func libraryWhitelistActive(filters map[string]string) bool {
	for key, state := range filters {
		if state == "include" && strings.HasPrefix(key, "library_") {
			return true
		}
	}
	return false
}

// isFilterActive returns whether the artist list has any active filter.
// Bulk selection is only available when a filter narrows the visible set; this
// guards against users accidentally selecting the entire library.
func isFilterActive(data ArtistListData) bool {
	return activeFilterCount(data.Filters) > 0 || data.Search != "" || data.LibraryID != "" || data.Filter != ""
}

// activeFilterCount returns the number of active (non-neutral) filters in the map.
func activeFilterCount(filters map[string]string) int {
	count := 0
	for _, v := range filters {
		if v == "include" || v == "exclude" {
			count++
		}
	}
	return count
}

// filterChipLabel returns the display label for an active filter chip.
func filterChipLabel(ctx context.Context, key, state string) string {
	var name string
	switch key {
	// Legacy / composite filters.
	case "missing_meta":
		name = t(ctx, "artists.filter.missing_metadata")
	case "missing_images":
		name = t(ctx, "artists.filter.missing_images")
	case "missing_mbid":
		name = t(ctx, "artists.filter.missing_mbid")
	case "excluded":
		name = t(ctx, "artists.filter.excluded")
	case "locked":
		name = t(ctx, "artists.filter.locked")
	// Artist-type filters.
	case "type_person":
		name = t(ctx, "artists.filter.person")
	case "type_group":
		name = t(ctx, "artists.filter.group")
	case "type_orchestra":
		name = t(ctx, "artists.filter.orchestra")
	// Metadata field presence filters.
	case "has_biography":
		name = t(ctx, "artists.filter.has_biography")
	case "has_years_active":
		name = t(ctx, "artists.filter.has_years_active")
	case "has_formed":
		name = t(ctx, "artists.filter.has_formed")
	case "has_disbanded":
		name = t(ctx, "artists.filter.has_disbanded")
	case "has_born":
		name = t(ctx, "artists.filter.has_born")
	case "has_died":
		name = t(ctx, "artists.filter.has_died")
	case "has_gender":
		name = t(ctx, "artists.filter.has_gender")
	case "has_type":
		name = t(ctx, "artists.filter.has_type")
	case "has_country":
		name = t(ctx, "artists.filter.has_country")
	case "has_genres":
		name = t(ctx, "artists.filter.has_genres")
	case "has_styles":
		name = t(ctx, "artists.filter.has_styles")
	case "has_moods":
		name = t(ctx, "artists.filter.has_moods")
	case "has_members":
		name = t(ctx, "artists.filter.has_members")
	case "has_discography":
		name = t(ctx, "artists.filter.has_discography")
	// Per-image-type presence filters.
	case "has_thumb":
		name = t(ctx, "artists.filter.has_thumb")
	case "has_fanart":
		name = t(ctx, "artists.filter.has_fanart")
	case "has_logo":
		name = t(ctx, "artists.filter.has_logo")
	case "has_banner":
		name = t(ctx, "artists.filter.has_banner")
	// Platform membership filters.
	case "in_emby":
		name = t(ctx, "artists.filter.in_emby")
	case "in_jellyfin":
		name = t(ctx, "artists.filter.in_jellyfin")
	case "has_lidarr":
		name = t(ctx, "artists.filter.has_lidarr")
	// Rule violation filter.
	case "has_violations":
		name = t(ctx, "artists.filter.has_violations")
	default:
		if strings.HasPrefix(key, "library_") {
			name = t(ctx, "artists.filter.library")
		} else {
			name = key
		}
	}
	if state == "exclude" {
		return tf(ctx, "artists.filter.not_prefix", name)
	}
	return name
}

// filterChipLabelFromData returns the display label for an active filter chip,
// resolving library names from the provided slice when the key is a library filter.
// sources is used to append the connection name for imported libraries.
func filterChipLabelFromData(ctx context.Context, key, state string, libs []library.Library, sources map[string]LibrarySourceInfo) string {
	if strings.HasPrefix(key, "library_") {
		libID := key[len("library_"):]
		for _, lib := range libs {
			if lib.ID == libID {
				label := libraryDropdownLabel(lib, sources)
				if state == "exclude" {
					return tf(ctx, "artists.filter.not_prefix", label)
				}
				return label
			}
		}
	}
	return filterChipLabel(ctx, key, state)
}

// filterChipClass returns the CSS classes for an active filter chip based on state.
func filterChipClass(state string) string {
	if state == "exclude" {
		return "inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300"
	}
	return "inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300"
}

// sortedFilterKeys returns the keys of a filter map in sorted order for
// deterministic chip rendering.
func sortedFilterKeys(filters map[string]string) []string {
	keys := make([]string, 0, len(filters))
	for k := range filters {
		keys = append(keys, k)
	}
	sort.Strings(keys)
	return keys
}

// sortDropdownItem returns the CSS classes for a sort dropdown item, with active highlighting.
func sortDropdownItem(active bool) string {
	base := "w-full text-left px-4 py-1.5 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 "
	if active {
		return base + "font-semibold text-blue-600 dark:text-blue-400"
	}
	return base + "text-gray-700 dark:text-gray-200"
}

templ ArtistsPage(assets AssetPaths, data ArtistListData) {
	@Layout(t(ctx, "artists.title"), assets) {
		<div class="space-y-6">
			<div class="sw-card rounded-lg px-6 py-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<h1 class="text-2xl font-bold">{ t(ctx, "artists.title") }</h1>
					<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
						{ tn(ctx, "artists.in_library", data.Pagination.TotalItems) }
					</p>
				</div>
				<button
					id="scan-btn"
					hx-post="/api/v1/scanner/run"
					hx-swap="none"
					data-label-scan={ t(ctx, "artists.scan_library") }
					data-label-scanning={ t(ctx, "artists.scanning") }
					class="inline-flex items-center justify-center gap-2 rounded-md bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
				>
					<span id="scan-spinner" class="hidden">
						<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
						</svg>
					</span>
					<span id="scan-label">{ t(ctx, "artists.scan_library") }</span>
				</button>
			</div>
			<input type="hidden" name="view" id="artist-view-input" value={ data.View }/>
			<input type="hidden" name="sort" id="artist-sort-input" value={ data.Sort }/>
			<input type="hidden" name="order" id="artist-order-input" value={ data.Order }/>
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="relative flex-1 max-w-sm">
					<input
						id="artist-search"
						type="search"
						name="search"
						value={ data.Search }
						placeholder={ t(ctx, "artists.search_placeholder") }
						aria-label={ t(ctx, "artists.search_placeholder") }
						hx-get="/artists"
						hx-trigger="keyup changed delay:300ms"
						hx-target="#artist-content"
						hx-swap="outerHTML"
						hx-include="[name='library_id'],[name='view'],[name='sort'],[name='order']"
						class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
					/>
				</div>
				<div class="flex items-center gap-3">
					if len(data.Libraries) > 1 {
						<select
							name="library_id"
							hx-get="/artists"
							hx-trigger="change"
							hx-target="#artist-content"
							hx-swap="outerHTML"
							hx-include="[name='search'],[name='view'],[name='sort'],[name='order']"
							class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
							aria-label={ t(ctx, "artists.filter_by_library") }
						>
							<option value="" selected?={ data.LibraryID == "" }>{ t(ctx, "artists.all_libraries") }</option>
							for _, lib := range data.Libraries {
								<option value={ lib.ID } selected?={ data.LibraryID == lib.ID }>{ libraryDropdownLabel(lib, data.LibrarySources) }</option>
							}
						</select>
					}
					<!-- Filters flyout trigger button -->
					<button
						id="artist-filter-trigger"
						type="button"
						class={ "inline-flex items-center gap-1.5 rounded-md border px-3 py-2 text-sm transition-colors focus:outline-none focus:ring-1 focus:ring-blue-500", templ.KV(filterTriggerActive, activeFilterCount(data.Filters) > 0), templ.KV(filterTriggerNeutral, activeFilterCount(data.Filters) == 0) }
						data-active-classes={ filterTriggerActive }
						data-neutral-classes={ filterTriggerNeutral }
						data-badge-classes={ filterTriggerBadge }
						aria-label={ t(ctx, "common.open_filter_panel") }
						aria-expanded="false"
						aria-controls="artist-filters-flyout"
						onclick={ components.OpenFilterFlyout("artist-filters-flyout") }
					>
						<!-- Heroicons: funnel (mini) -->
						<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
							<path fill-rule="evenodd" d="M2.628 1.601C5.028 1.206 7.49 1 10 1s4.973.206 7.372.601a.75.75 0 0 1 .628.74v2.288a2.25 2.25 0 0 1-.659 1.59l-4.682 4.683a2.25 2.25 0 0 0-.659 1.59v3.037c0 .684-.31 1.33-.844 1.757l-1.937 1.55A.75.75 0 0 1 9 18.25v-5.757a2.25 2.25 0 0 0-.659-1.591L3.659 6.22A2.25 2.25 0 0 1 3 4.629V2.34a.75.75 0 0 1 .628-.74Z" clip-rule="evenodd"></path>
						</svg>
						<span>{ t(ctx, "common.filters") }</span>
						if activeFilterCount(data.Filters) > 0 {
							<span class={ filterTriggerBadge } aria-label={ func() string { n := activeFilterCount(data.Filters); if n == 1 { return t(ctx, "common.active_filter_one") }; return tf(ctx, "common.active_filter_other", n) }() }>
								{ fmt.Sprintf("%d", activeFilterCount(data.Filters)) }
							</span>
						}
					</button>
					@components.ContextHelp("help-artists-filters", t(ctx, "artists.help.filters.label"), t(ctx, "artists.help.filters"), "core-concepts/artists-and-libraries#libraries")
					<details id="sort-dropdown" class="relative">
						<summary class="list-none cursor-pointer inline-flex items-center gap-1.5 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-1 focus:ring-blue-500" title={ t(ctx, "common.sort") }>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5"></path>
							</svg>
							<span id="sort-field-label" class="hidden sm:inline">{ sortLabel(ctx, data.Sort) }</span>
							<span id="sort-order-label" class="hidden sm:inline text-gray-400">{ orderLabel(ctx, data.Order) }</span>
						</summary>
						<div class="absolute right-0 top-full z-20 mt-1 w-52 rounded-md border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-lg py-1">
							<div class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">{ t(ctx, "artists.sort_by") }</div>
							<button type="button" onclick="setSort('name')" class={ sortDropdownItem(data.Sort == "name") }>{ t(ctx, "artists.sort.name") }</button>
							<button type="button" onclick="setSort('sort_name')" class={ sortDropdownItem(data.Sort == "sort_name") }>{ t(ctx, "artists.sort.sort_name") }</button>
							<button type="button" onclick="setSort('type')" class={ sortDropdownItem(data.Sort == "type") }>{ t(ctx, "artists.sort.type") }</button>
							<button type="button" onclick="setSort('origin')" class={ sortDropdownItem(data.Sort == "origin") }>{ t(ctx, "artists.sort.origin") }</button>
							<button type="button" onclick="setSort('health_score')" class={ sortDropdownItem(data.Sort == "health_score") }>{ t(ctx, "artists.sort.health_score") }</button>
							<button type="button" onclick="setSort('updated_at')" class={ sortDropdownItem(data.Sort == "updated_at") }>{ t(ctx, "artists.sort.last_updated") }</button>
							<button type="button" onclick="setSort('created_at')" class={ sortDropdownItem(data.Sort == "created_at") }>{ t(ctx, "artists.sort.date_added") }</button>
							<div class="my-1 border-t border-gray-100 dark:border-gray-700"></div>
							<div class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">{ t(ctx, "artists.direction") }</div>
							<button type="button" onclick="setOrder('asc')" class={ sortDropdownItem(data.Order == "asc") }>{ t(ctx, "artists.sort.ascending") }</button>
							<button type="button" onclick="setOrder('desc')" class={ sortDropdownItem(data.Order == "desc") }>{ t(ctx, "artists.sort.descending") }</button>
						</div>
					</details>
					@components.ContextHelp("help-artists-sort", t(ctx, "artists.help.sort.label"), t(ctx, "artists.help.sort"), "")
					<div id="col-toggle-wrapper" class={ templ.KV("hidden", data.View != "table") }>
						@components.ColumnToggle("artists", "artists-table", []components.ColumnDef{
							{Key: "name", Label: t(ctx, "artists.col.name"), Required: true},
							{Key: "type", Label: t(ctx, "artists.sort.type")},
							{Key: "origin", Label: t(ctx, "artists.sort.origin")},
							{Key: "metadata", Label: t(ctx, "artists.col.metadata")},
							{Key: "thumb", Label: img.ImageTermFor("thumb", data.ProfileName)},
							{Key: "fanart", Label: img.ImageTermFor("fanart", data.ProfileName)},
							{Key: "logo", Label: img.ImageTermFor("logo", data.ProfileName)},
							{Key: "mbid", Label: t(ctx, "artists.col.mbid")},
						})
					</div>
					<div id="view-toggle" class="flex rounded-md border border-gray-300 dark:border-gray-600 overflow-hidden">
						<button
							type="button"
							title={ t(ctx, "artists.view.table") }
							aria-label={ t(ctx, "artists.view.table") }
							hx-get="/artists"
							hx-target="#artist-content"
							hx-swap="outerHTML"
							hx-include="[name='search'],[name='library_id'],[name='sort'],[name='order']"
							hx-vals='{"view":"table","page":"1"}'
							onclick="setView('table')"
							class={ "p-2 transition-colors", templ.KV("bg-blue-600 text-white", data.View == "table"), templ.KV("bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700", data.View != "table") }
						>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"></path>
							</svg>
						</button>
						<button
							type="button"
							title={ t(ctx, "artists.view.grid") }
							aria-label={ t(ctx, "artists.view.grid") }
							hx-get="/artists"
							hx-target="#artist-content"
							hx-swap="outerHTML"
							hx-include="[name='search'],[name='library_id'],[name='sort'],[name='order']"
							hx-vals='{"view":"grid","page":"1"}'
							onclick="setView('grid')"
							class={ "p-2 transition-colors", templ.KV("bg-blue-600 text-white", data.View == "grid"), templ.KV("bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700", data.View != "grid") }
						>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
			<!-- FilterFlyout panel for artist filters -->
			@components.FilterFlyout("artist-filters-flyout", t(ctx, "artists.filters_title"), "artist-filter-trigger", activeFilterCount(data.Filters), "#artist-content") {
				@components.FilterSection(t(ctx, "artists.filter_section.metadata")) {
					@components.FilterItem("artist-filters-flyout", "filter_missing_meta", "y", t(ctx, "artists.filter.missing_metadata"), filterState(data.Filters, "missing_meta"))
					@components.FilterItem("artist-filters-flyout", "filter_missing_mbid", "y", t(ctx, "artists.filter.missing_mbid"), filterState(data.Filters, "missing_mbid"))
				}
				@components.FilterSection(t(ctx, "artists.filter_section.metadata_fields")) {
					@components.FilterItem("artist-filters-flyout", "filter_has_biography", "y", t(ctx, "artists.filter.has_biography"), filterState(data.Filters, "has_biography"))
					@components.FilterItem("artist-filters-flyout", "filter_has_years_active", "y", t(ctx, "artists.filter.has_years_active"), filterState(data.Filters, "has_years_active"))
					@components.FilterItem("artist-filters-flyout", "filter_has_formed", "y", t(ctx, "artists.filter.has_formed"), filterState(data.Filters, "has_formed"))
					@components.FilterItem("artist-filters-flyout", "filter_has_disbanded", "y", t(ctx, "artists.filter.has_disbanded"), filterState(data.Filters, "has_disbanded"))
					@components.FilterItem("artist-filters-flyout", "filter_has_born", "y", t(ctx, "artists.filter.has_born"), filterState(data.Filters, "has_born"))
					@components.FilterItem("artist-filters-flyout", "filter_has_died", "y", t(ctx, "artists.filter.has_died"), filterState(data.Filters, "has_died"))
					@components.FilterItem("artist-filters-flyout", "filter_has_gender", "y", t(ctx, "artists.filter.has_gender"), filterState(data.Filters, "has_gender"))
					@components.FilterItem("artist-filters-flyout", "filter_has_type", "y", t(ctx, "artists.filter.has_type"), filterState(data.Filters, "has_type"))
					@components.FilterItem("artist-filters-flyout", "filter_has_country", "y", t(ctx, "artists.filter.has_country"), filterState(data.Filters, "has_country"))
					@components.FilterItem("artist-filters-flyout", "filter_has_genres", "y", t(ctx, "artists.filter.has_genres"), filterState(data.Filters, "has_genres"))
					@components.FilterItem("artist-filters-flyout", "filter_has_styles", "y", t(ctx, "artists.filter.has_styles"), filterState(data.Filters, "has_styles"))
					@components.FilterItem("artist-filters-flyout", "filter_has_moods", "y", t(ctx, "artists.filter.has_moods"), filterState(data.Filters, "has_moods"))
					@components.FilterItem("artist-filters-flyout", "filter_has_members", "y", t(ctx, "artists.filter.has_members"), filterState(data.Filters, "has_members"))
					@components.FilterItem("artist-filters-flyout", "filter_has_discography", "y", t(ctx, "artists.filter.has_discography"), filterState(data.Filters, "has_discography"))
				}
				@components.FilterSection(t(ctx, "artists.filter_section.images")) {
					@components.FilterItem("artist-filters-flyout", "filter_missing_images", "y", t(ctx, "artists.filter.missing_images"), filterState(data.Filters, "missing_images"))
					@components.FilterItem("artist-filters-flyout", "filter_has_thumb", "y", t(ctx, "artists.filter.has_thumb"), filterState(data.Filters, "has_thumb"))
					@components.FilterItem("artist-filters-flyout", "filter_has_fanart", "y", t(ctx, "artists.filter.has_fanart"), filterState(data.Filters, "has_fanart"))
					@components.FilterItem("artist-filters-flyout", "filter_has_logo", "y", t(ctx, "artists.filter.has_logo"), filterState(data.Filters, "has_logo"))
					@components.FilterItem("artist-filters-flyout", "filter_has_banner", "y", t(ctx, "artists.filter.has_banner"), filterState(data.Filters, "has_banner"))
				}
				@components.FilterSection(t(ctx, "artists.filter_section.platform")) {
					@components.FilterItem("artist-filters-flyout", "filter_in_emby", "y", t(ctx, "artists.filter.in_emby"), filterState(data.Filters, "in_emby"))
					@components.FilterItem("artist-filters-flyout", "filter_in_jellyfin", "y", t(ctx, "artists.filter.in_jellyfin"), filterState(data.Filters, "in_jellyfin"))
					@components.FilterItem("artist-filters-flyout", "filter_has_lidarr", "y", t(ctx, "artists.filter.has_lidarr"), filterState(data.Filters, "has_lidarr"))
				}
				@components.FilterSection(t(ctx, "artists.filter_section.status")) {
					@components.FilterItem("artist-filters-flyout", "filter_excluded", "y", t(ctx, "artists.filter.excluded"), filterState(data.Filters, "excluded"))
					@components.FilterItem("artist-filters-flyout", "filter_locked", "y", t(ctx, "artists.filter.locked"), filterState(data.Filters, "locked"))
					@components.FilterItem("artist-filters-flyout", "filter_has_violations", "y", t(ctx, "artists.filter.has_violations"), filterState(data.Filters, "has_violations"))
				}
				@components.FilterSection(t(ctx, "artists.filter_section.artist_type")) {
					@components.FilterItem("artist-filters-flyout", "filter_type_person", "y", t(ctx, "artists.filter.person"), filterState(data.Filters, "type_person"))
					@components.FilterItem("artist-filters-flyout", "filter_type_group", "y", t(ctx, "artists.filter.group"), filterState(data.Filters, "type_group"))
					@components.FilterItem("artist-filters-flyout", "filter_type_orchestra", "y", t(ctx, "artists.filter.orchestra"), filterState(data.Filters, "type_orchestra"))
				}
				if len(data.Libraries) > 1 {
					@components.FilterSection(t(ctx, "artists.filter_section.library")) {
						for _, lib := range data.Libraries {
							{{ libState := filterState(data.Filters, "library_"+lib.ID) }}
							{{ libLabel := libraryDropdownLabel(lib, data.LibrarySources) }}
							// Whitelist mode (issue #1217): every library pill not
							// set to Include is "out of scope" and rendered dimmed.
							{{ libOutOfScope := libraryWhitelistActive(data.Filters) && libState != "include" }}
							@components.FilterItemLibrary(
								"artist-filters-flyout",
								"filter_library_"+lib.ID,
								"y",
								libLabel,
								libState,
								libOutOfScope,
								tf(ctx, "artists.filter.library_out_of_scope", libLabel),
							)
						}
					}
				}
			}
			if data.View == "grid" {
				@ArtistGrid(data)
			} else {
				@ArtistTable(data)
			}
		</div>
		@BulkProgressPill()
		<script>
			var _artistsBp = (document.querySelector('meta[name="htmx-base-path"]') || {content: ''}).content;
			// Inject flyout filter params from the URL into HTMX requests that
			// target #artist-content. The flyout stores state in the URL only
			// (not in named form elements), so hx-include cannot pick it up.
			document.body.addEventListener('htmx:configRequest', function(evt) {
				if (evt.detail.target && evt.detail.target.id === 'artist-content') {
					var urlParams = new URLSearchParams(window.location.search);
					// Declarative hx-get flows (search, library dropdown,
					// view-toggle buttons) drive their request URL purely
					// from hx-include'd form fields, so the off-page
					// selection scope (ids, #1227) is not carried unless
					// this hook re-injects it. The "Show all" chip
					// intentionally drops ids and opts out via the
					// data-clear-ids attribute on its hx-get element.
					var elt = evt.detail.elt;
					var clearIDs = !!(elt && elt.getAttribute && elt.getAttribute('data-clear-ids') === 'true');
					urlParams.forEach(function(val, key) {
						if (key.indexOf('filter_') === 0 && !(key in evt.detail.parameters)) {
							evt.detail.parameters[key] = val;
							return;
						}
						if (key === 'ids' && !clearIDs && !('ids' in evt.detail.parameters)) {
							evt.detail.parameters.ids = val;
						}
					});
				}
			});

			var _sortActiveClass = 'w-full text-left px-4 py-1.5 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 font-semibold text-blue-600 dark:text-blue-400';
			var _sortInactiveClass = 'w-full text-left px-4 py-1.5 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200';

			// All sortable field keys -- used by updateSortUI to refresh dropdown
			// and column header indicators in one sweep.
			var _sortFields = ['name', 'sort_name', 'type', 'origin', 'health_score', 'updated_at', 'created_at'];

			function updateSortUI(sort, order) {
				var fieldLabel = document.getElementById('sort-field-label');
				var orderLabel = document.getElementById('sort-order-label');
				if (fieldLabel) {
					var activeBtn = document.querySelector('#sort-dropdown button[onclick="setSort(\'' + sort + '\')"]');
					fieldLabel.textContent = activeBtn ? activeBtn.textContent.trim() : sort;
				}
				if (orderLabel) {
					var activeOrder = document.querySelector('#sort-dropdown button[onclick="setOrder(\'' + order + '\')"]');
					orderLabel.textContent = activeOrder ? activeOrder.textContent.trim() : order;
				}
				_sortFields.forEach(function(f) {
					var btn = document.querySelector('#sort-dropdown button[onclick="setSort(\'' + f + '\')"]');
					if (btn) btn.className = f === sort ? _sortActiveClass : _sortInactiveClass;
				});
				['asc', 'desc'].forEach(function(d) {
					var btn = document.querySelector('#sort-dropdown button[onclick="setOrder(\'' + d + '\')"]');
					if (btn) btn.className = d === order ? _sortActiveClass : _sortInactiveClass;
				});
				// Update column header sort indicators. Each sortable <th> has a
				// data-sort-col attribute matching the sort key. The active column
				// shows an arrow (data-dir="asc" or "desc"); all others are hidden.
				document.querySelectorAll('th[data-sort-col]').forEach(function(th) {
					var col = th.getAttribute('data-sort-col');
					var asc = th.querySelector('.sw-sort-asc');
					var desc = th.querySelector('.sw-sort-desc');
					if (!asc || !desc) return;
					if (col === sort) {
						asc.style.display = order === 'asc' ? '' : 'none';
						desc.style.display = order === 'desc' ? '' : 'none';
					} else {
						asc.style.display = 'none';
						desc.style.display = 'none';
					}
				});
			}

			// setSortColumn is called by table column header buttons. It implements
			// a three-state cycle: off -> asc -> desc -> off (revert to name asc).
			// The first click on an inactive column activates it ascending; a second
			// click on the same column flips to descending; a third click removes
			// the explicit sort and returns to the default (name, asc).
			function setSortColumn(field) {
				var sortInput = document.getElementById('artist-sort-input');
				var orderInput = document.getElementById('artist-order-input');
				if (!sortInput || !orderInput) return;
				var newSort, newOrder;
				if (sortInput.value === field) {
					if (orderInput.value === 'asc') {
						// Second click: flip to descending.
						newSort = field;
						newOrder = 'desc';
					} else {
						// Third click: remove explicit sort, revert to default.
						newSort = 'name';
						newOrder = 'asc';
					}
				} else {
					// First click on this column: activate ascending.
					newSort = field;
					newOrder = 'asc';
				}
				sortInput.value = newSort;
				orderInput.value = newOrder;
				updateSortUI(newSort, newOrder);
				htmx.ajax('GET', '/artists', {
					target: '#artist-content',
					swap: 'outerHTML',
					values: buildArtistParams({page: '1'})
				});
			}

			function setSort(field) {
				var sortInput = document.getElementById('artist-sort-input');
				var orderInput = document.getElementById('artist-order-input');
				if (!sortInput || !orderInput) return;
				if (sortInput.value === field) {
					orderInput.value = (orderInput.value === 'asc') ? 'desc' : 'asc';
				} else {
					sortInput.value = field;
					orderInput.value = 'asc';
				}
				updateSortUI(sortInput.value, orderInput.value);
				closeSortDropdown();
				htmx.ajax('GET', '/artists', {
					target: '#artist-content',
					swap: 'outerHTML',
					values: buildArtistParams({page: '1'})
				});
			}

			function setOrder(dir) {
				var sortInput = document.getElementById('artist-sort-input');
				var orderInput = document.getElementById('artist-order-input');
				if (!orderInput) return;
				orderInput.value = dir;
				updateSortUI(sortInput ? sortInput.value : '', dir);
				closeSortDropdown();
				htmx.ajax('GET', '/artists', {
					target: '#artist-content',
					swap: 'outerHTML',
					values: buildArtistParams({page: '1'})
				});
			}

			function closeSortDropdown() {
				var d = document.getElementById('sort-dropdown');
				if (d) d.removeAttribute('open');
			}

			function buildArtistParams(overrides) {
				var params = {};
				// Collect form-based params from named elements.
				['search', 'library_id', 'view', 'sort', 'order'].forEach(function(name) {
					var el = document.querySelector('[name="' + name + '"]');
					if (el) params[name] = el.value;
				});
				// Carry all flyout filter params from the current URL dynamically.
				var urlParams = new URLSearchParams(window.location.search);
				urlParams.forEach(function(val, key) {
					if (key.indexOf('filter_') === 0) {
						params[key] = val;
					}
				});
				// Preserve the off-page selection scope (#1227) across
				// search / sort / view rebuilds. Without this, the URL
				// rebuild in afterSwap drops ids and the user's "Show
				// selected" view collapses on the next interaction.
				var ids = urlParams.get('ids');
				if (ids) params.ids = ids;
				return Object.assign(params, overrides);
			}

			// Update view toggle button classes to reflect the active view.
			// Mirrors the server-side templ.KV classes on the #view-toggle buttons.
			var _viewActiveClass = 'p-2 transition-colors bg-blue-600 text-white';
			var _viewInactiveClass = 'p-2 transition-colors bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700';
			function updateViewToggleUI(view) {
				var toggle = document.getElementById('view-toggle');
				if (!toggle) return;
				var tableBtn = toggle.querySelector('button[onclick="setView(\'table\')"]');
				var gridBtn = toggle.querySelector('button[onclick="setView(\'grid\')"]');
				if (tableBtn) tableBtn.className = view === 'table' ? _viewActiveClass : _viewInactiveClass;
				if (gridBtn) gridBtn.className = view === 'grid' ? _viewActiveClass : _viewInactiveClass;
			}

			function setView(view) {
				var input = document.getElementById('artist-view-input');
				if (input) input.value = view;
				updateViewToggleUI(view);
				// Show/hide column toggle based on view
				var colToggle = document.getElementById('col-toggle-wrapper');
				if (colToggle) {
					if (view === 'table') {
						colToggle.classList.remove('hidden');
					} else {
						colToggle.classList.add('hidden');
					}
				}
				// Fire-and-forget save preference
				var csrfToken = document.cookie.replace(/(?:(?:^|.*;\s*)csrf_token\s*\=\s*([^;]*).*$)|^.*$/, "$1");
				fetch(_artistsBp + '/api/v1/settings', {
					method: 'PUT',
					headers: {'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken},
					body: JSON.stringify({"ui.artists_view": view})
				}).catch(function() {});
			}

			// After HTMX swaps artist content, push the current filter/sort state
			// into the URL so browser back-navigation restores the correct view.
			// Uses window.location.pathname (not hardcoded '/artists') for basePath
			// support, and carries over the page param from the HTMX request URL.
			document.body.addEventListener('htmx:afterSwap', function(evt) {
				if (evt.detail.target && evt.detail.target.id === 'artist-content') {
					// Re-sync flyout state from URL after any swap (including chip dismissals
					// via DismissFilterChip, which bypass the sw:filter-applied event).
					if (window.swFilterFlyout) {
						swFilterFlyout.initFromURL('artist-filters-flyout');
					}

					var params = buildArtistParams({});
					// Extract page and the off-page selection scope (#1227)
					// from the HTMX request URL. The "Show selected" click
					// adds ids; the "Show all" click drops it. The history
					// rebuild must mirror whichever the request actually
					// carried so back-navigation restores the right view.
					try {
						// Use documented HTMX 2.x afterSwap fields. Priority order:
						//   1. evt.detail.pathInfo.finalRequestPath (canonical 2.x; reflects
						//      htmx-side hx-push-url rewrites)
						//   2. evt.detail.pathInfo.requestPath (initial request path)
						//   3. evt.detail.requestConfig.path (legacy fallback)
						//   4. evt.detail.xhr.responseURL (post-HTTP-redirect URL)
						// Migrated to pathInfo per #1228 to match the htmx 2.x event
						// contract. The legacy 2-level fallback (requestConfig.path,
						// xhr.responseURL) is preserved below as a defensive
						// belt-and-braces against runtime event-shape drift.
						var pi = evt.detail.pathInfo;
						var rc = evt.detail.requestConfig;
						var xhr = evt.detail.xhr;
						var rawPath = (pi && (pi.finalRequestPath || pi.requestPath)) ||
							(rc && rc.path) ||
							(xhr && xhr.responseURL);
						if (!rawPath) {
							// Surface silent-fail in the console so future htmx event-shape
							// regressions show up during dev/UAT instead of presenting as a
							// stale URL bar with no other symptom.
							if (window.console && console.debug) {
								console.debug('[artists] htmx:afterSwap missing pathInfo/requestConfig; URL state not updated', evt.detail);
							}
							// Bail out of the entire handler so history.replaceState below
							// does not rewrite the URL from the stale params snapshot.
							return;
						}
						var reqUrl = new URL(rawPath, window.location.origin);
						var ids = reqUrl.searchParams.get('ids');
						if (ids) {
							params.ids = ids;
						} else {
							delete params.ids;
						}
						var page = reqUrl.searchParams.get('page');
						if (page && page !== '1') params.page = page;
						var pageSize = reqUrl.searchParams.get('page_size');
						if (pageSize) params.page_size = pageSize;
					} catch(e) {
						// Mirror the no-rawPath path's debug log so a malformed
						// URL/event regression surfaces in the console during
						// dev/UAT instead of presenting as a stale URL bar.
						if (window.console && console.debug) {
							console.debug('[artists] htmx:afterSwap URL parse failed; URL state not updated', e, evt.detail);
						}
						// Same reasoning as the no-rawPath bail-out: if URL parse
						// fails for any reason, the params snapshot is stale and
						// rewriting history with it would clobber the user URL bar.
						return;
					}
					var qs = Object.keys(params).filter(function(k) { return params[k]; }).map(function(k) {
						return encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
					}).join('&');
					history.replaceState(null, '', window.location.pathname + (qs ? '?' + qs : ''));
				}
			});

			// Reload artist content when the filter flyout applies filters.
			document.body.addEventListener('sw:filter-applied', function(evt) {
				if (evt.target && evt.target.id === 'artist-content') {
					// Strip the base path from location.pathname before passing to htmx.ajax
					// to avoid a double-prefix from the htmx:configRequest hook.
					var bpMeta = document.querySelector('meta[name="htmx-base-path"]');
					var bp = bpMeta ? bpMeta.content : '';
					var path = window.location.pathname;
					if (bp && path.startsWith(bp)) {
						path = path.slice(bp.length) || '/';
					}
					htmx.ajax('GET', path + window.location.search, {target: '#artist-content', swap: 'outerHTML'});
				}
			});

			// Initialise the flyout from URL params on first page load.
			document.addEventListener('DOMContentLoaded', function() {
				if (window.swFilterFlyout) {
					swFilterFlyout.initFromURL('artist-filters-flyout');
				}
			});

			// restoreStateFromURL syncs all filter controls, hidden inputs,
			// sort labels, and view toggle from the current URL query params,
			// then triggers an HTMX content reload so the artist list matches
			// the URL state. Used by both pageshow (bfcache) and popstate
			// (history back/forward) handlers.
			//
			// A debounce guard prevents duplicate calls when bfcache restore
			// fires both pageshow and popstate in quick succession.
			var _restoreLastRun = 0;
			var _restoreLastHref = '';
			function restoreStateFromURL() {
				var now = Date.now();
				var href = window.location.href;
				if (href === _restoreLastHref && now - _restoreLastRun < 100) return;
				_restoreLastHref = href;
				_restoreLastRun = now;
				var params = new URLSearchParams(window.location.search);
				// Re-sync flyout chip states from URL.
				if (window.swFilterFlyout) {
					swFilterFlyout.initFromURL('artist-filters-flyout');
				}
				// Sync the search input from URL params.
				var searchEl = document.getElementById('artist-search');
				if (searchEl) searchEl.value = params.get('search') || '';
				// Sync select elements from URL params.
				['library_id'].forEach(function(name) {
					var val = params.get(name);
					var el = document.querySelector('select[name="' + name + '"]');
					if (el) el.value = (val !== null) ? val : '';
				});
				// Sync hidden inputs from URL params, resetting to markup
				// defaults when a param is absent so browser history
				// restoration cannot retain stale values from a newer state.
				['view', 'sort', 'order'].forEach(function(name) {
					var val = params.get(name);
					var el = document.getElementById('artist-' + name + '-input');
					if (el) el.value = (val !== null) ? val : el.defaultValue;
				});
				// Update visible sort labels and view toggle to match restored state.
				var sortInput = document.getElementById('artist-sort-input');
				var orderInput = document.getElementById('artist-order-input');
				if (sortInput && orderInput) updateSortUI(sortInput.value, orderInput.value);
				var viewInput = document.getElementById('artist-view-input');
				if (viewInput) {
					updateViewToggleUI(viewInput.value);
					var colToggle = document.getElementById('col-toggle-wrapper');
					if (colToggle) colToggle.classList.toggle('hidden', viewInput.value !== 'table');
				}
				var _rsMeta = document.querySelector('meta[name="htmx-base-path"]');
				var _rsBp = _rsMeta ? _rsMeta.content : '';
				var _rsPath = window.location.pathname;
				if (_rsBp && _rsPath.startsWith(_rsBp)) { _rsPath = _rsPath.slice(_rsBp.length) || '/'; }
				htmx.ajax('GET', _rsPath + window.location.search, {target: '#artist-content', swap: 'outerHTML'});
			}

			// When the page is restored from bfcache (browser back/forward navigation),
			// sync filter controls from the URL query params and reload content so
			// status badges reflect the latest state.
			window.addEventListener('pageshow', function(evt) {
				if (evt.persisted) {
					restoreStateFromURL();
				}
			});

			// Handle browser back/forward navigation between pushState entries
			// (e.g. filter changes, pagination). Without this, pressing back after
			// applying filters and navigating away would show stale content even
			// though the URL contains the correct filter params. Works in Firefox
			// and all major browsers.
			window.addEventListener('popstate', function() {
				restoreStateFromURL();
			});

			(function() {
				var btn = document.getElementById('scan-btn');
				if (!btn) return;

				document.body.addEventListener('htmx:afterRequest', function(evt) {
					if (evt.detail.elt !== btn) return;
					if (!evt.detail.successful) return;

					var spinner = document.getElementById('scan-spinner');
					var label = document.getElementById('scan-label');
					btn.disabled = true;
					spinner.classList.remove('hidden');
					label.textContent = btn.dataset.labelScanning || 'Scanning...';

					function resetScanUI() {
						btn.disabled = false;
						spinner.classList.add('hidden');
						label.textContent = btn.dataset.labelScan || 'Scan Library';
					}
					pollAsyncStatus(_artistsBp + '/api/v1/scanner/status', {
						onData: function(data) {
							if (data.status === 'completed' || data.status === 'failed' || data.status === 'canceled') {
								resetScanUI();
								var _scMeta = document.querySelector('meta[name="htmx-base-path"]');
								var _scBp = _scMeta ? _scMeta.content : '';
								var _scPath = window.location.pathname;
								if (_scBp && _scPath.startsWith(_scBp)) { _scPath = _scPath.slice(_scBp.length) || '/'; }
								htmx.ajax('GET', _scPath + window.location.search, {target: '#artist-content', swap: 'outerHTML'});
								return true;
							}
							return false;
						},
						onHTTPError: function() {
							resetScanUI();
						},
						onNetworkError: function() {
							resetScanUI();
						}
					});
				});
			})();

			// Bulk-action controller. Wires the Select-All checkbox, per-row
			// checkboxes, the "N selected" indicator, and the action dropdown
			// to the /api/v1/artists/bulk-actions endpoint. The controller is
			// idempotent: it attaches listeners via event delegation so it
			// works across HTMX swaps of #artist-content without re-binding.
			(function() {
				// Selection state persists across HTMX swaps of the list so
				// the user can paginate while keeping earlier selections.
				var selected = new Set();
				// Matches the backend cap in handlers_bulk_actions.go; keeps
				// the UI in sync so we never POST a payload the server will
				// reject with a generic "failed to start" toast.
				var MAX_BULK_SELECTION = 1000;
				var capWarned = false;
				// Tracks the last checkbox clicked for shift-click range
				// selection (Gmail/GitHub-style). Reset on scope change.
				var lastClickedId = null;
				// Polling handle for the in-flight bulk action status. Non-null
				// while a bulk or single-artist run-rules action is running.
				var progressPoll = null;
				// Tracks whether a bulk action is running end-to-end. Gates the
				// Apply button so checkbox/dropdown changes cannot re-enable it
				// mid-flight and queue a second POST (which would 409-loop).
				var bulkActionRunning = false;

				function warnCap() {
					if (capWarned) return;
					capWarned = true;
					var bar = document.getElementById('bulk-action-bar');
					var tpl = (bar && bar.getAttribute('data-i18n-selection-cap')) || 'You can select up to {count} artists at a time.';
					alert(tpl.replace('{count}', String(MAX_BULK_SELECTION)));
				}

				function tryAdd(id) {
					if (selected.has(id)) return true;
					if (selected.size >= MAX_BULK_SELECTION) {
						warnCap();
						return false;
					}
					selected.add(id);
					return true;
				}

				function updateBar() {
					var bar = document.getElementById('bulk-action-bar');
					if (!bar) return;
					var countEl = document.getElementById('bulk-selected-count');
					var applyBtn = document.getElementById('bulk-action-apply');
					var selectEl = document.getElementById('bulk-action-select');
					var selectAll = document.getElementById('bulk-select-all');
					var showSelectedBtn = document.getElementById('bulk-show-selected');
					var boxes = document.querySelectorAll('#artist-content .sw-bulk-select');
					var i18nNone = bar.getAttribute('data-i18n-none') || 'None selected';
					var i18nSelectedOne = bar.getAttribute('data-i18n-selected-one') || '1 selected';
					var i18nSelectedOther = bar.getAttribute('data-i18n-selected-other') || '{count} selected';
					var i18nSplitOne = bar.getAttribute('data-i18n-selected-split-one') || '{total} selected ({onpage} on this page, 1 elsewhere)';
					var i18nSplitOther = bar.getAttribute('data-i18n-selected-split-other') || '{total} selected ({onpage} on this page, {offpage} elsewhere)';
					// Sync per-row checkboxes with persisted selection state and
					// count the on-page hits in the same pass so the toolbar
					// count can name how many of the selection are visible vs
					// off-page (issue #1227). visibleChecked counts checked
					// boxes among rows currently in the DOM; offPage is the
					// remainder of the selection that lives on other pages.
					var visibleChecked = 0;
					boxes.forEach(function(cb) {
						var id = cb.getAttribute('data-artist-id');
						cb.checked = selected.has(id);
						if (cb.checked) visibleChecked++;
					});
					var offPage = selected.size - visibleChecked;
					if (offPage < 0) offPage = 0;
					if (countEl) {
						if (selected.size === 0) {
							countEl.textContent = i18nNone;
						} else if (offPage === 0) {
							if (selected.size === 1) {
								countEl.textContent = i18nSelectedOne;
							} else {
								countEl.textContent = i18nSelectedOther.replace('{count}', String(selected.size));
							}
						} else {
							var tpl = offPage === 1 ? i18nSplitOne : i18nSplitOther;
							countEl.textContent = tpl
								.replace('{total}', String(selected.size))
								.replace('{onpage}', String(visibleChecked))
								.replace('{offpage}', String(offPage));
						}
					}
					if (applyBtn) applyBtn.disabled = bulkActionRunning || selected.size === 0 || !selectEl || !selectEl.value;
					if (selectEl) selectEl.disabled = bulkActionRunning || selected.size === 0;
					// Toggle the "Show selected" affordance: hidden when no
					// selection exists; visible (as inline-flex) once at least
					// one item is in the selection store. We use a single
					// display utility per state to avoid the "two display
					// classes co-applied, later one wins" cascade trap (memory
					// feedback_css_cascade_display_utilities).
					if (showSelectedBtn) {
						if (selected.size === 0) {
							showSelectedBtn.classList.add('hidden');
							showSelectedBtn.classList.remove('inline-flex');
							showSelectedBtn.disabled = true;
						} else {
							showSelectedBtn.classList.remove('hidden');
							showSelectedBtn.classList.add('inline-flex');
							showSelectedBtn.disabled = bulkActionRunning;
						}
					}
					// Select-All indeterminate state.
					var allChecked = false;
					if (selectAll) {
						if (boxes.length === 0) {
							selectAll.checked = false;
							selectAll.indeterminate = false;
						} else if (visibleChecked === 0) {
							selectAll.checked = false;
							selectAll.indeterminate = false;
						} else if (visibleChecked === boxes.length) {
							selectAll.checked = true;
							selectAll.indeterminate = false;
							allChecked = true;
						} else {
							selectAll.checked = false;
							selectAll.indeterminate = true;
						}
					}
					// Swap the checkbox label between Select all / Deselect all
					// so screen readers and sighted users both see the action
					// that a click will perform next.
					var labelEl = document.getElementById('bulk-select-all-label');
					if (labelEl) {
						var i18nSelectAll = bar.getAttribute('data-i18n-select-all') || 'Select all on page';
						var i18nDeselectAll = bar.getAttribute('data-i18n-deselect-all') || 'Deselect all on page';
						labelEl.textContent = allChecked ? i18nDeselectAll : i18nSelectAll;
					}
					if (selectAll) {
						var i18nSelectAllAria = bar.getAttribute('data-i18n-select-all') || 'Select all on page';
						var i18nDeselectAllAria = bar.getAttribute('data-i18n-deselect-all') || 'Deselect all on page';
						selectAll.setAttribute('aria-label', allChecked ? i18nDeselectAllAria : i18nSelectAllAria);
					}
					// "Select all N matching" affordance: show only when every
					// visible row is checked AND the result spans more than one
					// page (i.e. there are artists off-screen that could also be
					// selected). Hide it when fewer than all visible rows are
					// checked, when only one page exists, or when a bulk action
					// is running.
					var selectAllMatchingBtn = document.getElementById('bulk-select-all-matching');
					if (selectAllMatchingBtn) {
						var totalPages = parseInt(bar.getAttribute('data-total-pages') || '1', 10);
						var totalMatching = parseInt(bar.getAttribute('data-total-matching') || '0', 10);
						// Show if: all visible rows checked, more than one page, no
						// bulk action running, and at least one visible row exists.
						var showMatchingBtn = allChecked && totalPages > 1 && !bulkActionRunning && boxes.length > 0;
						if (showMatchingBtn) {
							// Update label and aria to reflect the true total.
							var matchingTpl = bar.getAttribute('data-i18n-select-all-matching') || 'Select all {total} matching';
							var matchingAria = bar.getAttribute('data-i18n-select-all-matching-aria') || 'Select all {total} artists matching the current filters';
							selectAllMatchingBtn.textContent = matchingTpl.replace('{total}', String(totalMatching));
							selectAllMatchingBtn.setAttribute('aria-label', matchingAria.replace('{total}', String(totalMatching)));
							selectAllMatchingBtn.classList.remove('hidden');
							selectAllMatchingBtn.classList.add('inline-flex');
							selectAllMatchingBtn.disabled = false;
						} else {
							selectAllMatchingBtn.classList.add('hidden');
							selectAllMatchingBtn.classList.remove('inline-flex');
							selectAllMatchingBtn.disabled = true;
						}
					}
				}

				// Shift-click range selection: capture on click (before the
				// change event) so we can see event.shiftKey. If shift is
				// held and we have a prior lastClickedId, select/deselect
				// every checkbox between the two anchors in DOM order.
				document.body.addEventListener('click', function(ev) {
					var t = ev.target;
					if (!t || !t.classList || !t.classList.contains('sw-bulk-select')) return;
					var id = t.getAttribute('data-artist-id');
					if (!id) return;
					// Keyboard Shift+Space triggers a click with shiftKey.
					if (ev.shiftKey && lastClickedId && lastClickedId !== id) {
						var boxes = Array.prototype.slice.call(
							document.querySelectorAll('#artist-content .sw-bulk-select')
						);
						var idx1 = -1, idx2 = -1;
						for (var i = 0; i < boxes.length; i++) {
							var bid = boxes[i].getAttribute('data-artist-id');
							if (bid === lastClickedId) idx1 = i;
							if (bid === id) idx2 = i;
						}
						if (idx1 >= 0 && idx2 >= 0) {
							var lo = Math.min(idx1, idx2), hi = Math.max(idx1, idx2);
							// Target state follows the just-clicked checkbox's
							// post-click state (which the browser has already
							// set by the time this click handler runs).
							var target = t.checked;
							for (var j = lo; j <= hi; j++) {
								var cb = boxes[j];
								var cid = cb.getAttribute('data-artist-id');
								if (!cid) continue;
								if (target) {
									if (!tryAdd(cid)) { cb.checked = false; continue; }
									cb.checked = true;
								} else {
									selected.delete(cid);
									cb.checked = false;
								}
							}
							if (!target) capWarned = false;
							updateBar();
						}
					}
					lastClickedId = id;
				}, true);

				document.body.addEventListener('change', function(ev) {
					var t = ev.target;
					if (!t) return;
					if (t.classList && t.classList.contains('sw-bulk-select')) {
						var id = t.getAttribute('data-artist-id');
						if (!id) return;
						if (t.checked) {
							if (!tryAdd(id)) { t.checked = false; }
						} else {
							selected.delete(id);
							capWarned = false;
						}
						updateBar();
					} else if (t.id === 'bulk-select-all') {
						var boxes = document.querySelectorAll('#artist-content .sw-bulk-select');
						boxes.forEach(function(cb) {
							var id = cb.getAttribute('data-artist-id');
							if (!id) return;
							if (t.checked) {
								cb.checked = tryAdd(id);
							} else {
								cb.checked = false;
								selected.delete(id);
							}
						});
						if (!t.checked) capWarned = false;
						updateBar();
					} else if (t.id === 'bulk-action-select') {
						updateBar();
					}
				});

				// Build the localized verb label for a bulk action from the
				// data attributes on the progress pill. Falls back to the
				// raw action key if a verb is missing.
				function actionVerb(action) {
					var pill = document.getElementById('bulk-progress-pill');
					if (!pill) return action;
					var key = 'data-i18n-verb-' + action.replace(/_/g, '-');
					return pill.getAttribute(key) || action;
				}

				// Render the progress pill with the current snapshot. Called
				// from both the initial 202 response and the poll callback.
				function renderProgressPill(action, processed, total) {
					var pill = document.getElementById('bulk-progress-pill');
					var txt = document.getElementById('bulk-progress-text');
					if (!pill || !txt) return;
					var tpl = pill.getAttribute('data-i18n-template') || '{verb}: {processed} of {total} artists';
					var verb = actionVerb(action);
					txt.textContent = tpl
						.replace('{verb}', verb)
						.replace('{processed}', String(processed))
						.replace('{total}', String(total));
					pill.classList.remove('hidden');
					// Re-enable the cancel button each render tick so a prior
					// canceled run does not leave the button disabled on the
					// next action.
					var cancelBtn = document.getElementById('bulk-progress-cancel');
					if (cancelBtn) cancelBtn.disabled = false;
				}

				function hideProgressPill() {
					var pill = document.getElementById('bulk-progress-pill');
					if (pill) pill.classList.add('hidden');
				}

				// Start polling bulk-actions/status every 2s. Stops on terminal
				// status and surfaces an outcome-breakdown toast. Page reloads
				// mid-action re-attach by calling this on DOMContentLoaded.
				// Process one /status snapshot. Returns true when the status
				// is terminal (idle/completed/failed) so callers know to stop
				// polling and do not need to start one. Shared between the
				// active poll callback and the DOMContentLoaded recovery
				// path so a page reload near the end of a bulk job still
				// surfaces the summary toast from the terminal snapshot.
				function handleProgressSnapshot(data, initialAction) {
					if (!data || data.status === 'idle') {
						hideProgressPill();
						bulkActionRunning = false;
						updateBar();
						return true;
					}
					renderProgressPill(data.action || initialAction || '', data.processed || 0, data.total || 0);
					// Reveal the cancel button only for bulk-actions runs.
					// The pill is reused by single-artist flows (e.g. the
					// detail-page run-rules) that do not go through /bulk-
					// actions/cancel and have no cancel affordance.
					var _cancelBtn = document.getElementById('bulk-progress-cancel');
					if (_cancelBtn) _cancelBtn.classList.remove('hidden');
					if (data.status === 'completed' || data.status === 'failed' || data.status === 'canceled') {
						hideProgressPill();
						bulkActionRunning = false;
						updateBar();
						var pill = document.getElementById('bulk-progress-pill');
						// Re-identify auto breaks out auto_linked/queued/
						// no_match counters so the toast can say "3 auto-
						// linked, 2 queued, 1 no match" instead of the
						// generic succeeded/skipped triad. Other actions
						// keep the existing summary text.
						var msg;
						if ((data.action === 're_identify_auto' || data.action === 're_identify') &&
							((data.auto_linked || 0) + (data.queued || 0) + (data.no_match || 0) + (data.failed || 0) > 0)) {
							var rtpl = (pill && pill.getAttribute('data-i18n-reidentify-summary')) ||
								'{auto_linked} auto-linked, {queued} queued, {no_match} no match';
							msg = rtpl
								.replace('{auto_linked}', String(data.auto_linked || 0))
								.replace('{queued}', String(data.queued || 0))
								.replace('{no_match}', String(data.no_match || 0))
								.replace('{failed}', String(data.failed || 0));
						} else {
							var tpl = (pill && pill.getAttribute('data-i18n-summary')) || '{succeeded} succeeded, {failed} failed, {skipped} skipped';
							msg = tpl
								.replace('{succeeded}', String(data.succeeded || 0))
								.replace('{failed}', String(data.failed || 0))
								.replace('{skipped}', String(data.skipped || 0));
						}
						if (typeof window.showSuccessToast === 'function' && (data.failed || 0) === 0) {
							window.showSuccessToast(msg);
						} else if (typeof window.showToast === 'function') {
							window.showToast(msg);
						}
						return true;
					}
					return false;
				}

				function startProgressPoll(initialAction) {
					if (progressPoll) { progressPoll.stop(); progressPoll = null; }
					bulkActionRunning = true;
					updateBar();
					progressPoll = pollAsyncStatus(_artistsBp + '/api/v1/artists/bulk-actions/status', {
						onData: function(data) {
							return handleProgressSnapshot(data, initialAction);
						},
						onHTTPError: function() {
							// Transport/HTTP errors are non-terminal: the backend
							// job may still be running. Keep bulkActionRunning set
							// so Apply stays disabled; a later idle/completed/
							// failed snapshot from the polling retry will clear
							// the lock. Releasing here would reopen the duplicate-
							// submit window and reintroduce the 409 loop.
							updateBar();
						},
						onNetworkError: function() {
							// Same rationale as onHTTPError: the status endpoint
							// may be transiently unreachable while the action is
							// still running. Do not clear the lock on an unknown
							// status.
							updateBar();
						}
					});
				}
				// Expose so other controllers (single-artist run-rules on the
				// artist detail page) can attach to an in-flight action.
				window.swBulkProgress = {
					start: startProgressPoll,
					render: renderProgressPill,
					hide: hideProgressPill
				};

				// Cancel the in-flight bulk action. The button is wired via
				// onclick on the pill; the poll loop picks up the terminal
				// "canceled" status on the next tick and clears the pill.
				window.swCancelBulkAction = function() {
					var btn = document.getElementById('bulk-progress-cancel');
					if (btn) btn.disabled = true;
					var csrfToken = document.cookie.replace(/(?:(?:^|.*;\s*)csrf_token\s*\=\s*([^;]*).*$)|^.*$/, "$1");
					fetch(_artistsBp + '/api/v1/artists/bulk-actions/cancel', {
						method: 'POST',
						credentials: 'same-origin',
						headers: {'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken}
					}).catch(function() {
						if (btn) btn.disabled = false;
					});
				};

				// Size-aware confirm dialog. <=50: no dialog; >50 and <=500:
				// simple confirm with action + count; >500: stronger warning
				// that names external API impact for re-identify and
				// fetch_images. Returns true when the user confirmed.
				function confirmBulkAction(action, count) {
					if (count <= 50) return true;
					var pill = document.getElementById('bulk-progress-pill');
					// Use the action-dropdown's selected option label so the
					// confirm text reads naturally (e.g. "Apply Run rules to
					// 100 artists?") rather than the progress-verb form.
					var selectEl = document.getElementById('bulk-action-select');
					var verb = action;
					if (selectEl && selectEl.selectedOptions && selectEl.selectedOptions[0]) {
						verb = selectEl.selectedOptions[0].textContent || action;
					}
					// The large-count copy names external provider APIs, so
					// only use it for actions that actually hit them. Local
					// actions (scan, run_rules) get the plain small template
					// regardless of count to avoid misleading warnings.
					var usesExternalProviders = action === 're_identify_auto' || action === 're_identify_review' || action === 'fetch_images';
					var tpl;
					if (count > 500 && usesExternalProviders) {
						tpl = (pill && pill.getAttribute('data-i18n-confirm-large')) || 'You are about to apply {action} to {count} artists. This may take a while and will hit external provider APIs (MusicBrainz, Fanart.tv, etc.). Continue?';
					} else {
						tpl = (pill && pill.getAttribute('data-i18n-confirm-small')) || 'Apply {action} to {count} artists?';
					}
					var msg = tpl.replace('{action}', verb).replace('{count}', String(count));
					return window.confirm(msg);
				}

				// "Show selected" affordance (#1227): when sort moves selected
				// artists off the current page, the toolbar count names how
				// many are on this page vs elsewhere. Clicking "Show selected"
				// issues an htmx GET to /artists with the current selection
				// as `ids=` so the user can review the entire selection in
				// one place. We reuse htmx.ajax (rather than a plain anchor)
				// so the swap target stays #artist-content and the existing
				// afterSwap URL listener pushes the new state onto history.
				document.body.addEventListener('click', function(ev) {
					var t = ev.target;
					if (!t || t.id !== 'bulk-show-selected') return;
					if (selected.size === 0) return;
					var ids = Array.from(selected).slice(0, MAX_BULK_SELECTION);
					var params = buildArtistParams({page: '1', ids: ids.join(',')});
					if (window.htmx) {
						// Root-relative path here -- the document-level
						// htmx:configRequest hook prepends basePath, so
						// embedding _artistsBp would double-prefix on
						// sub-path deployments.
						window.htmx.ajax('GET', '/artists', {
							target: '#artist-content',
							swap: 'outerHTML',
							values: params
						});
					}
				});

				// "Select all N matching" click handler: fetch the full cross-page
				// ID list from GET /api/v1/artists/matching-ids using the same
				// filter params currently in the URL, then load all returned IDs
				// into the `selected` Set (up to MAX_BULK_SELECTION). Captures
				// the scope token at the moment of the fetch so a filter change
				// that races the response causes the stale result to be discarded.
				document.body.addEventListener('click', function(ev) {
					var t = ev.target;
					if (!t || t.id !== 'bulk-select-all-matching') return;
					t.disabled = true;

					// Snapshot the scope token so we can detect a filter change
					// that races the async fetch. Capture the current URL params
					// to forward as query-string on the matching-ids request.
					var scopeAtFetch = currentScopeToken();
					var currentParams = new URLSearchParams(window.location.search);

					// Build the matching-ids URL, forwarding all filter params
					// that parseFlyoutFilters and handleArtistMatchingIDs understand.
					var idsURL = _artistsBp + '/api/v1/artists/matching-ids';
					var forwardKeys = ['search', 'filter', 'library_id'];
					var fwd = new URLSearchParams();
					currentParams.forEach(function(v, k) {
						if (forwardKeys.indexOf(k) >= 0 || k.indexOf('filter_') === 0) {
							fwd.set(k, v);
						}
					});
					var qs = fwd.toString();
					if (qs) idsURL += '?' + qs;

					fetch(idsURL, {credentials: 'same-origin'})
						.then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
						.then(function(data) {
							// Discard the response if a filter change has happened since
							// the fetch started (scope-token drift). The user is now
							// looking at a different result set.
							if (currentScopeToken() !== scopeAtFetch) { if (t) t.disabled = false; return; }

							var bar = document.getElementById('bulk-action-bar');
							if (!data || !Array.isArray(data.ids)) {
								alert((bar && bar.getAttribute('data-i18n-select-all-matching-failed')) || 'Could not load the full matching list. Please try again.');
								if (t) t.disabled = false;
								return;
							}

							// Load returned IDs into the selection, up to the hard cap.
							selected.clear();
							capWarned = false;
							for (var i = 0; i < data.ids.length; i++) {
								if (!tryAdd(data.ids[i])) break;
							}

							// Warn the user if the server returned a capped result.
							if (data.capped) {
								var cappedTpl = (bar && bar.getAttribute('data-i18n-select-all-matching-capped')) || 'Loaded {count} of {total} matching artists (limit reached). Actions will apply to these {count} only.';
								alert(cappedTpl
									.replace(/{count}/g, String(selected.size))
									.replace('{total}', String(data.total)));
							}

							updateBar();
						})
						.catch(function() {
							var bar = document.getElementById('bulk-action-bar');
							alert((bar && bar.getAttribute('data-i18n-select-all-matching-failed')) || 'Could not load the full matching list. Please try again.');
							if (t) t.disabled = false;
						});
				});

				document.body.addEventListener('click', function(ev) {
					var t = ev.target;
					if (!t || t.id !== 'bulk-action-apply') return;
					var selectEl = document.getElementById('bulk-action-select');
					if (!selectEl || !selectEl.value || selected.size === 0) return;
					var action = selectEl.value;
					// Defensive truncation: the UI cap should already prevent
					// this, but guard against any drift so we never hit the
					// backend's hard 1000-ID rejection with a generic toast.
					var ids = Array.from(selected).slice(0, MAX_BULK_SELECTION);
					if (!confirmBulkAction(action, ids.length)) return;
					var csrfToken = document.cookie.replace(/(?:(?:^|.*;\s*)csrf_token\s*\=\s*([^;]*).*$)|^.*$/, "$1");
					t.disabled = true;
					// Re-identify (review) dispatches to the wizard flow
					// rather than the bulk-actions endpoint: the wizard is
					// interactive and owns its own session state, so routing
					// it through the singleton bulk-action slot would be
					// misleading. Start the wizard then redirect the user to
					// its first step.
					if (action === 're_identify_review') {
						fetch(_artistsBp + '/api/v1/artists/re-identify/wizard', {
							method: 'POST',
							headers: {'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken},
							body: JSON.stringify({ids: ids})
						}).then(function(r) {
							if (!r.ok) {
								var bar3 = document.getElementById('bulk-action-bar');
								alert((bar3 && bar3.getAttribute('data-i18n-failed')) || 'Bulk action failed to start.');
								t.disabled = false;
								return;
							}
							return r.json();
						}).then(function(data) {
							if (!data || !data.session_id) return;
							window.location.href = _artistsBp + '/artists/re-identify/wizard/' + data.session_id + '/step/0';
						}).catch(function() {
							t.disabled = false;
						});
						return;
					}
					fetch(_artistsBp + '/api/v1/artists/bulk-actions', {
						method: 'POST',
						headers: {'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken},
						body: JSON.stringify({action: action, ids: ids})
					}).then(function(r) {
						var bar = document.getElementById('bulk-action-bar');
						var i18nBusy = (bar && bar.getAttribute('data-i18n-busy')) || 'A bulk action is already running. Please wait for it to finish.';
						var i18nFailed = (bar && bar.getAttribute('data-i18n-failed')) || 'Bulk action failed to start.';
						if (r.status === 409) {
							alert(i18nBusy);
							t.disabled = false;
						} else if (!r.ok) {
							alert(i18nFailed);
							t.disabled = false;
						} else {
							// Render an immediate 0-of-total pill so the user sees
							// feedback before the first poll tick lands, then
							// start polling. Apply-disabled stays true until the
							// poll observes a terminal status.
							renderProgressPill(action, 0, ids.length);
							selected.clear();
							capWarned = false;
							updateBar();
							startProgressPoll(action);
						}
					}).catch(function() {
						var bar2 = document.getElementById('bulk-action-bar');
						alert((bar2 && bar2.getAttribute('data-i18n-failed')) || 'Bulk action failed to start.');
						t.disabled = false;
					});
				});

				// Scope token: filter-identifying params only. If any of
				// these change across an htmx swap, the user is looking
				// at a different result set and the previous selection is
				// no longer meaningful. Pagination, sort, order, and view
				// do NOT reset selection so the user can re-sort, paginate,
				// or switch table/grid while preserving their selection.
				//
				// Prefer the explicit URLSearchParams source over
				// window.location.search so the same routine works whether
				// we are reacting to an htmx swap (where the URL has
				// already been updated by the listener at line 638) or
				// computing the initial token at IIFE init.
				function tokenFromParams(p) {
					var keys = [];
					p.forEach(function(_v, k) {
						if (k === 'search' || k === 'library_id' || k === 'filter' || k.indexOf('filter_') === 0) {
							keys.push(k);
						}
					});
					keys.sort();
					return keys.map(function(k) { return k + '=' + p.get(k); }).join('&');
				}
				function currentScopeToken() {
					return tokenFromParams(new URLSearchParams(window.location.search));
				}
				// Compute the scope token from an htmx request URL. Used in
				// the afterSwap handler to derive the new scope without
				// depending on whether the URL-update listener has run yet.
				// htmx 2.0.8 exposes the request configuration on
				// evt.detail.requestConfig.path (the path htmx issued the
				// request to) and the resolved URL on evt.detail.xhr.responseURL
				// (post-redirect). We try requestConfig.path first because it
				// reflects what htmx asked for, fall back to xhr.responseURL,
				// then finally to window.location if neither is present.
				function scopeTokenFromRequest(evt) {
					try {
						var rc = evt && evt.detail && evt.detail.requestConfig;
						var xhr = evt && evt.detail && evt.detail.xhr;
						var path = (rc && rc.path) || (xhr && xhr.responseURL);
						if (path) {
							var u = new URL(path, window.location.origin);
							return tokenFromParams(u.searchParams);
						}
					} catch (e) { /* fall through */ }
					return currentScopeToken();
				}
				var lastScopeToken = currentScopeToken();

				// Re-sync on initial load and after every HTMX swap of the
				// artist content (pagination, filter change, etc.). Also
				// probe the bulk-actions/status endpoint on load so a page
				// reload mid-action re-attaches the progress pill.
				// Seed the `selected` Set from the active `?ids=` URL param.
				// Mirrors the server-side parseIDsParam canonical ID shape
				// (^[A-Za-z0-9_-]{1,64}$, see handlers_artist.go) so the
				// client store stays consistent with what the server rendered:
				// a hand-crafted URL like ?ids=valid,@@ otherwise lets the
				// bulk-action POST submit @@ and earn a 400 wholesale rejection.
				// Capped to MAX_BULK_SELECTION to match the in-memory contract.
				// Idempotent: safe to call after `selected.clear()` on a
				// scope-token change so the toolbar re-syncs with the
				// server-rendered chip when ids= survives the swap.
				function seedSelectedFromURL() {
					try {
						var idRe = /^[A-Za-z0-9_-]{1,64}$/;
						var initialIDs = new URLSearchParams(window.location.search).get('ids');
						if (!initialIDs) return;
						var parts = initialIDs.split(',');
						for (var i = 0; i < parts.length && selected.size < MAX_BULK_SELECTION; i++) {
							var pid = parts[i].trim();
							if (idRe.test(pid)) selected.add(pid);
						}
					} catch (e) { /* ignore */ }
				}

				document.addEventListener('DOMContentLoaded', function() {
					// Seed from any `ids=` URL param so a reload or
					// shareable-link revisit of /artists?ids=a,b,c keeps the
					// toolbar count, the "Show selected" affordance, and the
					// per-row checkboxes consistent with the chip the server
					// already rendered (#1227).
					seedSelectedFromURL();
					updateBar();
					// Fire-and-forget status probe. If an action is in flight
					// the poll attaches; otherwise the pill stays hidden.
					fetch(_artistsBp + '/api/v1/artists/bulk-actions/status', {credentials: 'same-origin'})
						.then(function(r) { return r.ok ? r.json() : null; })
						.then(function(data) {
							// Terminal snapshots (completed/failed/idle) are
							// handled in-place so the summary toast is not
							// dropped on reload-near-end. Non-terminal returns
							// false and we start the normal poll.
							if (!data) return;
							if (handleProgressSnapshot(data, data.action || '')) return;
							startProgressPoll(data.action || '');
						})
						.catch(function(){ /* ignore */ });
				});
				document.body.addEventListener('htmx:afterSwap', function(evt) {
					if (evt.detail.target && evt.detail.target.id === 'artist-content') {
						// Derive the new scope from the htmx request URL so
						// the comparison does not depend on the URL-update
						// listener (line 638) having fired first. This keeps
						// selection stable across sort/order/page/view swaps
						// (issue #1081 F1) regardless of listener ordering.
						var currentToken = scopeTokenFromRequest(evt);
						if (currentToken !== lastScopeToken) {
							selected.clear();
							capWarned = false;
							lastScopeToken = currentToken;
							// Re-seed from the post-swap URL: if the new
							// URL still carries an ids param, the scope-clear
							// above would otherwise leave the toolbar
							// reporting an empty selection while the
							// server-rendered selection chip is still
							// present (search/library/view changes preserve
							// ids via buildArtistParams + the configRequest
							// hook, but change other scope keys).
							seedSelectedFromURL();
						}
						// Reset the shift-click anchor on every swap: after
						// pagination or sort the prior DOM ordering no longer
						// applies, so an old anchor could select an unintended
						// range on the next shift-click.
						lastClickedId = null;
						// Re-derive every checkbox's checked state from the
						// `selected` Set. The freshly-swapped HTML never
						// includes a `checked` attribute, so this is what
						// keeps checkmarks attached to artist IDs (not row
						// positions) across sort changes (issue #1081 F2).
						updateBar();
					}
				});
			})();
		</script>
	}
}

// ArtistTable is the HTMX-swappable table fragment.
// BulkActionBar renders the Select-All control, "N selected" indicator, and
// bulk action dropdown. It is only rendered when a filter is active so the
// user cannot accidentally select the entire library in one click. The bar
// is wired to a small client-side controller (initialized in ArtistsPage)
// that manages checkbox state, Select-All indeterminate, and POSTs the
// selected IDs to /api/v1/artists/bulk-actions.
//
// When a sort change moves selected artists off the current page, the toolbar
// renders an "X selected (Y on this page, Z elsewhere)" form computed by the
// JS controller, and exposes a "Show selected" button that filters the list
// to only the selection (issue #1227). When the selection-filter is active
// (data.IDs non-empty) the bar instead renders a dismissible chip with a
// "Show all" link that clears the filter.
templ BulkActionBar(data ArtistListData) {
	<div
		id="bulk-action-bar"
		class="flex flex-wrap items-center gap-3 mb-3 rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-2"
		role="toolbar"
		aria-label={ t(ctx, "artists.bulk.toolbar") }
		data-i18n-none={ t(ctx, "artists.bulk.none_selected") }
		data-i18n-selected-one={ t(ctx, "artists.bulk.selected.one") }
		data-i18n-selected-other={ t(ctx, "artists.bulk.selected.other") }
		data-i18n-selected-split-one={ t(ctx, "artists.bulk.selected.split.one") }
		data-i18n-selected-split-other={ t(ctx, "artists.bulk.selected.split.other") }
		data-i18n-busy={ t(ctx, "artists.bulk.busy") }
		data-i18n-failed={ t(ctx, "artists.bulk.failed") }
		data-i18n-select-all={ t(ctx, "artists.bulk.select_all") }
		data-i18n-deselect-all={ t(ctx, "artists.bulk.deselect_all") }
		data-i18n-selection-cap={ t(ctx, "artists.bulk.selection_cap") }
		data-i18n-select-all-matching={ t(ctx, "artists.bulk.select_all_matching") }
		data-i18n-select-all-matching-aria={ t(ctx, "artists.bulk.select_all_matching.aria") }
		data-i18n-select-all-matching-capped={ t(ctx, "artists.bulk.select_all_matching.capped") }
		data-i18n-select-all-matching-failed={ t(ctx, "artists.bulk.select_all_matching.failed") }
		data-total-matching={ strconv.Itoa(data.Pagination.TotalItems) }
		data-total-pages={ strconv.Itoa(data.Pagination.TotalPages) }
	>
		<label class="inline-flex items-center gap-2 text-sm text-gray-700 dark:text-gray-200">
			<input
				id="bulk-select-all"
				type="checkbox"
				class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
				aria-controls="artist-content"
				aria-label={ t(ctx, "artists.bulk.select_all") }
			/>
			<span id="bulk-select-all-label">{ t(ctx, "artists.bulk.select_all") }</span>
		</label>
		<span id="bulk-selected-count" class="text-sm text-gray-500 dark:text-gray-400" aria-live="polite">
			{ t(ctx, "artists.bulk.none_selected") }
		</span>
		// "Show selected" affordance: visible only when at least one
		// item is selected. Clicking issues an htmx GET to /artists with
		// an `ids=` filter (preserving the current view) so the user
		// can review or paginate through selections that the active sort
		// pushed onto other pages. The button stays display:none until
		// the JS controller sees a non-empty selection so a stale page
		// (no selection) does not flash the affordance on first paint.
		<button
			id="bulk-show-selected"
			type="button"
			class="hidden ml-1 items-center rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2.5 py-1 text-xs font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 disabled:opacity-50 disabled:cursor-not-allowed"
			aria-label={ t(ctx, "artists.bulk.show_selected.aria") }
			disabled
		>
			{ t(ctx, "artists.bulk.show_selected") }
		</button>
		// "Select all N matching" affordance: appears only after the user
		// has selected all visible rows on a multi-page result set. Clicking
		// it fetches the full cross-page ID list from
		// GET /api/v1/artists/matching-ids and loads it into the `selected`
		// Set, replacing the page-scoped selection. Hidden until JS shows it.
		// The button text and aria-label are updated dynamically by updateBar().
		<button
			id="bulk-select-all-matching"
			type="button"
			class="hidden ml-1 items-center rounded-md border border-blue-300 dark:border-blue-600 bg-blue-50 dark:bg-blue-900/30 px-2.5 py-1 text-xs font-medium text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-800/40 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 disabled:opacity-50 disabled:cursor-not-allowed"
			aria-label={ t(ctx, "artists.bulk.select_all_matching.aria") }
			disabled
		>
			{ t(ctx, "artists.bulk.select_all_matching") }
		</button>
		<div class="ml-auto inline-flex items-center gap-2">
			// docAnchor intentionally empty: the most relevant docs page
			// (how-to/refresh-metadata) talks about a "Bulk actions > Refresh
			// metadata" entry that the dropdown does not actually offer, so
			// linking there would misdirect. The body text covers all five
			// listed actions; a follow-up docs page can replace this with a
			// real anchor.
			@components.ContextHelp("help-artists-bulk-action", t(ctx, "artists.help.bulk_action.label"), t(ctx, "artists.help.bulk_action"), "")
			<select
				id="bulk-action-select"
				class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 disabled:opacity-50"
				disabled
				aria-label={ t(ctx, "artists.bulk.action_label") }
			>
				<option value="">{ t(ctx, "artists.bulk.choose_action") }</option>
				<option value="run_rules">{ t(ctx, "artists.bulk.action.run_rules") }</option>
				<option value="re_identify_auto">{ t(ctx, "artists.bulk.action.re_identify_auto") }</option>
				<option value="re_identify_review">{ t(ctx, "artists.bulk.action.re_identify_review") }</option>
				<option value="scan">{ t(ctx, "artists.bulk.action.scan") }</option>
				<option value="fetch_images">{ t(ctx, "artists.bulk.action.fetch_images") }</option>
			</select>
			<button
				id="bulk-action-apply"
				type="button"
				class="ml-2 inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
				disabled
			>
				{ t(ctx, "artists.bulk.apply") }
			</button>
		</div>
	</div>
	if len(data.IDs) > 0 {
		// Selection-filter chip: only rendered when the server received a
		// non-empty `ids=` parameter, so it stays in sync with the URL on
		// reload, htmx swap, or shareable-link revisit. The "Show all"
		// link drops the `ids` param and re-issues the htmx swap, which
		// the existing pagination URL listener pushes onto window.location.
		<div class="flex flex-wrap items-center gap-2 mb-3" aria-label={ t(ctx, "artists.bulk.toolbar") }>
			<span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-200 px-2.5 py-0.5 text-xs font-medium">
				{ tn(ctx, "artists.bulk.showing_selected", len(data.IDs)) }
				<a
					href={ templ.SafeURL(basePath() + showAllPath(data)) }
					hx-get={ showAllPath(data) }
					hx-target="#artist-content"
					hx-swap="outerHTML"
					hx-push-url="true"
					data-clear-ids="true"
					class="ml-0.5 inline-flex h-3.5 w-3.5 items-center justify-center rounded-full hover:bg-black/10 dark:hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
					aria-label={ t(ctx, "artists.bulk.show_all.aria") }
					title={ t(ctx, "artists.bulk.show_all") }
				>
					<svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
						<path d="M4 4l4 4m0-4L4 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
					</svg>
				</a>
			</span>
		</div>
	}
}

// showAllPath returns the current artist-list path with the IDs filter
// removed. Used by the "Show all" affordance on the selection chip to
// clear the #1227 filter without losing the user's view, sort, search,
// or other filter state. Returns a root-relative path so the
// document-level htmx:configRequest hook can prepend basePath() once
// for HTMX requests; callers wrap with basePath() themselves for
// non-HTMX href values.
func showAllPath(data ArtistListData) string {
	v := url.Values{}
	if data.Search != "" {
		v.Set("search", data.Search)
	}
	if data.Sort != "" {
		v.Set("sort", data.Sort)
	}
	if data.Order != "" {
		v.Set("order", data.Order)
	}
	if data.Filter != "" {
		v.Set("filter", data.Filter)
	}
	if data.LibraryID != "" {
		v.Set("library_id", data.LibraryID)
	}
	if data.View != "" {
		v.Set("view", data.View)
	}
	for k, state := range data.Filters {
		if state == "include" {
			v.Set("filter_"+k, "+y")
		} else if state == "exclude" {
			v.Set("filter_"+k, "-y")
		}
	}
	enc := v.Encode()
	if enc == "" {
		return "/artists"
	}
	return "/artists?" + enc
}

templ ArtistTable(data ArtistListData) {
	<div id="artist-content" data-filter-active?={ isFilterActive(data) }>
		@BulkActionBar(data)
		<!-- Active filter chips: re-rendered on every HTMX swap so state stays in sync -->
		if activeFilterCount(data.Filters) > 0 {
			<div class="flex flex-wrap items-center gap-2 mb-4" aria-label={ t(ctx, "common.active_filters") }>
				for _, key := range sortedFilterKeys(data.Filters) {
					if data.Filters[key] == "include" || data.Filters[key] == "exclude" {
						<span class={ filterChipClass(data.Filters[key]) }>
							{ filterChipLabelFromData(ctx, key, data.Filters[key], data.Libraries, data.LibrarySources) }
							<button
								type="button"
								class="ml-0.5 inline-flex h-3.5 w-3.5 items-center justify-center rounded-full hover:bg-black/10 dark:hover:bg-white/20 focus:outline-none"
								aria-label={ tf(ctx, "common.remove_filter", filterChipLabelFromData(ctx, key, data.Filters[key], data.Libraries, data.LibrarySources)) }
								onclick={ components.DismissFilterChip("filter_"+key, "#artist-content") }
							>
								<svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
									<path d="M4 4l4 4m0-4L4 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
								</svg>
							</button>
						</span>
					}
				}
			</div>
		}
		<div class="overflow-x-auto">
			<table id="artists-table" class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
				<thead class="bg-gray-50 dark:bg-gray-800">
					<tr>
						<th scope="col" class="px-3 py-3 w-8">
							<span class="sr-only">{ t(ctx, "artists.bulk.select_column") }</span>
						</th>
						<!-- Name column: three-state sort cycle (asc -> desc -> off) -->
						<th scope="col" data-col="name" data-sort-col="name" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							<button
								type="button"
								onclick="setSortColumn('name')"
								class="inline-flex items-center gap-1 hover:text-gray-700 dark:hover:text-gray-200"
								title={ t(ctx, "artists.sort_by_name") }
							>
								{ t(ctx, "artists.col.name") }
								<svg class="sw-sort-asc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "name" && data.Order == "asc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path></svg>
								<svg class="sw-sort-desc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "name" && data.Order == "desc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
							</button>
						</th>
						<!-- Type column: sortable, hidden by default via column toggle -->
						<th scope="col" data-col="type" data-sort-col="type" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							<button
								type="button"
								onclick="setSortColumn('type')"
								class="inline-flex items-center gap-1 hover:text-gray-700 dark:hover:text-gray-200"
								title={ t(ctx, "artists.sort_by_type") }
							>
								{ t(ctx, "artists.sort.type") }
								<svg class="sw-sort-asc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "type" && data.Order == "asc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path></svg>
								<svg class="sw-sort-desc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "type" && data.Order == "desc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
							</button>
						</th>
						<!-- Origin/Country column: sortable, hidden by default via column toggle -->
						<th scope="col" data-col="origin" data-sort-col="origin" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							<button
								type="button"
								onclick="setSortColumn('origin')"
								class="inline-flex items-center gap-1 hover:text-gray-700 dark:hover:text-gray-200"
								title={ t(ctx, "artists.sort_by_origin") }
							>
								{ t(ctx, "artists.sort.origin") }
								<svg class="sw-sort-asc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "origin" && data.Order == "asc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path></svg>
								<svg class="sw-sort-desc h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style={ func() string { if data.Sort == "origin" && data.Order == "desc" { return "" }; return "display:none" }() }><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
							</button>
						</th>
						<th scope="col" data-col="metadata" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							{ t(ctx, "artists.col.metadata") }
						</th>
						<th scope="col" data-col="thumb" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							{ img.ImageTermFor("thumb", data.ProfileName) }
						</th>
						<th scope="col" data-col="fanart" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							{ img.ImageTermFor("fanart", data.ProfileName) }
						</th>
						<th scope="col" data-col="logo" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							{ img.ImageTermFor("logo", data.ProfileName) }
						</th>
						<th scope="col" data-col="mbid" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">
							{ t(ctx, "artists.col.mbid") }
						</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-900">
					if len(data.Artists) == 0 {
						<tr>
							<td colspan="9" class="px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
								{ t(ctx, "artists.empty_state") }
							</td>
						</tr>
					}
					for _, a := range data.Artists {
						@ArtistRow(a, data.LibrarySources, data.ComplianceMap, data.PlatformPresence, data.ProfileName, true)
					}
				</tbody>
			</table>
		</div>
		@components.Pagination(data.Pagination)
	</div>
}

templ ArtistRow(a artist.Artist, sources map[string]LibrarySourceInfo, compliance map[string]artist.ComplianceStatus, platforms map[string]artist.PlatformPresence, profileName string, selectable bool) {
	<tr class={ "hover:bg-gray-50 dark:hover:bg-gray-800", templ.KV("opacity-50", a.IsExcluded) }>
		if selectable {
			<td class="px-3 py-3 w-8 align-middle">
				<input
					type="checkbox"
					class="sw-bulk-select h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
					data-artist-id={ a.ID }
					aria-label={ tf(ctx, "artists.bulk.select_artist", a.Name) }
				/>
			</td>
		}
		<td data-col="name" class="px-4 py-3 text-sm">
			<div class="flex items-center gap-1.5">
				if complianceAvailable(compliance) {
					<span
						class={ "inline-block h-2.5 w-2.5 shrink-0 rounded-full", complianceDotClass(artistCompliance(a.ID, compliance)) }
						title={ complianceDotTitle(ctx, artistCompliance(a.ID, compliance)) }
						aria-label={ complianceDotTitle(ctx, artistCompliance(a.ID, compliance)) }
						role="img"
					></span>
				}
				@artistPlatformBadges(a, sources, platforms)
				<a
					href={ templ.SafeURL(basePath() + "/artists/" + a.ID) }
					class="font-medium text-blue-600 dark:text-blue-400 hover:underline"
				>
					{ a.Name }
				</a>
				if a.SortName != "" && a.SortName != a.Name {
					<span class="ml-1 text-xs text-gray-400">({ a.SortName })</span>
				}
				if a.IsExcluded {
					<span class="ml-1 inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2 py-0.5 text-xs font-medium text-gray-600 dark:text-gray-400">{ t(ctx, "artists.excluded") }</span>
				}
			</div>
		</td>
		<td data-col="type" class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">
			{ a.Type }
		</td>
		<td data-col="origin" class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">
			{ a.Origin }
		</td>
		<td data-col="metadata" class="px-4 py-3 text-center">
			@components.StatusBadge(a.NFOExists, t(ctx, "artists.col.metadata"))
		</td>
		<td data-col="thumb" class="px-4 py-3 text-center">
			@components.ImageStatusBadge(a.ThumbExists, a.ThumbLowRes, img.ImageTermFor("thumb", profileName))
		</td>
		<td data-col="fanart" class="px-4 py-3 text-center">
			@components.ImageStatusBadge(a.FanartExists, a.FanartLowRes, img.ImageTermFor("fanart", profileName))
		</td>
		<td data-col="logo" class="px-4 py-3 text-center">
			@components.ImageStatusBadge(a.LogoExists, a.LogoLowRes, img.ImageTermFor("logo", profileName))
		</td>
		<td data-col="mbid" class="px-4 py-3 text-center">
			@components.StatusBadge(a.MusicBrainzID != "", t(ctx, "artists.col.mbid"))
		</td>
	</tr>
}

// ArtistGrid is the HTMX-swappable grid fragment.
templ ArtistGrid(data ArtistListData) {
	<div id="artist-content" data-filter-active?={ isFilterActive(data) }>
		@BulkActionBar(data)
		<!-- Active filter chips: re-rendered on every HTMX swap so state stays in sync -->
		if activeFilterCount(data.Filters) > 0 {
			<div class="flex flex-wrap items-center gap-2 mb-4" aria-label={ t(ctx, "common.active_filters") }>
				for _, key := range sortedFilterKeys(data.Filters) {
					if data.Filters[key] == "include" || data.Filters[key] == "exclude" {
						<span class={ filterChipClass(data.Filters[key]) }>
							{ filterChipLabelFromData(ctx, key, data.Filters[key], data.Libraries, data.LibrarySources) }
							<button
								type="button"
								class="ml-0.5 inline-flex h-3.5 w-3.5 items-center justify-center rounded-full hover:bg-black/10 dark:hover:bg-white/20 focus:outline-none"
								aria-label={ tf(ctx, "common.remove_filter", filterChipLabelFromData(ctx, key, data.Filters[key], data.Libraries, data.LibrarySources)) }
								onclick={ components.DismissFilterChip("filter_"+key, "#artist-content") }
							>
								<svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
									<path d="M4 4l4 4m0-4L4 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
								</svg>
							</button>
						</span>
					}
				}
			</div>
		}
		if len(data.Artists) == 0 {
			<div class="px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
				{ t(ctx, "artists.empty_state") }
			</div>
		} else {
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
				for _, a := range data.Artists {
					@ArtistCard(a, data.LibrarySources, data.ComplianceMap, data.PlatformPresence, true)
				}
			</div>
		}
		@components.Pagination(data.Pagination)
	</div>
}

templ ArtistCard(a artist.Artist, sources map[string]LibrarySourceInfo, compliance map[string]artist.ComplianceStatus, platforms map[string]artist.PlatformPresence, selectable bool) {
	<div class="relative">
		if selectable {
			<label
				class="absolute top-1.5 right-1.5 z-10 flex items-center justify-center rounded-full bg-white/90 dark:bg-gray-900/90 p-0.5 shadow cursor-pointer"
				onclick="event.stopPropagation();"
				aria-label={ tf(ctx, "artists.bulk.select_artist", a.Name) }
			>
				<input
					type="checkbox"
					class="sw-bulk-select h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-2 focus:ring-blue-500"
					data-artist-id={ a.ID }
					onclick="event.stopPropagation();"
					aria-label={ tf(ctx, "artists.bulk.select_artist", a.Name) }
				/>
			</label>
		}
		<a
			href={ templ.SafeURL(basePath() + "/artists/" + a.ID) }
			class={ "group block rounded-lg overflow-hidden bg-white dark:bg-gray-800 shadow hover:shadow-md transition-shadow", templ.KV("opacity-50", a.IsExcluded) }
		>
			<div class="aspect-square bg-gray-100 dark:bg-gray-700 relative overflow-hidden">
				if a.ThumbExists {
					if a.ThumbPlaceholder != "" {
						<div class="lqip-placeholder" style={ templ.SafeCSS("background-image:url('" + a.ThumbPlaceholder + "')") } aria-hidden="true"></div>
					}
					<img
						src={ basePath() + "/api/v1/artists/" + a.ID + "/images/thumb/file" }
						alt={ a.Name }
						loading="lazy"
						class="absolute inset-0 h-full w-full object-cover group-hover:scale-105 transition-transform duration-200"
						onerror="this.style.display='none'"
					/>
				} else if a.ThumbPlaceholder != "" {
					<div class="lqip-placeholder" style={ templ.SafeCSS("background-image:url('" + a.ThumbPlaceholder + "')") } aria-hidden="true"></div>
				} else {
					<div class="h-full w-full flex items-center justify-center">
						<svg class="h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
						</svg>
					</div>
				}
				if complianceAvailable(compliance) {
					<span
						class={ "absolute top-1.5 left-1.5 h-3 w-3 rounded-full border border-white/50 dark:border-gray-900/50", complianceDotClass(artistCompliance(a.ID, compliance)) }
						title={ complianceDotTitle(ctx, artistCompliance(a.ID, compliance)) }
						aria-label={ complianceDotTitle(ctx, artistCompliance(a.ID, compliance)) }
						role="img"
					></span>
				}
				@artistCardPlatformBadges(a, sources, platforms)
			</div>
			<div class="px-2 py-2">
				<p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate" title={ a.Name }>
					{ a.Name }
				</p>
				<p class={ "mt-0.5 text-xs font-medium", components.HealthScoreClass(a.HealthScore) }>
					{ fmt.Sprintf("%.0f%%", a.HealthScore) }
				</p>
			</div>
		</a>
	</div>
}

// artistPlatformBadges renders inline platform badges for the table view name column.
templ artistPlatformBadges(a artist.Artist, sources map[string]LibrarySourceInfo, platforms map[string]artist.PlatformPresence) {
	if badges := computeArtistBadges(ctx, a, sources, platforms); len(badges) > 0 {
		<span class="inline-flex items-center gap-0.5 shrink-0">
			for _, b := range badges {
				@components.PlatformBadge(b.Platform, b.Tooltip)
			}
		</span>
	}
}

// artistCardPlatformBadges renders overlay platform badges for the grid card view.
// Badges are positioned in the bottom-right corner of the card image area.
templ artistCardPlatformBadges(a artist.Artist, sources map[string]LibrarySourceInfo, platforms map[string]artist.PlatformPresence) {
	if badges := computeArtistBadges(ctx, a, sources, platforms); len(badges) > 0 {
		<div class="absolute bottom-1 right-1 flex items-center gap-0.5">
			for _, b := range badges {
				<span class="rounded-full bg-black/60 p-0.5">
					@components.PlatformBadge(b.Platform, b.Tooltip)
				</span>
			}
		</div>
	}
}

// BulkProgressPill renders the persistent in-flight action notification used
// by bulk actions and single-artist run-rules. The pill is hidden until
// bulk-controller JS populates and reveals it, and is attached at the
// ArtistsPage root so it stays visible during HTMX swaps of #artist-content.
// The progress text is composed in JS from the verb + processed + total
// counters returned by /api/v1/artists/bulk-actions/status.
templ BulkProgressPill() {
	<div
		id="bulk-progress-pill"
		class="hidden fixed bottom-6 right-6 z-40 flex items-center gap-3 rounded-full bg-blue-600 dark:bg-blue-500 px-4 py-2 text-sm font-medium text-white shadow-lg"
		role="status"
		aria-live="polite"
		data-i18n-verb-run-rules={ t(ctx, "artists.bulk.progress.run_rules") }
		data-i18n-verb-re-identify={ t(ctx, "artists.bulk.progress.re_identify") }
		data-i18n-verb-re-identify-auto={ t(ctx, "artists.bulk.progress.re_identify_auto") }
		data-i18n-verb-re-identify-review={ t(ctx, "artists.bulk.progress.re_identify_review") }
		data-i18n-verb-scan={ t(ctx, "artists.bulk.progress.scan") }
		data-i18n-verb-fetch-images={ t(ctx, "artists.bulk.progress.fetch_images") }
		data-i18n-template={ t(ctx, "artists.bulk.progress.template") }
		data-i18n-single={ t(ctx, "artists.bulk.progress.single") }
		data-i18n-summary={ t(ctx, "artists.bulk.summary") }
		data-i18n-reidentify-summary={ t(ctx, "artists.bulk.reidentify.summary") }
		data-i18n-confirm-small={ t(ctx, "artists.bulk.confirm.small") }
		data-i18n-confirm-large={ t(ctx, "artists.bulk.confirm.large") }
	>
		<svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
			<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
			<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
		</svg>
		<span id="bulk-progress-text">...</span>
		<button
			type="button"
			id="bulk-progress-cancel"
			class="hidden ml-2 inline-flex items-center rounded-full bg-white/15 hover:bg-white/25 px-3 py-0.5 text-xs font-semibold text-white focus:outline-none focus:ring-2 focus:ring-white/60 disabled:opacity-50 disabled:cursor-not-allowed"
			aria-label={ t(ctx, "artists.bulk.cancel") }
			onclick="swCancelBulkAction()"
		>
			{ t(ctx, "artists.bulk.cancel") }
		</button>
	</div>
}
