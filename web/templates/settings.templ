// joinNames joins a string slice with ", " for display.
func joinNames(names []string) string {
	return strings.Join(names, ", ")
}

// profileEditable returns true if the profile's image naming should be editable.
// The seeded "custom" profile and all user-created profiles are editable;
// other builtin profiles (emby, jellyfin, kodi, plex) are read-only.
func profileEditable(p *platform.Profile) bool {
	if p == nil {
		return false
	}
	return !p.IsBuiltin || p.ID == "custom"
}

// SettingsSearchEntry is one searchable item in the settings in-page search index.
// The index is built server-side and emitted as inline JSON so the client-side
// filter can run without any API call.
type SettingsSearchEntry struct {
	ID       string        `json:"id"`    // DOM id of the ContextHelp span (e.g. "help-platform-profile")
	Label    string        `json:"label"` // Human-readable control label
	HelpText string        `json:"help"`  // Short help text for the control
	TabID    SettingsTabID `json:"tab"`   // Tab the control lives on (closed set; see SettingsTabID constants)
}

// jsonSearchIndex serializes a search index slice to a JSON string for inline
// script emission. Falls back to "[]" on marshal error so the page never breaks;
// the failure is logged so operators see it instead of just a silently empty
// search box.
func jsonSearchIndex(index []SettingsSearchEntry) string {
	b, err := json.Marshal(index)
	if err != nil {
		slog.Error("settings search index: json.Marshal failed; emitting empty index",
			"err", err, "entry_count", len(index))
		return "[]"
	}
	return string(b)
}

// SettingsData holds the data for the settings page.
type SettingsData struct {
	ActiveTab                SettingsTabID
	Libraries                []library.Library
	Profiles                 []platform.Profile
	ActiveProfile            *platform.Profile
	ProviderKeys             []provider.ProviderKeyStatus
	Priorities               []provider.FieldPriority
	Connections              []connection.Connection
	Webhooks                 []webhook.Webhook
	WebSearchProviders       []provider.WebSearchProviderStatus
	ShowPlatformDebug        bool
	Rules                    []rule.Rule
	HasLocalLibrary          bool
	BadgeEnabled             bool
	BadgeSeverityError       bool
	BadgeSeverityWarning     bool
	BadgeSeverityInfo        bool
	RuleScheduleMinutes      int
	APITokens                []auth.APIToken
	BackupRetention          int
	BackupMaxAgeDays         int
	SymlinkSupported         bool
	CacheMaxSizeMB           string
	NameSimilarityThreshold  int
	MetadataLanguages        []string             // Ordered BCP 47 tags for metadata language preference.
	NameRomanizationFallback bool                 // Whether the MB sort-name romanization fallback is enabled.
	VocabConfig              *tagdict.VocabConfig // Tag-filtering config for the Tag Sources card.
	BasePath                 string               // Current SW_BASE_PATH value (read-only display).
	BasePathEnvOverride      bool                 // True when the SW_BASE_PATH env var is set.
	TLS                      TLSStatusData        // Read-only summary of the running TLS listener configuration.
	Users                    UsersTabData
	AuthProviders            AuthProvidersData
	Updates                  UpdatesTabData
}

// TLSStatusData feeds the read-only TLS Status card in the Settings General
// tab. The card surfaces what listeners are actually bound (HTTPS vs HTTP)
// so a deployment that flips SW_TLS_CERT_FILE can confirm the change took
// effect without parsing logs. It carries no editable fields and no
// secrets; cert/key paths are not displayed because the operator already
// knows where they live and exposing them would only widen the attack
// surface in a screenshot.
type TLSStatusData struct {
	// Mode is one of "off", "byo", or "acme". Maps directly to a single
	// label in the rendered card. "acme" is reserved for #930+; the
	// template handles all three branches today so future PRs only update
	// the handler.
	Mode string
	// AcmeDomain is the DNS name issued by ACME, surfaced in the "Active
	// (ACME, <domain>)" label when Mode == "acme". Empty otherwise.
	AcmeDomain string
	// HTTPSPort is the bound HTTPS listener port (used when Mode != "off").
	// In collapse mode it equals Server.Port; otherwise it equals
	// Server.TLS.Port.
	HTTPSPort int
	// HTTPPort is the bound plain-HTTP listener port. Used when Mode ==
	// "off" so the card reads "HTTP on :1973".
	HTTPPort int
	// HTTPRedirectPort is the optional 301-redirect listener port. Set to
	// 0 when no redirect listener is configured. Wired in #929; the
	// conditional render is in place today.
	HTTPRedirectPort int
	// HTTP3Port is the UDP port the HTTP/3 (QUIC) listener is bound to. Set
	// to 0 when HTTP/3 is disabled. When non-zero the card adds a
	// "HTTP/3 on :<port>/udp" listener row so operators can confirm the
	// QUIC listener took effect.
	HTTP3Port int
}

// UpdatesTabData holds the data for the Updates settings tab.
type UpdatesTabData struct {
	CurrentVersion     string // Running binary version (from version.Version)
	Channel            string // "stable" | "prerelease" | "nightly"
	Enabled            bool   // Top-level updater kill switch
	AutoCheck          bool
	AutoUpdate         bool   // When true (and !IsDocker), scheduler calls Apply automatically
	CheckIntervalHours int    // Background auto-check cadence; minimum 1
	IsDocker           bool   // When true, hide binary apply controls
	LastChecked        string // RFC 3339 or empty
	LatestVersion      string // Latest version from last check (may be empty if not yet checked)
	UpdateAvailable    bool
	ReleaseURL         string
	// LastAutoApplied is the RFC3339 timestamp of the last successful
	// auto-apply (empty when no auto-apply has occurred). Surfaced as a
	// "last auto-applied: vX.Y.Z" line below the AutoUpdate toggle so
	// users can confirm the scheduler is doing what they asked for.
	LastAutoApplied        string
	LastAutoAppliedVersion string
	// SkippedVersions is the persisted list of release tags that the
	// scheduler must NOT auto-apply. The skip-this-version button in
	// the Updates tab POSTs to /updates/skips to append.
	SkippedVersions []string
	// RestartRequired is true after a successful Apply replaced the on-disk
	// binary in this process's lifetime. When true, the Updates tab renders a
	// persistent "Update installed -- restart to finish" banner instead of
	// the Apply/Check actions, so users know the Apply succeeded and that a
	// restart is the only remaining step.
	RestartRequired bool
	// PendingVersion is the tag of the installed-but-not-yet-running binary,
	// shown in the restart-required banner. Empty unless RestartRequired.
	PendingVersion string
	// LoadFailed is true when the server-side render could not read the
	// updater config (e.g. settings table read error). When true, the tab
	// renders an error banner and disables the Save path, because the
	// rendered controls show the in-code defaults rather than the user's
	// actual persisted configuration; a naive Save click would overwrite
	// real values with those defaults.
	LoadFailed bool
}

// vocabExcludePatternsText returns the exclude patterns as a newline-separated
// string suitable for pre-filling the Tag Sources textarea. Returns an empty
// string when no patterns are configured so the textarea renders blank.
func (d SettingsData) vocabExcludePatternsText() string {
	if d.VocabConfig == nil || len(d.VocabConfig.Exclude) == 0 {
		return ""
	}
	return strings.Join(d.VocabConfig.Exclude, "\n")
}

// vocabMaxGenres returns the max_genres cap as a string for the number input.
// Returns "0" when no config is set (no-op default).
func (d SettingsData) vocabMaxGenres() string {
	if d.VocabConfig == nil {
		return "0"
	}
	return strconv.Itoa(d.VocabConfig.MaxGenres)
}

// vocabMaxStyles returns the max_styles cap as a string for the number input.
// Returns "0" when no config is set (no-op default).
func (d SettingsData) vocabMaxStyles() string {
	if d.VocabConfig == nil {
		return "0"
	}
	return strconv.Itoa(d.VocabConfig.MaxStyles)
}

// vocabMaxMoods returns the max_moods cap as a string for the number input.
// Returns "0" when no config is set (no-op default).
func (d SettingsData) vocabMaxMoods() string {
	if d.VocabConfig == nil {
		return "0"
	}
	return strconv.Itoa(d.VocabConfig.MaxMoods)
}

// SettingsTabID is the stable identifier for a settings page tab. Promoting
// this to a named type with package-level constants lifts the closed-set
// invariant into the compiler: a typoed tab id is a build error, not a
// silent runtime mismatch between the search index and the rendered nav.
type SettingsTabID string

const (
	TabGeneral       SettingsTabID = "general"
	TabProviders     SettingsTabID = "providers"
	TabConnections   SettingsTabID = "connections"
	TabLibraries     SettingsTabID = "libraries"
	TabAutomation    SettingsTabID = "automation"
	TabRules         SettingsTabID = "rules"
	TabUsers         SettingsTabID = "users"
	TabAuthProviders SettingsTabID = "auth_providers"
	TabMaintenance   SettingsTabID = "maintenance"
	TabLogs          SettingsTabID = "logs"
	TabUpdates       SettingsTabID = "updates"
)

// settingsTab defines a tab in the settings page navigation.
type settingsTab struct {
	ID    SettingsTabID
	Label string
}

// settingsTabs returns the ordered list of settings page tabs.
func settingsTabs() []settingsTab {
	return []settingsTab{
		{ID: TabGeneral, Label: "settings.tab.general"},
		{ID: TabProviders, Label: "settings.tab.providers"},
		{ID: TabConnections, Label: "settings.tab.connections"},
		{ID: TabLibraries, Label: "settings.tab.libraries"},
		{ID: TabAutomation, Label: "settings.tab.automation"},
		{ID: TabRules, Label: "settings.tab.rules"},
		{ID: TabUsers, Label: "settings.tab.users"},
		{ID: TabAuthProviders, Label: "settings.tab.auth_providers"},
		{ID: TabMaintenance, Label: "settings.tab.maintenance"},
		{ID: TabLogs, Label: "settings.tab.logs"},
		{ID: TabUpdates, Label: "settings.tab.updates"},
	}
}

