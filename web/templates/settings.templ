		{ID: "help-tag-sources", Label: t(ctx, "settings.tag_sources.title"), HelpText: t(ctx, "settings.tag_sources.help"), TabID: TabProviders},
		{ID: "help-tag-sources-exclude", Label: t(ctx, "settings.tag_sources.exclude.label"), HelpText: t(ctx, "settings.tag_sources.exclude.help"), TabID: TabProviders},
		// Connections tab
		{ID: "help-connections", Label: t(ctx, "settings.connections.title"), HelpText: t(ctx, "settings.connections.help"), TabID: TabConnections},
		// Libraries tab
		{ID: "help-libraries", Label: t(ctx, "settings.libraries.title"), HelpText: t(ctx, "settings.libraries.help"), TabID: TabLibraries},
		{ID: "help-lib-add-name", Label: t(ctx, "settings.libraries.name"), HelpText: t(ctx, "settings.libraries.name.help"), TabID: TabLibraries},
		{ID: "help-lib-add-path", Label: t(ctx, "settings.libraries.path"), HelpText: t(ctx, "settings.libraries.path.help"), TabID: TabLibraries},
