// rulesForCategory filters rules by category.
func rulesForCategory(rules []rule.Rule, category string) []rule.Rule {
	var result []rule.Rule
	for _, r := range rules {
		if string(r.Category) == category {
			result = append(result, r)
		}
	}
	return result
}

// imageSubtypePrefixes is the canonical ordered list of image sub-type prefixes
// used for grouping image rules and validating rule IDs. Shared between
// rulesForImageSubtypeFallback and the image-rule rendering loop.
var imageSubtypePrefixes = []string{"thumb_", "fanart_", "logo_", "banner_", "backdrop_"}

// imageSubtypeLabel maps a rule ID to a localized image sub-type label used
// as a sub-group heading inside the Images category card.
func imageSubtypeLabel(ctx context.Context, ruleID string) string {
	switch {
	case strings.HasPrefix(ruleID, "thumb_"):
		return t(ctx, "settings.image_subtype.thumbnail")
	case strings.HasPrefix(ruleID, "fanart_"):
		return t(ctx, "settings.image_subtype.fanart")
	case strings.HasPrefix(ruleID, "logo_"):
		return t(ctx, "settings.image_subtype.logo")
	case strings.HasPrefix(ruleID, "banner_"):
		return t(ctx, "settings.image_subtype.banner")
	case strings.HasPrefix(ruleID, "backdrop_"):
		return t(ctx, "settings.image_subtype.backdrop")
	default:
		return t(ctx, "settings.image_subtype.general")
	}
}

// rulesForImageSubtype returns rules whose ID starts with the given prefix.
func rulesForImageSubtype(rules []rule.Rule, prefix string) []rule.Rule {
	var out []rule.Rule
	for _, r := range rules {
		if strings.HasPrefix(r.ID, prefix) {
			out = append(out, r)
		}
	}
	return out
}

// rulesForImageSubtypeFallback returns rules whose ID does not start with any
// recognized image sub-type prefix. These are grouped under a "General" heading.
func rulesForImageSubtypeFallback(rules []rule.Rule) []rule.Rule {
	var out []rule.Rule
	for _, r := range rules {
		matched := false
		for _, pfx := range imageSubtypePrefixes {
			if strings.HasPrefix(r.ID, pfx) {
				matched = true
				break
			}
		}
		if !matched {
			out = append(out, r)
		}
	}
	return out
}

// ruleCatalogueURL returns the absolute URL of a rule's section in the rules
// catalogue page on the docs site. The MkDocs Material toc plugin slugifies
// each H2 heading by lowercasing and replacing whitespace with hyphens; the
// codegen rule names map to that same slug, so we reproduce the slugify rule
// here rather than wire a separate manifest. Punctuation that mkdocs strips
// (the slash in "Artist/ID mismatch" -> "artistid-mismatch") is handled
// inline.
func ruleCatalogueURL(name string) string {
	slug := strings.ToLower(name)
	// Drop characters mkdocs strips entirely.
	slug = strings.NewReplacer("/", "", "(", "", ")", "", ",", "", ".", "", ":", "").Replace(slug)
	// Collapse runs of whitespace to a single hyphen.
	slug = strings.Join(strings.Fields(slug), "-")
	return "https://sydlexius.github.io/stillwater/reference/rules-catalogue/#" + slug
}

// categoryLabel returns a human-readable label for a rule category.
func categoryLabel(category string) string {
	switch category {
	case "nfo":
		return "NFO"
	case "image":
		return "Images"
	case "metadata":
		return "Metadata"
	default:
		return category
	}
}

// scopePillClasses returns CSS classes for API token scope pills.
func scopePillClasses(scope string) string {
	scope = strings.TrimSpace(scope)
	switch scope {
	case "read":
		return "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300"
	case "write":
		return "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300"
	case "webhook":
		return "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300"
	case "admin":
		return "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"
	default:
		return "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
	}
}

// tokenAfterRequest returns an inline JS handler for token lifecycle buttons.
// Revoke reloads the page so the token moves to the archive section correctly.
// Delete fades out the row. Errors show a toast.
func tokenAfterRequest(rowID, action string) string {
	if action == "revoke" {
		return "if(event.detail.successful) { " +
			"showSuccessToast('revoke successful'); " +
			"setTimeout(function(){ window.location.reload(); }, 500); " +
			"} else { try { var r=JSON.parse(event.detail.xhr.responseText); " +
			"showToast(r.error||'Operation failed'); } catch(e) { showToast('Operation failed'); } }"
	}
	return "if(event.detail.successful) { " +
		"var row = document.getElementById('" + rowID + "'); " +
		"if(row) { row.style.transition='opacity 0.3s'; row.style.opacity='0'; " +
		"setTimeout(function(){ row.remove(); }, 300); } " +
		"showSuccessToast('" + action + " successful'); " +
		"} else { try { var r=JSON.parse(event.detail.xhr.responseText); " +
		"showToast(r.error||'Operation failed'); } catch(e) { showToast('Operation failed'); } }"
}

func hasActiveTokens(tokens []auth.APIToken) bool {
	for _, t := range tokens {
		if t.Status == auth.TokenStatusActive {
			return true
		}
	}
	return false
}

func hasRevokedTokens(tokens []auth.APIToken) bool {
	for _, t := range tokens {
		if t.Status == auth.TokenStatusRevoked {
			return true
		}
	}
	return false
}

func countRevokedTokens(tokens []auth.APIToken) int {
	n := 0
	for _, t := range tokens {
		if t.Status == auth.TokenStatusRevoked {
			n++
		}
	}
	return n
}

// ruleToggleBtnClasses returns CSS classes for the enabled/disabled toggle button.
func ruleToggleBtnClasses(enabled bool) string {
	base := "relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
	if enabled {
		return base + " bg-blue-600"
	}
	return base + " bg-gray-200 dark:bg-gray-600"
}

// ruleToggleKnobClasses returns CSS classes for the toggle knob span.
func ruleToggleKnobClasses(enabled bool) string {
	base := "pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
	if enabled {
		return base + " translate-x-5"
	}
	return base + " translate-x-0"
}

// severityBadgeClasses returns Tailwind CSS classes for a severity badge.
func severityBadgeClasses(severity string) string {
	switch severity {
	case "error":
		return "bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300"
	case "warning":
		return "bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300"
	default:
		return "bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
	}
}

// ruleHasConfig returns true if the rule has user-configurable parameters.
func ruleHasConfig(id string) bool {
	switch id {
	case "thumb_min_res", "thumb_square", "fanart_min_res", "fanart_aspect",
		"logo_min_res", "banner_min_res", "bio_exists", "logo_padding",
		"discography_populated":
		return true
	}
	return false
}

// intOrDefault formats an int for use in an HTML input value, using def when v is zero.
func intOrDefault(v, def int) string {
	if v == 0 {
		return fmt.Sprintf("%d", def)
	}
	return fmt.Sprintf("%d", v)
}

// floatOrDefault formats a float64 for use in an HTML input value, using def when v is zero.
func floatOrDefault(v, def float64) string {
	val := v
	if val == 0 {
		val = def
	}
	return fmt.Sprintf("%g", val)
}

// stringOrDefault returns v for an HTML input value, falling back to def when v
// is empty. Used for text-valued rule config fields (e.g. the discography
// release-type filter) so a freshly seeded rule shows its default in the form.
func stringOrDefault(v, def string) string {
	if v == "" {
		return def
	}
	return v
}

// defaultMinWidth returns the default minimum width for a given rule.
func defaultMinWidth(id string) int {
	switch id {
	case "thumb_min_res":
		return 500
	case "fanart_min_res":
		return 1920
	case "logo_min_res":
		return 400
	case "banner_min_res":
		return 1000
	}
	return 0
}

// defaultMinHeight returns the default minimum height for a given rule.
func defaultMinHeight(id string) int {
	switch id {
	case "thumb_min_res":
		return 500
	case "fanart_min_res":
		return 1080
	case "banner_min_res":
		return 185
	}
	return 0
}

// defaultAspectRatio returns the default aspect ratio for a given rule.
func defaultAspectRatio(id string) float64 {
	switch id {
	case "thumb_square":
		return 1.0
	case "fanart_aspect":
		return 16.0 / 9.0
	}
	return 1.0
}

// floatNear returns true if a and b are within 0.001 of each other.
func floatNear(a, b float64) bool {
	d := a - b
	if d < 0 {
		d = -d
	}
	return d < 0.001
}

// fanartResPresetKey returns the preset key matching the given fanart resolution,
// defaulting to 1080p when both values are zero.
func fanartResPresetKey(w, h int) string {
	if w == 0 {
		w = 1920
	}
	if h == 0 {
		h = 1080
	}
	switch {
	case w == 1280 && h == 720:
		return "720p"
	case w == 1920 && h == 1080:
		return "1080p"
	case w == 2560 && h == 1440:
		return "1440p"
	case w == 3840 && h == 2160:
		return "4k"
	}
	return "custom"
}

// thumbResPresetKey returns the preset key for a thumbnail resolution.
func thumbResPresetKey(w, h int) string {
	if w == 0 {
		w = 500
	}
	if h == 0 {
		h = 500
	}
	switch {
	case w == 500 && h == 500:
		return "std"
	case w == 1000 && h == 1000:
		return "hd"
	case w == 2000 && h == 2000:
		return "ultra"
	}
	return "custom"
}

// logoWidthPresetKey returns the preset key for a logo minimum width.
func logoWidthPresetKey(w int) string {
	if w == 0 {
		w = 400
	}
	switch w {
	case 400:
		return "std"
	case 800:
		return "large"
	}
	return "custom"
}

// bannerResPresetKey returns the preset key for a banner resolution.
func bannerResPresetKey(w, h int) string {
	if w == 0 {
		w = 1000
	}
	if h == 0 {
		h = 185
	}
	switch {
	case w == 758 && h == 140:
		return "kodi"
	case w == 1000 && h == 185:
		return "wide"
	}
	return "custom"
}

// fanartAspectPresetKey returns the preset key for a fanart aspect ratio.
func fanartAspectPresetKey(ratio float64) string {
	if ratio == 0 {
		ratio = 16.0 / 9.0
	}
	switch {
	case floatNear(ratio, 16.0/9.0):
		return "16:9"
	case floatNear(ratio, 1.6):
		return "16:10"
	case floatNear(ratio, 2.0):
		return "2:1"
	}
	return "custom"
}

// thumbAspectPresetKey returns the preset key for a thumbnail aspect ratio.
func thumbAspectPresetKey(ratio float64) string {
	if ratio == 0 {
		ratio = 1.0
	}
	if floatNear(ratio, 1.0) {
		return "1:1"
	}
	return "custom"
}

// providerIsAvailable returns true if a provider has a key configured or does not require one.
func providerIsAvailable(name provider.ProviderName, keys []provider.ProviderKeyStatus) bool {
	for _, k := range keys {
		if k.Name == name {
			return k.Status != "unconfigured"
		}
	}
	// Web search providers are not in the key list; check separately.
	if isWebSearchProvider(name) {
		return true
	}
	return false
}

// availableProviders filters a priority list to only providers that are configured
// and not structurally excluded for the given field (e.g. MusicBrainz never
// provides biography text, so it is excluded from the biography priority list).
func availableProviders(pri provider.FieldPriority, keys []provider.ProviderKeyStatus) []provider.ProviderName {
	var result []provider.ProviderName
	for _, p := range pri.Providers {
		if provider.IsExcludedForField(pri.Field, p) {
			continue
		}
		if providerIsAvailable(p, keys) {
			result = append(result, p)
		}
	}
	return result
}

// providerIsDisabled returns true if a provider is in the field's disabled list.
func providerIsDisabled(name provider.ProviderName, disabled []provider.ProviderName) bool {
	for _, d := range disabled {
		if d == name {
			return true
		}
	}
	return false
}

// connectionsForType filters connections by type.
func connectionsForType(conns []connection.Connection, connType string) []connection.Connection {
	var result []connection.Connection
	for _, c := range conns {
		if c.Type == connType {
			result = append(result, c)
		}
	}
	return result
}

// hasOKConnection returns true if any connection in the slice has status "ok".
func hasOKConnection(conns []connection.Connection) bool {
	for _, c := range conns {
		if c.Status == "ok" {
			return true
		}
	}
	return false
}

// webSearchToggleJSON generates the JSON body for a web search toggle request.
func webSearchToggleJSON(enabled bool) string {
	if enabled {
		return `{"enabled":true}`
	}
	return `{"enabled":false}`
}

// isWebSearchProvider returns true if the provider is a web search provider.
func isWebSearchProvider(name provider.ProviderName) bool {
	for _, n := range provider.AllWebSearchProviderNames() {
		if n == name {
			return true
		}
	}
	return false
}

templ SettingsPage(assets AssetPaths, data SettingsData) {
	@Layout("Settings", assets) {
		<script src={ assets.SettingsResetConfirmPrefsJS }></script>
		<script src={ assets.SettingsTabsJS }></script>
		<script src={ assets.SettingsPlatformDebugJS }></script>
		<script src={ assets.SettingsSymlinkJS }></script>
		<script src={ assets.SettingsBasePathJS }></script>
		<script src={ assets.SettingsLibraryJS }></script>
		<script src={ assets.SettingsConnectionJS }></script>
		<script src={ assets.SettingsConnectionFeatureToggleJS }></script>
		<script src={ assets.SettingsRuleToggleJS }></script>
		<script src={ assets.SettingsApiTokenJS }></script>
		<script src={ assets.SettingsRuleScheduleJS }></script>
		<script src={ assets.SettingsMaintenanceJS }></script>
		<script src={ assets.SettingsLoggingJS }></script>
		<script src={ assets.SettingsLogViewerJS }></script>
		<script src={ assets.SettingsExportJS }></script>
		<script src={ assets.SettingsProfileNamingJS }></script>
		@settingsUsersScript()
		@settingsAuthProvidersScript()
		@components.LanguagePickerScript()
		<script src={ assets.SettingsRomanizationFallbackJS }></script>
		@components.ContextHelpScript()
		@settingsSearchIndexScript(BuildSettingsSearchIndex(ctx))
		<script src={ assets.SettingsSearchJS }></script>
		<script src={ assets.SortableJS }></script>
		<script src={ assets.SettingsNotifBadgesJS }></script>
		<div class="sw-settings space-y-6">
			<div class="sw-card rounded-lg px-6 py-4">
				<h1 class="text-2xl font-bold">{ t(ctx, "settings.title") }</h1>
				<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
					{ t(ctx, "settings.description") }
				</p>
			</div>
			@settingsTabBar(data.ActiveTab, assets.BasePath)
			<!-- General tab -->
			<div
				data-tab-panel={ string(TabGeneral) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabGeneral),
				}
			>
				@SectionPlatformProfile(data)
				@SectionActiveProfile(data)
				<!-- TLS Status. Read-only summary of the running listener
				     configuration so an operator can confirm a TLS deploy
				     took effect without parsing logs. Values come from the
				     same Config that the listener layer reads, so what the
				     card shows is what is actually bound. -->
				@SectionTLSStatus(data)
				<!-- Base Path. Editable when SW_BASE_PATH env var is unset (the
				     env value wins to keep operator-managed deployments stable);
				     read-only with an amber caption otherwise. Saves go through
				     PUT /api/v1/settings under the "server.base_path" key and
				     surface a shared restart-required banner because the HTTP
				     mux is wired at startup and cannot rebind on the fly. -->
				@SectionBasePath(data)
				@SectionBehavior(data)
				<!-- Image Cache Configuration -->
				@SectionImageCache(data, assets)
				<!-- Onboarding section: re-run wizard (#1142) -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg" id="settings-onboarding">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<h2 class="text-lg font-semibold">{ t(ctx, "settings.onboarding_section_title") }</h2>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.onboarding_section_body") }
						</p>
					</div>
					<div class="px-6 py-4">
						<button
							type="button"
							id="rerun-onboarding-btn"
							class="rounded-md border border-blue-500 text-blue-600 dark:text-blue-400 px-3 py-1.5 text-sm hover:bg-blue-50 dark:hover:bg-blue-950 transition-colors"
							aria-haspopup="dialog"
							aria-controls="rerun-onboarding-confirm"
							onclick="openRerunOnboardingDialog(this)"
						>
							{ t(ctx, "settings.rerun_onboarding_button") }
						</button>
						<dialog
							id="rerun-onboarding-confirm"
							aria-modal="true"
							aria-labelledby="rerun-onboarding-confirm-title"
							class="rounded-lg p-6 bg-white dark:bg-gray-800 shadow-xl backdrop:bg-black/30"
						>
							<h4 id="rerun-onboarding-confirm-title" class="text-base font-semibold mb-2 text-gray-900 dark:text-gray-100">{ t(ctx, "settings.rerun_confirm_title") }</h4>
							<p class="text-sm text-gray-600 dark:text-gray-300 mb-4">{ t(ctx, "settings.rerun_confirm_body") }</p>
							<div class="flex justify-end gap-2">
								<button
									type="button"
									onclick="closeRerunOnboardingDialog()"
									class="px-3 py-1.5 text-sm rounded-md bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
								>
									{ t(ctx, "common.cancel") }
								</button>
								<button
									type="button"
									id="rerun-onboarding-confirm-btn"
									data-i18n-failed-http={ t(ctx, "settings.rerun_failed_http") }
									data-i18n-failed-network={ t(ctx, "settings.rerun_failed_network") }
									class="px-3 py-1.5 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors"
								>
									{ t(ctx, "settings.rerun_confirm_continue") }
								</button>
							</div>
						</dialog>
						<script>
							(function() {
								var dialog = document.getElementById('rerun-onboarding-confirm');
								var btn = document.getElementById('rerun-onboarding-confirm-btn');
								if (!btn) return;
								// Track the element that opened the dialog so close
								// can restore keyboard focus (mirrors the
								// path_picker.templ / artist_duplicates.templ pattern).
								var lastFocused = null;
								window.openRerunOnboardingDialog = function(trigger) {
									if (!dialog) return;
									lastFocused = trigger || document.activeElement;
									dialog.showModal();
									// Move focus to the confirm button so screen
									// readers announce the new context and Tab order
									// begins inside the dialog. Defer to next tick so
									// the dialog has settled into the modal layer.
									setTimeout(function() { btn.focus(); }, 0);
								};
								window.closeRerunOnboardingDialog = function() {
									if (dialog && dialog.open) dialog.close();
								};
								if (dialog) {
									dialog.addEventListener('close', function() {
										if (lastFocused && typeof lastFocused.focus === 'function') {
											lastFocused.focus();
										}
									});
								}
								btn.addEventListener('click', function() {
									btn.disabled = true;
									// Use the canonical CSRF reader from preferences.js
									// to avoid drift if the cookie name ever changes.
									var csrf = (typeof window.swCsrfToken === 'function') ? window.swCsrfToken() : '';
									var bp = (function() {
										var m = document.querySelector('meta[name="htmx-base-path"]');
										return m ? m.content : '';
									})();
									var httpTpl = btn.dataset.i18nFailedHttp || 'Re-run onboarding failed ({status})';
									var netMsg = btn.dataset.i18nFailedNetwork || 'Network error. Please try again.';
									fetch(bp + '/api/v1/onboarding/reset', {
										method: 'POST',
										headers: {'X-CSRF-Token': decodeURIComponent(csrf)}
									}).then(function(res) {
										if (res.ok) {
											window.location.href = bp + '/setup/wizard';
										} else {
											btn.disabled = false;
											var msg = httpTpl.replace('{status}', res.status);
											if (window.showToast) {
												window.showToast(msg);
											} else {
												alert(msg);
											}
										}
									}).catch(function() {
										btn.disabled = false;
										if (window.showToast) {
											window.showToast(netMsg);
										} else {
											alert(netMsg);
										}
									});
								});
							})();
						</script>
					</div>
				</div>
			</div>
			<!-- Providers tab -->
			<div
				data-tab-panel={ string(TabProviders) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabProviders),
				}
			>
				if len(data.ProviderKeys) > 0 {
					<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
						<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
							<div class="flex items-center gap-2">
								<h2 class="text-lg font-semibold">{ t(ctx, "settings.provider_keys.title") }</h2>
								@components.ContextHelp("help-provider-keys", t(ctx, "settings.provider_keys.title"), t(ctx, "settings.provider_keys.help"), "settings-providers-provider-keys")
							</div>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
								{ t(ctx, "settings.provider_keys.description") }
							</p>
						</div>
						<div class="px-6 py-4 space-y-4">
							for _, pk := range data.ProviderKeys {
								<div id={ "provider-card-" + string(pk.Name) }>
									@ProviderKeyCard(pk)
								</div>
							}
						</div>
					</div>
				}
				if len(data.WebSearchProviders) > 0 {
					<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
						<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
							<div class="flex items-center gap-2">
								<h2 class="text-lg font-semibold">{ t(ctx, "settings.web_search.title") }</h2>
								@components.ContextHelp("help-web-search", t(ctx, "settings.web_search.title"), t(ctx, "settings.web_search.help"), "settings-providers-web-search")
							</div>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
								{ t(ctx, "settings.web_search.description") }
							</p>
						</div>
						<div class="px-6 py-4 space-y-4">
							for _, ws := range data.WebSearchProviders {
								@WebSearchToggle(ws)
							}
						</div>
					</div>
				}
				if len(data.Priorities) > 0 {
					<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
						<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
							<div class="flex items-center justify-between gap-2">
								<div class="flex items-center gap-2">
									<h2 class="text-lg font-semibold">{ t(ctx, "settings.priorities.title") }</h2>
									@components.ContextHelp("help-provider-priorities", t(ctx, "settings.priorities.title"), t(ctx, "settings.priorities.help"), "settings-providers-priorities")
								</div>
								<button
									type="button"
									class="text-sm px-3 py-2 rounded bg-red-600 text-white hover:bg-red-700 transition-colors"
									hx-post="/api/v1/providers/priorities/reset"
									hx-target="#priority-rows"
									hx-swap="outerHTML"
									hx-confirm={ t(ctx, "settings.priorities.confirm_restore") }
								>
									{ t(ctx, "settings.priorities.restore_defaults") }
								</button>
							</div>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
								{ t(ctx, "settings.priorities.description") }
							</p>
						</div>
						<div class="px-6 py-4">
							@PriorityChipRows(data.Priorities, data.ProviderKeys)
						</div>
					</div>
				}
				<!-- Metadata Language Preferences -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.metadata_languages.title") }</h2>
							@components.ContextHelp("help-metadata-languages", t(ctx, "settings.metadata_languages.title"), t(ctx, "settings.metadata_languages.help"), "settings-providers-metadata-languages")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.metadata_languages.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<div class="space-y-3">
							@components.LanguagePicker(components.LanguagePickerOpts{
								InstanceID:       "settings",
								InitialLanguages: data.MetadataLanguages,
								Labels: components.LanguagePickerLabels{
									InputLabel:       t(ctx, "settings.metadata_languages.input_label"),
									InputPlaceholder: t(ctx, "settings.metadata_languages.input_placeholder"),
									Remove:           t(ctx, "settings.metadata_languages.remove"),
									AriaListLabel:    t(ctx, "settings.metadata_languages.aria_list_label"),
									AriaPillHint:     t(ctx, "settings.metadata_languages.aria_pill_hint"),
									AriaPillLabel:    t(ctx, "settings.metadata_languages.aria_pill_label"),
									DefaultHint:      t(ctx, "settings.metadata_languages.default_hint"),
									ToastSaved:       t(ctx, "settings.metadata_languages.toast_saved"),
									ToastFailed:      t(ctx, "settings.metadata_languages.toast_failed"),
									ToastMax:         t(ctx, "settings.metadata_languages.toast_max"),
								},
							})
							<!-- Romanization fallback toggle -->
							<div class="flex items-start justify-between gap-4 pt-3 border-t border-gray-200 dark:border-gray-700">
								<div>
									<div class="text-sm font-medium text-gray-900 dark:text-gray-100">{ t(ctx, "settings.metadata_languages.romanization_fallback.label") }</div>
									<div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{ t(ctx, "settings.metadata_languages.romanization_fallback.description") }</div>
								</div>
								{{
									romanizationChecked := data.NameRomanizationFallback
									romanizationAriaVal := "true"
									if !romanizationChecked {
										romanizationAriaVal = "false"
									}
								}}
								<button
									type="button"
									id="pref-romanization-fallback-toggle"
									class={
										"relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800",
										templ.KV("bg-blue-600", romanizationChecked),
										templ.KV("bg-gray-200 dark:bg-gray-600", !romanizationChecked),
									}
									role="switch"
									aria-checked={ romanizationAriaVal }
									aria-label={ t(ctx, "settings.metadata_languages.romanization_fallback.label") }
									data-toast-saved={ t(ctx, "settings.metadata_languages.romanization_fallback.toast_saved") }
									data-toast-failed={ t(ctx, "settings.metadata_languages.romanization_fallback.toast_failed") }
									onclick="swToggleRomanizationFallback(this)"
								>
									<span
										class={
											"pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out",
											templ.KV("translate-x-5", romanizationChecked),
											templ.KV("translate-x-0", !romanizationChecked),
										}
									></span>
								</button>
							</div>
						</div>
					</div>
				</div>
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.advanced.title") }</h2>
							@components.ContextHelp("help-advanced", t(ctx, "settings.advanced.title"), t(ctx, "settings.advanced.help"), "settings-providers-advanced")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.advanced.description") }
						</p>
					</div>
					<div class="px-6 py-4 space-y-4">
						<div>
							<div class="flex items-center gap-1 mb-1">
								<label for="name_similarity_threshold" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
									{ t(ctx, "settings.name_similarity.label") }
								</label>
								@components.ContextHelp("help-name-similarity", t(ctx, "settings.name_similarity.label"), t(ctx, "settings.name_similarity.help"), "settings-providers-name-similarity")
							</div>
							<p class="text-xs text-gray-500 dark:text-gray-400 mb-2">
								{ t(ctx, "settings.name_similarity.description") }
							</p>
							<div class="flex items-center gap-3">
								<input
									type="number"
									id="name_similarity_threshold"
									name="name_similarity_threshold"
									min="0"
									max="100"
									step="1"
									value={ strconv.Itoa(data.NameSimilarityThreshold) }
									aria-label={ t(ctx, "settings.name_similarity.label") }
									class="w-24 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
								/>
								<span class="text-sm text-gray-500 dark:text-gray-400">%</span>
								<button
									type="button"
									class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
									onclick={ saveNameSimilarityThreshold() }
								>
									{ t(ctx, "actions.save") }
								</button>
								<span id="name-similarity-status" class="text-sm text-green-600 dark:text-green-400 hidden">{ t(ctx, "common.saved") }</span>
							</div>
						</div>
					</div>
				</div>
				<!-- Tag Sources card: exclude-pattern textarea + per-field count caps -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.tag_sources.title") }</h2>
							@components.ContextHelp("help-tag-sources", t(ctx, "settings.tag_sources.title"), t(ctx, "settings.tag_sources.help"), "settings-providers-tag-sources")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.tag_sources.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<form
							id="tag-sources-form"
							hx-put="/api/v1/settings/vocab"
							hx-encoding="application/x-www-form-urlencoded"
							hx-target="#tag-sources-status"
							hx-swap="innerHTML"
						>
							<div class="space-y-5">
								<!-- Exclude patterns textarea -->
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="tag-sources-exclude" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
											{ t(ctx, "settings.tag_sources.exclude.label") }
										</label>
										@components.ContextHelp("help-tag-sources-exclude", t(ctx, "settings.tag_sources.exclude.label"), t(ctx, "settings.tag_sources.exclude.help"), "settings-providers-tag-sources-exclude")
									</div>
									<p class="text-xs text-gray-500 dark:text-gray-400 mb-2">
										{ t(ctx, "settings.tag_sources.exclude.description") }
									</p>
									<textarea
										id="tag-sources-exclude"
										name="exclude"
										rows="5"
										aria-label={ t(ctx, "settings.tag_sources.exclude.label") }
										placeholder={ t(ctx, "settings.tag_sources.exclude.placeholder") }
										class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 font-mono focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
									>{ data.vocabExcludePatternsText() }</textarea>
								</div>
								<!-- Per-field count caps -->
								<div>
									<p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
										{ t(ctx, "settings.tag_sources.caps.label") }
									</p>
									<p class="text-xs text-gray-500 dark:text-gray-400 mb-3">
										{ t(ctx, "settings.tag_sources.caps.description") }
									</p>
									<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
										<!-- Max genres -->
										<div>
											<label for="tag-sources-max-genres" class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">
												{ t(ctx, "settings.tag_sources.caps.max_genres") }
											</label>
											<input
												type="number"
												id="tag-sources-max-genres"
												name="max_genres"
												min="0"
												step="1"
												value={ data.vocabMaxGenres() }
												aria-label={ t(ctx, "settings.tag_sources.caps.max_genres") }
												class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
											/>
										</div>
										<!-- Max styles -->
										<div>
											<label for="tag-sources-max-styles" class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">
												{ t(ctx, "settings.tag_sources.caps.max_styles") }
											</label>
											<input
												type="number"
												id="tag-sources-max-styles"
												name="max_styles"
												min="0"
												step="1"
												value={ data.vocabMaxStyles() }
												aria-label={ t(ctx, "settings.tag_sources.caps.max_styles") }
												class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
											/>
										</div>
										<!-- Max moods -->
										<div>
											<label for="tag-sources-max-moods" class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">
												{ t(ctx, "settings.tag_sources.caps.max_moods") }
											</label>
											<input
												type="number"
												id="tag-sources-max-moods"
												name="max_moods"
												min="0"
												step="1"
												value={ data.vocabMaxMoods() }
												aria-label={ t(ctx, "settings.tag_sources.caps.max_moods") }
												class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
											/>
										</div>
									</div>
								</div>
								<!-- Save control and status -->
								<div class="flex items-center gap-3 pt-1">
									<button
										type="submit"
										class="text-sm px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
									>
										{ t(ctx, "actions.save") }
									</button>
									<span
										id="tag-sources-status"
										role="status"
										aria-live="polite"
										aria-atomic="true"
										class="text-sm"
									></span>
								</div>
							</div>
						</form>
					</div>
				</div>
			</div>
			<!-- Connections tab -->
			<div
				data-tab-panel={ string(TabConnections) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabConnections),
				}
			>
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.connections.title") }</h2>
							@components.ContextHelp("help-connections", t(ctx, "settings.connections.title"), t(ctx, "settings.connections.help"), "settings-connections-connections")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.connections.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<!-- The clobber-warnings block was removed in favour of
							the global ConflictBanner in the layout. That banner
							covers every screen, carries per-connection CTAs, and
							shares its source of truth with the write-gate. -->
						<div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
							@serviceConnectionCard("emby", "Emby", "http://192.168.1.100:8096", connectionsForType(data.Connections, "emby"))
							@serviceConnectionCard("jellyfin", "Jellyfin", "http://192.168.1.100:8096", connectionsForType(data.Connections, "jellyfin"))
							@serviceConnectionCard("lidarr", "Lidarr", "http://192.168.1.100:8686", connectionsForType(data.Connections, "lidarr"))
						</div>
					</div>
				</div>
			</div>
			<!-- Libraries tab -->
			<div
				data-tab-panel={ string(TabLibraries) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabLibraries),
				}
			>
				@SectionLibraries(data)
			</div>
			<!-- Automation tab -->
			<div
				data-tab-panel={ string(TabAutomation) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabAutomation),
				}
			>
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.webhooks.title") }</h2>
							@components.ContextHelp("help-webhooks", t(ctx, "settings.webhooks.title"), t(ctx, "settings.webhooks.help"), "settings-automation-webhooks")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.webhooks.description") }
						</p>
					</div>
					<div id="webhooks-list" class="px-6 py-4 space-y-3">
						if len(data.Webhooks) == 0 {
							<p class="text-sm text-gray-500 dark:text-gray-400 italic">{ t(ctx, "settings.webhooks.empty") }</p>
						}
						for _, wh := range data.Webhooks {
							@webhookCard(wh)
						}
					</div>
					<div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
						<button
							type="button"
							class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
							onclick="document.getElementById('add-webhook-form').classList.toggle('hidden')"
						>
							{ t(ctx, "settings.webhooks.add") }
						</button>
						<div id="add-webhook-form" class="hidden mt-4">
							<form
								hx-post="/api/v1/webhooks"
								hx-target="#webhooks-list"
								hx-swap="innerHTML"
								hx-on::after-request="if(event.detail.successful) { this.reset(); this.closest('#add-webhook-form').classList.add('hidden'); window.location.reload(); }"
								class="space-y-3"
							>
								<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
									<div class="flex items-center gap-1">
										<label id="webhook-name-label" for="webhook-name" class="sr-only">{ t(ctx, "settings.webhooks.name.label") }</label>
										<input id="webhook-name" name="name" aria-labelledby="webhook-name-label" placeholder={ t(ctx, "settings.webhooks.name_placeholder") } required class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
										@components.ContextHelp("help-webhook-name", t(ctx, "settings.webhooks.name.label"), t(ctx, "settings.webhooks.name.help"), "settings-automation-webhooks-add")
									</div>
									<div class="flex items-center gap-1">
										<label id="webhook-type-label" for="webhook-type" class="sr-only">{ t(ctx, "settings.webhooks.type.label") }</label>
										<select id="webhook-type" name="type" aria-labelledby="webhook-type-label" required class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
											<option value="">{ t(ctx, "settings.webhooks.select_type") }</option>
											<option value="generic">{ t(ctx, "settings.webhooks.type_generic") }</option>
											<option value="discord">Discord</option>
											<option value="slack">Slack</option>
											<option value="gotify">Gotify</option>
										</select>
										@components.ContextHelp("help-webhook-type", t(ctx, "settings.webhooks.type.label"), t(ctx, "settings.webhooks.type.help"), "settings-automation-webhooks-select-type")
									</div>
									<div class="col-span-full flex items-center gap-1">
										<label id="webhook-url-label" for="webhook-url" class="sr-only">{ t(ctx, "settings.webhooks.url.label") }</label>
										<input id="webhook-url" name="url" type="url" aria-labelledby="webhook-url-label" placeholder={ t(ctx, "settings.webhooks.url_placeholder") } required class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
										@components.ContextHelp("help-webhook-url", t(ctx, "settings.webhooks.url.label"), t(ctx, "settings.webhooks.url.help"), "settings-automation-webhooks-url")
									</div>
								</div>
								<div class="flex gap-2">
									<button type="submit" class="text-sm px-3 py-2 rounded bg-green-600 text-white hover:bg-green-700 transition-colors">{ t(ctx, "actions.save") }</button>
									<button type="button" class="text-sm px-3 py-2 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" onclick="this.closest('#add-webhook-form').classList.add('hidden')">{ t(ctx, "actions.cancel") }</button>
								</div>
							</form>
						</div>
					</div>
				</div>
				<!-- Notification Badge Settings -->
				@components.SettingSection("help-notif-badges", t(ctx, "settings.notif_badges.title"), t(ctx, "settings.notif_badges.help"), "settings-automation-notif-badges", t(ctx, "settings.notif_badges.description")) {
					<div class="flex items-center gap-3">
						<label class="relative inline-flex items-center cursor-pointer">
							<input
								type="checkbox"
								class="sr-only peer"
								checked?={ data.BadgeEnabled }
								onclick="updateSetting('notif_badge_enabled', this.checked)"
							/>
							<div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-500 dark:peer-focus:ring-blue-600 rounded-full peer dark:bg-gray-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:after:border-gray-500 peer-checked:bg-blue-600"></div>
						</label>
						<span class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.notif_badges.enable_badge") }</span>
						@components.ContextHelp("help-notif-enable-badge", t(ctx, "settings.notif_badges.enable_badge"), t(ctx, "settings.notif_badges.enable_badge.help"), "settings-automation-notif-badges-enable-badge")
					</div>
					<div class="space-y-2">
						<div class="flex items-center gap-1">
							<p class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.notif_badges.count_by_severity") }</p>
							@components.ContextHelp("help-notif-count-severity", t(ctx, "settings.notif_badges.count_by_severity"), t(ctx, "settings.notif_badges.count_by_severity.help"), "settings-automation-notif-badges-count-by-severity")
						</div>
						<div class="flex flex-col gap-2">
							<label class="inline-flex items-center gap-2">
								<input
									type="checkbox"
									class="rounded border-gray-300 dark:border-gray-600 text-red-600 focus:ring-red-500"
									checked?={ data.BadgeSeverityError }
									onclick="updateSetting('notif_badge_severity_error', this.checked)"
								/>
								<span class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "common.errors") }</span>
							</label>
							<label class="inline-flex items-center gap-2">
								<input
									type="checkbox"
									class="rounded border-gray-300 dark:border-gray-600 text-amber-600 focus:ring-amber-500"
									checked?={ data.BadgeSeverityWarning }
									onclick="updateSetting('notif_badge_severity_warning', this.checked)"
								/>
								<span class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "common.warnings") }</span>
							</label>
							<label class="inline-flex items-center gap-2">
								<input
									type="checkbox"
									class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500"
									checked?={ data.BadgeSeverityInfo }
									onclick="updateSetting('notif_badge_severity_info', this.checked)"
								/>
								<span class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "common.info") }</span>
							</label>
						</div>
					</div>
				}
				<!-- API Tokens -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.api_tokens.title") }</h2>
							@components.ContextHelp("help-api-tokens", t(ctx, "settings.api_tokens.title"), t(ctx, "settings.api_tokens.help"), "settings-automation-api-tokens")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.api_tokens.description") }
						</p>
					</div>
					<div class="px-6 py-4 space-y-3">
						if len(data.APITokens) == 0 {
							<p class="text-sm text-gray-500 dark:text-gray-400 italic">{ t(ctx, "settings.api_tokens.empty") }</p>
						}
						for _, tok := range data.APITokens {
							if tok.Status == auth.TokenStatusActive {
								<div id={ "token-row-" + tok.ID } class="flex items-center justify-between py-2">
									<div>
										<span class="text-sm font-medium text-gray-900 dark:text-gray-100">{ tok.Name }</span>
										<div class="flex gap-1 mt-1">
											for _, scope := range strings.Split(tok.Scopes, ",") {
												if strings.TrimSpace(scope) != "" {
													<span class={ "inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium", scopePillClasses(scope) }>{ strings.TrimSpace(scope) }</span>
												}
											}
										</div>
										<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
											{ tf(ctx, "settings.api_tokens.created_at", tok.CreatedAt) }
											if tok.LastUsedAt != nil {
												{ tf(ctx, "settings.api_tokens.last_used", *tok.LastUsedAt) }
											}
										</p>
									</div>
									<button
										type="button"
										class="text-sm px-3 py-1 rounded border border-red-300 dark:border-red-600 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
										hx-delete={ "/api/v1/auth/tokens/" + tok.ID }
										hx-swap="none"
										hx-confirm={ t(ctx, "settings.api_tokens.confirm_revoke") }
										hx-on--after-request={ tokenAfterRequest("token-row-"+tok.ID, "revoke") }
										aria-label={ "Revoke token " + tok.Name }
									>
										Revoke
									</button>
								</div>
							}
						}
						if hasRevokedTokens(data.APITokens) {
							<div class="border-t border-gray-200 dark:border-gray-700 pt-3 mt-3">
								<button
									type="button"
									class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
									onclick="var el = document.getElementById('archived-tokens'); el.classList.toggle('hidden'); this.setAttribute('aria-expanded', el.classList.contains('hidden') ? 'false' : 'true'); this.querySelector('span').textContent = el.classList.contains('hidden') ? 'Show Archive' : 'Hide Archive'"
									aria-expanded="false"
									aria-controls="archived-tokens"
								>
									<span>Show Archive</span>
									{ fmt.Sprintf(" (%d)", countRevokedTokens(data.APITokens)) }
								</button>
								<div id="archived-tokens" class="hidden mt-3 space-y-3">
									for _, tok := range data.APITokens {
										if tok.Status == auth.TokenStatusRevoked {
											<div id={ "token-row-" + tok.ID } class="flex items-center justify-between py-2 opacity-50">
												<div>
													<span class="text-sm font-medium text-gray-900 dark:text-gray-100">{ tok.Name }</span>
													<span class="ml-2 text-xs font-medium text-red-600 dark:text-red-400">{ t(ctx, "settings.api_tokens.revoked") }</span>
													<div class="flex gap-1 mt-1">
														for _, scope := range strings.Split(tok.Scopes, ",") {
															if strings.TrimSpace(scope) != "" {
																<span class={ "inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium", scopePillClasses(scope) }>{ strings.TrimSpace(scope) }</span>
															}
														}
													</div>
													<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
														{ tf(ctx, "settings.api_tokens.created_at", tok.CreatedAt) }
														if tok.LastUsedAt != nil {
															{ tf(ctx, "settings.api_tokens.last_used", *tok.LastUsedAt) }
														}
													</p>
												</div>
												<button
													type="button"
													class="text-sm px-3 py-1 rounded border border-red-300 dark:border-red-600 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
													hx-delete={ "/api/v1/auth/tokens/" + tok.ID + "/permanent" }
													hx-swap="none"
													hx-confirm={ t(ctx, "settings.api_tokens.confirm_delete") }
													hx-on--after-request={ tokenAfterRequest("token-row-"+tok.ID, "delete") }
													aria-label={ "Delete token " + tok.Name }
												>
													Delete
												</button>
											</div>
										}
									}
								</div>
							</div>
						}
					</div>
					<div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
						<button
							type="button"
							class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
							onclick="document.getElementById('add-token-form').classList.toggle('hidden')"
						>
							Generate Token
						</button>
						<div id="add-token-form" class="hidden mt-4">
							<form id="create-token-form" class="space-y-3" onsubmit="createAPIToken(event)">
								<input name="name" placeholder={ t(ctx, "settings.api_tokens.name_placeholder") } required class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-500"/>
								<div class="flex flex-wrap gap-3">
									<div class="inline-flex items-center gap-1.5">
										<label class="inline-flex items-center gap-1.5">
											<input type="checkbox" name="scope_read" checked class="rounded border-gray-300 dark:border-gray-600"/>
											<span class="text-sm">{ t(ctx, "settings.api_tokens.scope_read") }</span>
										</label>
										@components.ContextHelp("help-token-scope-read", t(ctx, "settings.api_tokens.scope_read"), t(ctx, "settings.api_tokens.scope_read.help"), "settings-automation-api-tokens-scope-read")
									</div>
									<div class="inline-flex items-center gap-1.5">
										<label class="inline-flex items-center gap-1.5">
											<input type="checkbox" name="scope_write" class="rounded border-gray-300 dark:border-gray-600"/>
											<span class="text-sm">{ t(ctx, "settings.api_tokens.scope_write") }</span>
										</label>
										@components.ContextHelp("help-token-scope-write", t(ctx, "settings.api_tokens.scope_write"), t(ctx, "settings.api_tokens.scope_write.help"), "settings-automation-api-tokens-scope-write")
									</div>
									<div class="inline-flex items-center gap-1.5">
										<label class="inline-flex items-center gap-1.5">
											<input type="checkbox" name="scope_webhook" class="rounded border-gray-300 dark:border-gray-600"/>
											<span class="text-sm">{ t(ctx, "settings.api_tokens.scope_webhook") }</span>
										</label>
										@components.ContextHelp("help-token-scope-webhook", t(ctx, "settings.api_tokens.scope_webhook"), t(ctx, "settings.api_tokens.scope_webhook.help"), "settings-automation-api-tokens-scope-webhook")
									</div>
									<div class="inline-flex items-center gap-1.5">
										<label class="inline-flex items-center gap-1.5">
											<input type="checkbox" name="scope_admin" class="rounded border-gray-300 dark:border-gray-600"/>
											<span class="text-sm">{ t(ctx, "settings.api_tokens.scope_admin") }</span>
										</label>
										@components.ContextHelp("help-token-scope-admin", t(ctx, "settings.api_tokens.scope_admin"), t(ctx, "settings.api_tokens.scope_admin.help"), "settings-automation-api-tokens-scope-admin")
									</div>
								</div>
								<div class="flex gap-2">
									<button type="submit" class="text-sm px-3 py-2 rounded bg-green-600 text-white hover:bg-green-700 transition-colors">{ t(ctx, "actions.create") }</button>
									<button type="button" class="text-sm px-3 py-2 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" onclick="this.closest('#add-token-form').classList.add('hidden')">{ t(ctx, "actions.cancel") }</button>
								</div>
							</form>
							<div id="token-created-result" class="hidden mt-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded">
								<p class="text-sm font-medium text-green-800 dark:text-green-200 mb-1">{ t(ctx, "settings.api_tokens.created_message") }</p>
								<div class="flex items-center gap-2">
									<code id="token-plaintext" class="flex-1 text-xs bg-white dark:bg-gray-800 px-2 py-1 rounded border border-gray-200 dark:border-gray-600 break-all"></code>
									<button type="button" class="text-sm px-2 py-1 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" onclick="navigator.clipboard.writeText(document.getElementById('token-plaintext').textContent)">{ t(ctx, "actions.copy") }</button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- Rules tab -->
			<div
				data-tab-panel={ string(TabRules) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabRules),
				}
			>
				// Page-level first-occurrence flags for two ContextHelp icons inside
				// ruleRow: severity-badge legend (universal across categories, so
				// shown on the first rendered row regardless of category) and
				// requires-local-chip (shown on the first FS-unavailable row, when
				// any). Other ContextHelp instances on this tab (per-category and
				// conflict-gated) render unconditionally and are not gated here.
				{{ fsHelpShown := false }}
				{{ severityHelpShown := false }}
				for _, cat := range []string{"nfo", "image", "metadata"} {
					{{ catRules := rulesForCategory(data.Rules, cat) }}
					if len(catRules) > 0 {
						<div
							class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg"
							if cat == "image" {
								data-sw-requires-image-write
							}
							if cat == "nfo" {
								data-sw-requires-nfo-write
							}
						>
							<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
								{{ categoryHeading := tf(ctx, "settings.rules.category_header", categoryLabel(cat)) }}
								<div class="flex items-center gap-2">
									<h2 class="text-lg font-semibold">{ categoryHeading }</h2>
									// The conflict-gated chip + its help icon share the same
									// visibility hook (.sw-conflict-gated-chip is toggled by
									// JS when the active conflict state changes). Keeping the
									// help icon inside the chip wrapper ensures the "?"
									// describing the chip never shows when the chip itself is
									// hidden, which would otherwise refer to UI the user
									// cannot see.
									if cat == "image" {
										<span class="sw-conflict-gated-chip hidden" title={ t(ctx, "settings.rules.conflict_gated_image_tooltip") }>
											<span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 px-2 py-0.5 text-xs font-medium">{ t(ctx, "settings.rules.conflict_gated_chip") }</span>
											@components.ContextHelp("help-rules-conflict-gated-image", categoryHeading, t(ctx, "settings.rules.help_conflict_gated_image"), "core-concepts/conflict-gate#how-writes-are-gated")
										</span>
									}
									if cat == "nfo" {
										<span class="sw-conflict-gated-chip hidden" title={ t(ctx, "settings.rules.conflict_gated_nfo_tooltip") }>
											<span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 px-2 py-0.5 text-xs font-medium">{ t(ctx, "settings.rules.conflict_gated_chip") }</span>
											@components.ContextHelp("help-rules-conflict-gated-nfo", categoryHeading, t(ctx, "settings.rules.help_conflict_gated_nfo"), "core-concepts/conflict-gate#how-writes-are-gated")
										</span>
									}
									if cat == "nfo" {
										@components.ContextHelp("help-rules-nfo", categoryHeading, t(ctx, "settings.rules.help_nfo"), "settings-rules-rules")
									}
									if cat == "image" {
										@components.ContextHelp("help-rules-image", categoryHeading, t(ctx, "settings.rules.help_image"), "settings-rules-rules")
									}
									if cat == "metadata" {
										@components.ContextHelp("help-rules-metadata", categoryHeading, t(ctx, "settings.rules.help_metadata"), "settings-rules-rules")
									}
								</div>
							</div>
							<div class="px-6 divide-y divide-gray-100 dark:divide-gray-700">
								// Each row inspects the page-level flags (declared above)
								// before flipping them so the help icon emits exactly once.
								// The fsHelpShown and severityHelpShown flags are shared across
								// all sub-groups within this card so they still fire exactly once.
								if cat == "image" {
									for _, pfx := range imageSubtypePrefixes {
										{{ sub := rulesForImageSubtype(catRules, pfx) }}
										if len(sub) > 0 {
											<h3 class="px-0 pt-4 pb-1 text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">{ imageSubtypeLabel(ctx, sub[0].ID) }</h3>
											for _, rl := range sub {
												{{ isFsUnavail := rl.FilesystemDependent && !data.HasLocalLibrary }}
												{{ showFsHelp := isFsUnavail && !fsHelpShown }}
												{{ showSeverityHelp := !severityHelpShown }}
												if showFsHelp {
													{{ fsHelpShown = true }}
												}
												if showSeverityHelp {
													{{ severityHelpShown = true }}
												}
												@ruleRow(rl, data.HasLocalLibrary, showSeverityHelp, showFsHelp)
											}
										}
									}
									{{ generalRules := rulesForImageSubtypeFallback(catRules) }}
									if len(generalRules) > 0 {
										<h3 class="px-0 pt-4 pb-1 text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">{ imageSubtypeLabel(ctx, generalRules[0].ID) }</h3>
										for _, rl := range generalRules {
											{{ isFsUnavail := rl.FilesystemDependent && !data.HasLocalLibrary }}
											{{ showFsHelp := isFsUnavail && !fsHelpShown }}
											{{ showSeverityHelp := !severityHelpShown }}
											if showFsHelp {
												{{ fsHelpShown = true }}
											}
											if showSeverityHelp {
												{{ severityHelpShown = true }}
											}
											@ruleRow(rl, data.HasLocalLibrary, showSeverityHelp, showFsHelp)
										}
									}
								} else {
									for _, rl := range catRules {
										{{ isFsUnavail := rl.FilesystemDependent && !data.HasLocalLibrary }}
										{{ showFsHelp := isFsUnavail && !fsHelpShown }}
										{{ showSeverityHelp := !severityHelpShown }}
										if showFsHelp {
											{{ fsHelpShown = true }}
										}
										if showSeverityHelp {
											{{ severityHelpShown = true }}
										}
										@ruleRow(rl, data.HasLocalLibrary, showSeverityHelp, showFsHelp)
									}
								}
							</div>
						</div>
					}
				}
				if len(data.Rules) == 0 {
					<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg px-6 py-8 text-center">
						<p class="text-sm text-gray-500 dark:text-gray-400">{ t(ctx, "settings.rules.empty") }</p>
					</div>
				}
				<!-- Rule Evaluation Schedule -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.rule_schedule.title") }</h2>
							@components.ContextHelp("help-rule-schedule", t(ctx, "settings.rule_schedule.title"), t(ctx, "settings.rule_schedule.help"), "settings-rules-rule-schedule")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.rule_schedule.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<div class="flex items-center gap-4">
							<label class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.rule_schedule.interval_label") }</label>
							<select
								onchange="updateRuleSchedule(this)"
								class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
							>
								<option value="0" selected?={ data.RuleScheduleMinutes == 0 }>{ t(ctx, "common.disabled") }</option>
								<option value="5" selected?={ data.RuleScheduleMinutes == 5 }>{ t(ctx, "settings.schedule.every_5m") }</option>
								<option value="15" selected?={ data.RuleScheduleMinutes == 15 }>{ t(ctx, "settings.schedule.every_15m") }</option>
								<option value="30" selected?={ data.RuleScheduleMinutes == 30 }>{ t(ctx, "settings.schedule.every_30m") }</option>
								<option value="60" selected?={ data.RuleScheduleMinutes == 60 }>{ t(ctx, "settings.schedule.every_hour") }</option>
								<option value="360" selected?={ data.RuleScheduleMinutes == 360 }>{ t(ctx, "settings.schedule.every_6h") }</option>
								<option value="720" selected?={ data.RuleScheduleMinutes == 720 }>{ t(ctx, "settings.schedule.every_12h") }</option>
								<option value="1440" selected?={ data.RuleScheduleMinutes == 1440 }>{ t(ctx, "settings.schedule.daily") }</option>
							</select>
						</div>
						<p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.rule_schedule.note") }
						</p>
					</div>
				</div>
			</div>
			<!-- Users tab -->
			<div
				data-tab-panel={ string(TabUsers) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabUsers),
				}
			>
				@settingsUsersTab(data.Users)
			</div>
			<!-- Auth Providers tab -->
			<div
				data-tab-panel={ string(TabAuthProviders) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabAuthProviders),
				}
			>
				@settingsAuthProvidersTab(data.AuthProviders)
			</div>
			<!-- Maintenance tab -->
			<div
				data-tab-panel={ string(TabMaintenance) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabMaintenance),
				}
			>
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.confirm_dialogs.title") }</h2>
							@components.ContextHelp("help-confirm-dialogs", t(ctx, "settings.confirm_dialogs.title"), t(ctx, "settings.confirm_dialogs.help"), "settings-maintenance-confirm-dialogs")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.confirm_dialogs.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
							{ t(ctx, "settings.confirm_dialogs.reset_info") }
						</p>
						<button
							type="button"
							id="reset-confirm-prefs"
							class="text-sm px-3 py-2 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
							onclick="resetConfirmPrefs()"
						>
							Reset all confirmation preferences
						</button>
						<span id="confirm-reset-status" class="ml-2 text-sm text-green-600 dark:text-green-400 hidden">{ t(ctx, "settings.confirm_dialogs.reset_success") }</span>
					</div>
				</div>
				<!-- Database Maintenance -->
				@components.SettingSection("help-db-maintenance", t(ctx, "settings.db_maintenance.title"), t(ctx, "settings.db_maintenance.help"), "settings-maintenance-db-maintenance", t(ctx, "settings.db_maintenance.description")) {
					<div id="maintenance-status" hx-get="/api/v1/settings/maintenance/status" hx-trigger="load" hx-swap="innerHTML">
						<p class="text-sm text-gray-500 dark:text-gray-400 italic">{ t(ctx, "common.loading_status") }</p>
					</div>
					<div class="flex items-center gap-3 pt-2 border-t border-gray-200 dark:border-gray-700">
						<button
							type="button"
							class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
							hx-post="/api/v1/settings/maintenance/optimize"
							hx-target="#maintenance-status"
							hx-swap="innerHTML"
							hx-indicator="#optimize-spinner"
						>
							Optimize Now
						</button>
						<span id="optimize-spinner" class="htmx-indicator text-sm text-gray-500 dark:text-gray-400">
							Optimizing...
						</span>
						<button
							type="button"
							class="text-sm px-3 py-2 rounded bg-amber-600 text-white hover:bg-amber-700 transition-colors"
							hx-post="/api/v1/settings/maintenance/vacuum"
							hx-target="#maintenance-status"
							hx-swap="innerHTML"
							hx-indicator="#vacuum-spinner"
							hx-confirm={ t(ctx, "settings.db_maintenance.confirm_vacuum") }
						>
							Vacuum
						</button>
						<span id="vacuum-spinner" class="htmx-indicator text-sm text-gray-500 dark:text-gray-400">
							Running vacuum...
						</span>
					</div>
					<div class="pt-2 border-t border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-4">
							<div class="flex items-center gap-1">
								<label class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.db_maintenance.auto_schedule") }</label>
								@components.ContextHelp("help-db-auto-schedule", t(ctx, "settings.db_maintenance.auto_schedule"), t(ctx, "settings.db_maintenance.auto_schedule.help"), "settings-maintenance-db-maintenance-auto-schedule")
							</div>
							<select
								id="maint-interval"
								onchange="updateMaintSchedule(this)"
								class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
							>
								<option value="6">{ t(ctx, "settings.schedule.every_6h") }</option>
								<option value="12">{ t(ctx, "settings.schedule.every_12h") }</option>
								<option value="24" selected>{ t(ctx, "settings.schedule.daily") }</option>
								<option value="168">{ t(ctx, "settings.schedule.weekly") }</option>
							</select>
							<span id="maint-schedule-status"></span>
						</div>
						<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.db_maintenance.schedule_note") }
						</p>
					</div>
				}
				@components.SettingSection("help-backup", t(ctx, "settings.backup.title"), t(ctx, "settings.backup.help"), "settings-maintenance-backup", t(ctx, "settings.backup.description")) {
					<div class="flex items-center gap-3">
						<button
							type="button"
							class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
							hx-post="/api/v1/settings/backup"
							hx-target="#backup-list"
							hx-swap="innerHTML"
							hx-indicator="#backup-spinner"
						>
							Create Backup
						</button>
						<span id="backup-spinner" class="htmx-indicator text-sm text-gray-500 dark:text-gray-400">
							Creating backup...
						</span>
					</div>
					<div class="pt-2 border-t border-gray-200 dark:border-gray-700">
						<h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{ t(ctx, "settings.backup.retention") }</h3>
						<div class="flex flex-wrap items-center gap-4">
							<div class="flex items-center gap-2">
								<label for="backup-retention" class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "settings.backup.keep") }</label>
								@components.ContextHelp("help-backup-keep", t(ctx, "settings.backup.keep"), t(ctx, "settings.backup.keep.help"), "settings-maintenance-backup-keep")
								<input
									type="number"
									id="backup-retention"
									min="1"
									max="100"
									value={ fmt.Sprint(data.BackupRetention) }
									class="w-20 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1.5 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
								/>
								<span class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "settings.backup.backups_unit") }</span>
							</div>
							<div class="flex items-center gap-2">
								<label for="backup-max-age" class="text-sm text-gray-600 dark:text-gray-400">{ t(ctx, "settings.backup.max_age") }</label>
								@components.ContextHelp("help-backup-max-age", t(ctx, "settings.backup.max_age"), t(ctx, "settings.backup.max_age.help"), "settings-maintenance-backup-max-age")
								<select
									id="backup-max-age"
									class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
								>
									<option value="0" selected?={ data.BackupMaxAgeDays == 0 }>{ t(ctx, "common.never") }</option>
									<option value="7" selected?={ data.BackupMaxAgeDays == 7 }>{ t(ctx, "settings.backup.days_7") }</option>
									<option value="14" selected?={ data.BackupMaxAgeDays == 14 }>{ t(ctx, "settings.backup.days_14") }</option>
									<option value="30" selected?={ data.BackupMaxAgeDays == 30 }>{ t(ctx, "settings.backup.days_30") }</option>
									<option value="60" selected?={ data.BackupMaxAgeDays == 60 }>{ t(ctx, "settings.backup.days_60") }</option>
									<option value="90" selected?={ data.BackupMaxAgeDays == 90 }>{ t(ctx, "settings.backup.days_90") }</option>
								</select>
							</div>
							<button
								type="button"
								class="text-sm px-3 py-1.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
								onclick="saveBackupSettings()"
							>
								Save
							</button>
							<span id="backup-retention-status" class="text-xs text-green-600 dark:text-green-400 hidden">{ t(ctx, "common.saved") }</span>
						</div>
						<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.backup.retention_note") }
						</p>
					</div>
					<div id="backup-list" hx-get="/api/v1/settings/backup/history" hx-trigger="load" hx-swap="innerHTML">
						<p class="text-sm text-gray-500 dark:text-gray-400 italic">{ t(ctx, "settings.backup.loading_history") }</p>
					</div>
				}
				<!-- Settings Export / Import -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.export_import.title") }</h2>
							@components.ContextHelp("help-export-import", t(ctx, "settings.export_import.title"), t(ctx, "settings.export_import.help"), "settings-maintenance-export-import")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.export_import.description_line1") }
							{ t(ctx, "settings.export_import.description_line2") }
						</p>
					</div>
					<div class="px-6 py-4 space-y-4">
						<form
							onsubmit="event.preventDefault(); exportSettings(this);"
							class="space-y-3"
						>
							<div>
								<div class="flex items-center gap-1 mb-1">
									<label for="export-passphrase" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.export_import.export_passphrase") }</label>
									@components.ContextHelp("help-export-passphrase", t(ctx, "settings.export_import.export_passphrase"), t(ctx, "settings.export_import.export_passphrase.help"), "settings-maintenance-export-import-export-passphrase")
								</div>
								<input
									id="export-passphrase"
									name="export_passphrase"
									type="password"
									required
									minlength="8"
									placeholder={ t(ctx, "settings.export_import.passphrase_placeholder") }
									class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
								/>
							</div>
							<div class="flex items-center gap-3">
								<button
									type="submit"
									id="export-btn"
									class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
								>
									Export Settings
								</button>
								<span id="export-spinner" class="hidden text-sm text-gray-500 dark:text-gray-400">
									Exporting...
								</span>
							</div>
						</form>
						<div id="export-result" class="mt-2"></div>
						<div class="pt-2 border-t border-gray-200 dark:border-gray-700">
							<form
								hx-post="/api/v1/settings/import"
								hx-target="#import-result"
								hx-swap="innerHTML"
								hx-encoding="multipart/form-data"
								hx-indicator="#import-spinner"
								class="space-y-3"
							>
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="import-file" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.export_import.import_file_label") }</label>
										@components.ContextHelp("help-import-file", t(ctx, "settings.export_import.import_file_label"), t(ctx, "settings.export_import.import_file_label.help"), "settings-maintenance-export-import-import-file-label")
									</div>
									<input
										id="import-file"
										name="file"
										type="file"
										accept=".json"
										required
										class="block w-full text-sm text-gray-900 dark:text-gray-100 file:mr-4 file:py-2 file:px-3 file:rounded file:border-0 file:text-sm file:bg-gray-100 dark:file:bg-gray-700 file:text-gray-700 dark:file:text-gray-300 hover:file:bg-gray-200 dark:hover:file:bg-gray-600"
									/>
								</div>
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="import-passphrase" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.export_import.import_passphrase") }</label>
										@components.ContextHelp("help-import-passphrase", t(ctx, "settings.export_import.import_passphrase"), t(ctx, "settings.export_import.import_passphrase.help"), "settings-maintenance-export-import-import-passphrase")
									</div>
									<input
										id="import-passphrase"
										name="passphrase"
										type="password"
										required
										placeholder={ t(ctx, "settings.export_import.import_passphrase_placeholder") }
										class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
									/>
								</div>
								<div class="flex items-center gap-3">
									<button
										type="submit"
										class="text-sm px-3 py-2 rounded bg-green-600 text-white hover:bg-green-700 transition-colors"
									>
										Import
									</button>
									<span id="import-spinner" class="htmx-indicator text-sm text-gray-500 dark:text-gray-400">
										Importing...
									</span>
								</div>
							</form>
							<div id="import-result" class="mt-2"></div>
						</div>
						<p class="text-xs text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.export_import.encryption_note_line1") }
							{ t(ctx, "settings.export_import.encryption_note_line2") }
						</p>
					</div>
				</div>
			</div>
			<!-- Logs tab -->
			<div
				data-tab-panel={ string(TabLogs) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabLogs),
				}
			>
				<!-- Log Settings -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.log_settings.title") }</h2>
							@components.ContextHelp("help-log-settings", t(ctx, "settings.log_settings.title"), t(ctx, "settings.log_settings.help"), "settings-logs-log-settings")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.log_settings.description") }
						</p>
					</div>
					<div class="px-6 py-4">
						<form
							id="logging-config-form"
							hx-put="/api/v1/settings/logging"
							hx-target="#logging-status"
							hx-swap="innerHTML"
							class="space-y-4"
						>
							<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="log-level" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.level") }</label>
										@components.ContextHelp("help-log-level", t(ctx, "settings.log_settings.level"), t(ctx, "settings.log_settings.level.help"), "settings-logs-log-settings-level")
									</div>
									<select
										id="log-level"
										name="level"
										onchange="if(typeof updateEphemeralRow==='function')updateEphemeralRow()"
										class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
										hx-get="/api/v1/settings/logging"
										hx-trigger="load"
										hx-swap="none"
										hx-on::after-request="if(event.detail.successful){try{loadLoggingConfig(JSON.parse(event.detail.xhr.responseText));}catch(e){}}"
									>
										<option value="trace">{ t(ctx, "settings.log_settings.level_trace") }</option>
										<option value="debug">{ t(ctx, "settings.log_settings.level_debug") }</option>
										<option value="info" selected>{ t(ctx, "common.info") }</option>
										<option value="warn">Warn</option>
										<option value="error">{ t(ctx, "common.error") }</option>
									</select>
								</div>
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="log-format" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.format") }</label>
										@components.ContextHelp("help-log-format", t(ctx, "settings.log_settings.format"), t(ctx, "settings.log_settings.format.help"), "settings-logs-log-settings-format")
									</div>
									<select
										id="log-format"
										name="format"
										class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
									>
										<option value="json">{ t(ctx, "settings.log_settings.format_json") }</option>
										<option value="text">{ t(ctx, "settings.log_settings.format_text") }</option>
									</select>
								</div>
							</div>
							<!-- Ephemeral level: when checked, level change is not persisted to DB -->
							<div id="ephemeral-level-row" class="hidden flex items-center gap-2">
								<input
									type="checkbox"
									id="ephemeral-level"
									name="ephemeral"
									value="true"
									class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500 dark:bg-gray-700"
									aria-label={ t(ctx, "settings.log_settings.revert_on_restart") }
								/>
								<label for="ephemeral-level" class="text-sm text-gray-600 dark:text-gray-400">
									{ t(ctx, "settings.log_settings.revert_to") } <span id="ephemeral-revert-level" class="font-medium">info</span> { t(ctx, "settings.log_settings.on_restart") }
								</label>
							</div>
							<!-- Hidden input always submitted; JS keeps it in sync with the path display field -->
							<input type="hidden" name="file_path" id="log-file-path" value=""/>
							<!-- Log to file toggle -->
							<div class="flex items-center justify-between py-1">
								<div>
									<div class="flex items-center gap-1">
										<p class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.log_to_file.label") }</p>
										@components.ContextHelp("help-log-to-file", t(ctx, "settings.log_settings.log_to_file.label"), t(ctx, "settings.log_settings.log_to_file.help"), "settings-logs-log-settings-log-to-file")
									</div>
									<p class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.log_settings.log_to_file.description") }</p>
								</div>
								<button
									type="button"
									id="log-to-file-btn"
									role="switch"
									aria-checked="false"
									aria-label={ t(ctx, "settings.log_settings.log_to_file.label") }
									onclick="toggleFileLogging()"
									class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-gray-200 dark:bg-gray-600 transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
								>
									<span class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out translate-x-0"></span>
								</button>
							</div>
							<!-- File logging settings (shown when toggle is on) -->
							<div id="file-logging-settings" class="hidden space-y-4">
								<div>
									<div class="flex items-center gap-1 mb-1">
										<label for="log-file-path-display" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.file_path") }</label>
										@components.ContextHelp("help-log-file-path", t(ctx, "settings.log_settings.file_path"), t(ctx, "settings.log_settings.file_path.help"), "settings-logs-log-settings-file-path")
									</div>
									<input
										id="log-file-path-display"
										type="text"
										placeholder="/config/logs/stillwater.log"
										class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
										oninput="syncLogFilePath(this.value)"
									/>
									<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.log_settings.file_path_note") }</p>
								</div>
								<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
									<div>
										<div class="flex items-center gap-1 mb-1">
											<label for="log-file-max-size" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.max_size") }</label>
											@components.ContextHelp("help-log-max-size", t(ctx, "settings.log_settings.max_size"), t(ctx, "settings.log_settings.max_size.help"), "settings-logs-log-settings-max-size")
										</div>
										<input id="log-file-max-size" name="file_max_size_mb" type="number" value="10" min="1" class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" aria-label={ t(ctx, "settings.log_settings.max_size") }/>
									</div>
									<div>
										<div class="flex items-center gap-1 mb-1">
											<label for="log-file-max-files" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.files_to_keep") }</label>
											@components.ContextHelp("help-log-files-to-keep", t(ctx, "settings.log_settings.files_to_keep"), t(ctx, "settings.log_settings.files_to_keep.help"), "settings-logs-log-settings-files-to-keep")
										</div>
										<input id="log-file-max-files" name="file_max_files" type="number" value="5" min="1" class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" aria-label={ t(ctx, "settings.log_settings.files_to_keep") }/>
									</div>
									<div>
										<div class="flex items-center gap-1 mb-1">
											<label for="log-file-max-age" class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.log_settings.max_age") }</label>
											@components.ContextHelp("help-log-max-age", t(ctx, "settings.log_settings.max_age"), t(ctx, "settings.log_settings.max_age.help"), "settings-logs-log-settings-max-age")
										</div>
										<input id="log-file-max-age" name="file_max_age_days" type="number" value="30" min="1" class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" aria-label={ t(ctx, "settings.log_settings.max_age") }/>
									</div>
								</div>
								<!-- Cleanup row (visible only when rotated files exist) -->
								<div id="log-cleanup-row" class="hidden flex items-center gap-3 pt-1 border-t border-gray-200 dark:border-gray-700">
									<button
										type="button"
										onclick="cleanupLogFiles()"
										class="text-sm px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
									>
										Clean up old logs
									</button>
									<span id="log-cleanup-status" class="text-sm text-gray-500 dark:text-gray-400" role="status" aria-live="polite"></span>
								</div>
							</div>
							<div class="flex items-center gap-3">
								<button type="submit" class="text-sm px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors">
									Apply
								</button>
								<span id="logging-status" role="status" aria-live="polite"></span>
							</div>
						</form>
					</div>
				</div>
				<!-- Log Viewer -->
				<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
						<div class="flex items-center gap-2">
							<h2 class="text-lg font-semibold">{ t(ctx, "settings.log_viewer.title") }</h2>
							@components.ContextHelp("help-log-viewer", t(ctx, "settings.log_viewer.title"), t(ctx, "settings.log_viewer.help"), "settings-logs-log-viewer")
						</div>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.log_viewer.description") }
						</p>
					</div>
					<div class="px-6 py-4 space-y-3">
						<!-- Filter bar -->
						<div class="flex flex-wrap items-center gap-2">
							<div class="flex items-center gap-1" role="group" aria-label={ t(ctx, "settings.log_viewer.level_filter") }>
								<button
									type="button"
									data-log-level="trace"
									onclick="toggleLogLevel(this)"
									class="log-level-btn text-[10px] font-semibold uppercase px-2 py-1 rounded bg-purple-900/50 text-purple-300 opacity-50 hover:opacity-100 transition-opacity"
									aria-pressed="false"
								>
									Trace
								</button>
								<button
									type="button"
									data-log-level="debug"
									onclick="toggleLogLevel(this)"
									class="log-level-btn text-[10px] font-semibold uppercase px-2 py-1 rounded bg-gray-700 text-gray-300 opacity-50 hover:opacity-100 transition-opacity"
									aria-pressed="false"
								>
									Debug
								</button>
								<button
									type="button"
									data-log-level="info"
									onclick="toggleLogLevel(this)"
									class="log-level-btn text-[10px] font-semibold uppercase px-2 py-1 rounded bg-blue-900/50 text-blue-300 ring-1 ring-blue-500/50 transition-opacity"
									aria-pressed="true"
								>
									Info
								</button>
								<button
									type="button"
									data-log-level="warn"
									onclick="toggleLogLevel(this)"
									class="log-level-btn text-[10px] font-semibold uppercase px-2 py-1 rounded bg-amber-900/50 text-amber-300 ring-1 ring-amber-500/50 transition-opacity"
									aria-pressed="false"
								>
									Warn
								</button>
								<button
									type="button"
									data-log-level="error"
									onclick="toggleLogLevel(this)"
									class="log-level-btn text-[10px] font-semibold uppercase px-2 py-1 rounded bg-red-900/50 text-red-300 ring-1 ring-red-500/50 transition-opacity"
									aria-pressed="false"
								>
									Error
								</button>
							</div>
							<input
								type="text"
								id="log-search"
								placeholder={ t(ctx, "settings.log_viewer.search_placeholder") }
								oninput="updateLogFilters()"
								class="flex-1 min-w-[150px] rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
								aria-label={ t(ctx, "settings.log_viewer.search_placeholder") }
							/>
							<div class="flex items-center gap-1">
								<button
									type="button"
									id="log-pause-btn"
									onclick="toggleLogPause()"
									class="text-xs px-2.5 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
									aria-label={ t(ctx, "actions.pause") }
									aria-pressed="false"
								>
									Pause
								</button>
								<button
									type="button"
									onclick="clearLogs()"
									class="text-xs px-2.5 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
									aria-label={ t(ctx, "actions.clear") }
								>
									Clear
								</button>
								<button
									type="button"
									onclick="downloadLogs()"
									class="text-xs px-2.5 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
									aria-label={ t(ctx, "actions.download") }
								>
									Download
								</button>
							</div>
						</div>
						<!-- Log file picker (visible only when file logging is configured) -->
						<div id="log-file-picker-row" class="hidden flex items-center gap-2">
							<label for="log-file-select" class="text-xs text-gray-400 dark:text-gray-500 shrink-0">{ t(ctx, "settings.log_viewer.file_label") }:</label>
							<select
								id="log-file-select"
								onchange="selectLogFile(this.value)"
								class="rounded border border-gray-600 bg-gray-800 text-gray-200 text-xs px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500"
								aria-label={ t(ctx, "settings.log_viewer.select_file") }
							>
								<option value="">{ t(ctx, "settings.log_viewer.live_current") }</option>
							</select>
						</div>
						<!-- Log viewer container -->
						<div
							id="log-viewer"
							class="h-[28rem] overflow-y-auto font-mono text-xs bg-gray-950 rounded-lg border border-gray-800 p-2"
							hx-get="/api/v1/logs?limit=200&level=info"
							hx-trigger="load, every 2s, logRefresh from:body"
							hx-swap="innerHTML"
						>
							<div class="flex items-center justify-center h-full text-gray-500 text-sm">
								Loading logs...
							</div>
						</div>
						<p class="text-xs text-gray-500 dark:text-gray-400">
							{ t(ctx, "settings.log_viewer.footer_note") }
						</p>
					</div>
				</div>
			</div>
			<!-- Updates tab -->
			<div
				data-tab-panel={ string(TabUpdates) }
				class={
					"space-y-6",
					templ.KV("hidden", data.ActiveTab != TabUpdates),
				}
			>
				@settingsUpdatesTab(data.Updates, assets.BasePath)
			</div>
		</div>
		<script src={ assets.SettingsSortableInitJS }></script>
		<script src={ assets.SettingsUpdatesJS }></script>
	}
}

templ settingsTabBar(activeTab SettingsTabID, basePath string) {
	<div class="sw-card rounded-lg p-1.5">
		<div class="px-2 pb-1.5">
			<input
				type="search"
				id="settings-search-input"
				placeholder={ t(ctx, "settings.search_placeholder") }
				aria-label={ t(ctx, "settings.search_placeholder") }
				class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1.5 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
			/>
		</div>
		<nav class="flex overflow-x-auto gap-0.5" aria-label={ t(ctx, "settings.tabs_label") }>
			for _, tab := range settingsTabs() {
				<a
					href={ templ.SafeURL(basePath + "/settings?tab=" + string(tab.ID)) }
					class={
						"sw-settings-tab whitespace-nowrap rounded-md px-4 py-2 text-sm font-medium transition-all cursor-pointer",
						templ.KV("bg-white dark:bg-gray-700 text-blue-600 dark:text-blue-300 shadow-sm", tab.ID == activeTab),
						templ.KV("text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 hover:bg-white/60 dark:hover:bg-gray-700/60", tab.ID != activeTab),
					}
					data-tab={ string(tab.ID) }
					onclick="switchSettingsTab(event, this)"
				>
					{ t(ctx, tab.Label) }
				</a>
			}
		</nav>
	</div>
}

// settingsSearchIndexScript emits the search index as a window-global JSON
// variable. Using @templ.Raw avoids HTML-attribute escaping that would corrupt
// the JSON; this is safe because json.Marshal produces only ASCII-safe output
// with no unescaped angle brackets or ampersands.
templ settingsSearchIndexScript(index []SettingsSearchEntry) {
	@templ.Raw(`<script>window.swSettingsSearchIndex = ` + jsonSearchIndex(index) + `;</script>`)
}

templ settingsLibraryRow(lib library.Library) {
	<div class="flex items-center justify-between rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3" id={ "settings-lib-" + lib.ID }>
		<div>
			<div class="font-medium text-sm text-gray-900 dark:text-gray-100">{ lib.Name }</div>
			if lib.Path != "" {
				<div class="text-xs text-gray-500 dark:text-gray-400">{ lib.Path }</div>
			}
			<div class="flex items-center gap-1.5 mt-1">
				<span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2 py-0.5 text-xs text-gray-600 dark:text-gray-300">{ lib.Type }</span>
				if lib.ConnectionID != "" {
					<span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2 py-0.5 text-xs text-gray-600 dark:text-gray-300">{ t(ctx, "settings.libraries.connection_badge") }</span>
				}
				if lib.Source != "" && lib.Source != "manual" {
					<span class="inline-flex items-center gap-1 rounded-full bg-gray-100 dark:bg-gray-700 px-2 py-0.5 text-xs text-gray-600 dark:text-gray-300">
						<img src={ logoSrc(lib.Source) } class="h-3.5 w-3.5" alt=""/>
						{ sourceDisplayName(lib.Source) }
					</span>
				}
			</div>
		</div>
		<div class="flex items-center gap-2">
			if !lib.IsPathless() {
				<select
					class="text-xs rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 focus:ring-blue-500 px-1.5 py-1"
					title={ t(ctx, "settings.libraries.fs_mode_title") }
					onchange={ settingsUpdateFSMode(lib.ID) }
				>
					<option value="0" selected?={ lib.FSWatch == 0 }>{ t(ctx, "settings.libraries.fs_off") }</option>
					if lib.FSNotifySupported {
						<option value="1" selected?={ lib.FSWatch == library.FSModeWatch }>{ t(ctx, "settings.libraries.fs_watch") }</option>
					}
					<option value="2" selected?={ lib.FSWatch == library.FSModePoll }>{ t(ctx, "settings.libraries.fs_poll") }</option>
					if lib.FSNotifySupported {
						<option value="3" selected?={ lib.FSWatch == library.FSModeBoth }>{ t(ctx, "settings.libraries.fs_both") }</option>
					}
				</select>
				@components.ContextHelp("fs-mode-help-"+lib.ID, t(ctx, "settings.libraries.fs_mode_title"), t(ctx, "settings.libraries.fs_mode_title.help"), "settings-libraries-libraries-fs-mode-title")
				if lib.FSPollEnabled() {
					<select
						class="text-xs rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 focus:ring-blue-500 px-1.5 py-1"
						title={ t(ctx, "settings.libraries.poll_interval_title") }
						onchange={ settingsUpdatePollInterval(lib.ID) }
					>
						<option value="60" selected?={ lib.FSPollInterval == 60 }>1m</option>
						<option value="300" selected?={ lib.FSPollInterval == 300 }>5m</option>
						<option value="900" selected?={ lib.FSPollInterval == 900 }>15m</option>
						<option value="1800" selected?={ lib.FSPollInterval == 1800 }>30m</option>
					</select>
					@components.ContextHelp("help-lib-poll-interval-"+lib.ID, t(ctx, "settings.libraries.poll_interval_title"), t(ctx, "settings.libraries.poll_interval_title.help"), "settings-libraries-libraries-poll-interval-title")
				}
				<span class="inline-flex items-center gap-1">
					{{ lockNfoDescID := "lock-nfo-desc-" + lib.ID }}
					<label class="inline-flex items-center gap-1 text-xs text-gray-700 dark:text-gray-300 cursor-pointer">
						<input
							type="checkbox"
							class="rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-blue-500"
							checked?={ lib.NFOLockData }
							onchange={ settingsUpdateLockNFO(lib.ID) }
							aria-describedby={ lockNfoDescID }
						/>
						<span>{ t(ctx, "settings.libraries.lock_nfo_label") }</span>
					</label>
					<span id={ lockNfoDescID } class="sr-only">{ t(ctx, "settings.libraries.lock_nfo_label.description") }</span>
					@components.ContextHelp("lock-nfo-help-"+lib.ID, t(ctx, "settings.libraries.lock_nfo_label"), t(ctx, "settings.libraries.lock_nfo_label.help"), "settings-libraries-libraries-lock-nfo-label")
				</span>
			}
			if lib.ConnectionID != "" {
				<button
					type="button"
					id={ "populate-btn-" + lib.ID }
					class="text-xs px-2 py-1 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors inline-flex items-center gap-1"
					onclick={ settingsAsyncLibOp(lib.ConnectionID, lib.ID, "populate") }
				>
					<svg id={ "populate-spinner-" + lib.ID } class="hidden animate-spin h-3 w-3" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
					<span id={ "populate-label-" + lib.ID }>{ t(ctx, "settings.libraries.resync") }</span>
				</button>
			}
			if lib.ConnectionID != "" {
				<button
					type="button"
					id={ "scan-btn-" + lib.ID }
					class="text-xs px-2 py-1 rounded bg-gray-600 text-white hover:bg-gray-700 transition-colors inline-flex items-center gap-1"
					onclick={ settingsAsyncLibOp(lib.ConnectionID, lib.ID, "scan") }
				>
					<svg id={ "scan-spinner-" + lib.ID } class="hidden animate-spin h-3 w-3" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
					<span id={ "scan-label-" + lib.ID }>{ t(ctx, "settings.libraries.scan") }</span>
				</button>
			}
			<button
				type="button"
				class="text-xs text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300"
				onclick={ settingsDeleteLibrary(lib.ID) }
			>
				Remove
			</button>
		</div>
	</div>
}

script settingsUpdateFSMode(id string) {
	updateLibraryFSMode(id, parseInt(event.target.value, 10));
}

script settingsUpdatePollInterval(id string) {
	updateLibraryPollInterval(id, parseInt(event.target.value, 10));
}

script settingsUpdateLockNFO(id string) {
	updateLibraryLockNFO(id, event.target, !!event.target.checked);
}

script settingsDeleteLibrary(id string) {
	settingsDeleteLibrary_click(id);
}

script settingsAsyncLibOp(connID string, libID string, operation string) {
	runLibraryOp(connID, libID, operation);
}

templ ProviderKeyCard(pk provider.ProviderKeyStatus) {
	{{ hasGear := pk.RequiresKey || pk.OptionalKey || pk.SupportsBaseURL || len(pk.VerbosityOptions) > 0 }}
	<div class="flex flex-col gap-2 rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex items-center gap-3">
			if logoSrcSet(string(pk.Name)) != "" {
				<img
					src={ logoSrc(string(pk.Name)) }
					srcset={ logoSrcSet(string(pk.Name)) }
					alt=""
					class="h-6 w-6 shrink-0"
					aria-hidden="true"
				/>
			} else {
				<img
					src={ logoSrc(string(pk.Name)) }
					alt=""
					class="h-6 w-6 shrink-0"
					aria-hidden="true"
				/>
			}
			@providerStatusDot(string(pk.Name), pk.Status, false)
			<div>
				<div class="flex items-center gap-2">
					<span id={ "provider-name-" + string(pk.Name) } class="font-medium text-sm">{ pk.DisplayName }</span>
					if pk.AccessTier != "" {
						<span
							class={ "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium", tierBadgeClasses(pk.AccessTier) }
							title={ tierTooltip(ctx, pk.AccessTier) }
							aria-describedby={ "tier-tooltip-" + string(pk.Name) }
						>
							{ tierBadgeLabel(ctx, pk.AccessTier) }
						</span>
						<span id={ "tier-tooltip-" + string(pk.Name) } class="sr-only">{ tierTooltip(ctx, pk.AccessTier) }</span>
					}
				</div>
				{{ rlText := rateLimitText(pk.RateLimit) }}
				<div class="flex items-center gap-2 mt-0.5">
					if !pk.RequiresKey && !pk.OptionalKey {
						<span class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.provider_keys.no_key_required") }</span>
					} else if pk.OptionalKey && pk.HasKey {
						<span class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.provider_keys.premium_configured") }</span>
					} else if pk.OptionalKey {
						<span class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.provider_keys.free_tier") }</span>
					} else if pk.HasKey {
						<span class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.provider_keys.key_configured") }</span>
					} else {
						<span class="text-xs text-amber-600 dark:text-amber-400">{ t(ctx, "settings.provider_keys.key_required") }</span>
					}
					if rlText != "" {
						<span class="text-xs text-gray-400 dark:text-gray-500">{ rlText }</span>
					}
				</div>
			</div>
		</div>
		<div class="flex items-center gap-2">
			if pk.RequiresKey || pk.OptionalKey {
				if pk.HelpURL != "" {
					<a
						href={ templ.SafeURL(pk.HelpURL) }
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
					>
						{ getKeyLinkText(ctx, pk.AccessTier) }
					</a>
				}
			}
			if pk.SupportsBaseURL {
				if mirrorStatusLabel(ctx, pk.Mirror) != "" {
					<span class="inline-flex items-center rounded-full px-1.5 py-0.5 text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
						{ mirrorStatusLabel(ctx, pk.Mirror) }
					</span>
				}
			}
			if pk.RequiresKey || pk.OptionalKey || pk.HasKey || pk.SupportsBaseURL {
				<button
					type="button"
					class="text-sm px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors inline-flex items-center gap-1.5"
					aria-label={ "Test " + pk.DisplayName + " connection" }
					hx-post={ "/api/v1/providers/" + string(pk.Name) + "/test" }
					hx-target={ "#test-result-" + string(pk.Name) }
					hx-swap="innerHTML"
					hx-indicator={ "#test-spinner-" + string(pk.Name) }
				>
					Test
					<svg id={ "test-spinner-" + string(pk.Name) } class="htmx-indicator h-3.5 w-3.5 animate-spin" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</button>
			}
			if hasGear {
				<button
					type="button"
					class="p-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-gray-500 dark:text-gray-400"
					aria-label={ t(ctx, "common.configure") + " " + pk.DisplayName }
					aria-expanded="false"
					aria-controls={ "config-panel-" + string(pk.Name) }
					onclick={ toggleProviderConfig(string(pk.Name)) }
				>
					@components.IconCog6Tooth("h-5 w-5")
				</button>
			}
		</div>
	</div>
	<div id={ "test-result-" + string(pk.Name) } class="ml-8 text-xs mt-1" role="status" aria-live="polite" aria-atomic="true"></div>
	if hasGear {
		<div
			id={ "config-panel-" + string(pk.Name) }
			class="hidden mt-2 sm:ml-8"
			role="region"
			aria-label={ t(ctx, "common.configure") + " " + pk.DisplayName }
		>
			if pk.RequiresKey || pk.OptionalKey {
				<div class="flex flex-col gap-2">
					<p class="text-xs font-medium text-gray-600 dark:text-gray-400">
						if pk.HasKey {
							{ t(ctx, "settings.provider_config.update_key") }
						} else {
							{ t(ctx, "settings.provider_config.add_key") }
						}
					</p>
					<form
						id={ "key-form-" + string(pk.Name) }
						class="flex flex-col gap-2"
						hx-put={ "/api/v1/providers/" + string(pk.Name) + "/key" }
						hx-target={ "#provider-card-" + string(pk.Name) }
						hx-swap="innerHTML"
					>
						if pk.Name == provider.NameSpotify {
							<div class="flex flex-col gap-2 sm:flex-row sm:items-center">
								<input
									type="text"
									name="client_id"
									placeholder={ t(ctx, "settings.provider_config.client_id") }
									autocomplete="off"
									data-1p-ignore
									data-lpignore="true"
									class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
									required
								/>
								<input
									type="password"
									name="client_secret"
									placeholder={ t(ctx, "settings.provider_config.client_secret") }
									autocomplete="off"
									data-1p-ignore
									data-lpignore="true"
									class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
									required
								/>
							</div>
							<p class="text-xs text-gray-500 dark:text-gray-400">
								{ t(ctx, "settings.provider_keys.spotify_note_prefix") }
								<a href="https://developer.spotify.com" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">Spotify Developer</a> { t(ctx, "settings.provider_keys.spotify_note_suffix") }
							</p>
						} else {
							<div class="flex flex-col gap-2 sm:flex-row sm:items-center">
								<input
									type="text"
									name="api_key"
									if pk.OptionalKey {
										placeholder={ t(ctx, "settings.provider_keys.premium_key_placeholder") }
									} else {
										placeholder={ t(ctx, "settings.provider_keys.key_placeholder") }
									}
									autocomplete="off"
									data-1p-ignore
									data-lpignore="true"
									class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
									required
								/>
							</div>
						}
						<div class="flex gap-2">
							<button
								type="submit"
								class="text-sm px-3 py-2 rounded bg-green-600 text-white hover:bg-green-700 transition-colors"
							>
								Save
							</button>
							<button
								type="button"
								class="text-sm px-3 py-2 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
								onclick={ toggleProviderConfig(string(pk.Name)) }
							>
								Cancel
							</button>
						</div>
					</form>
					<div id={ "provider-save-result-" + string(pk.Name) } class="mt-1"></div>
				</div>
			}
			if pk.SupportsBaseURL {
				{{ serverType := mirrorServerType(pk.Mirror) }}
				if pk.RequiresKey || pk.OptionalKey {
					<div class="border-t border-gray-100 dark:border-gray-700 my-3"></div>
				}
				<form
					id={ "config-form-" + string(pk.Name) }
					class="flex flex-col gap-3"
				>
					<fieldset>
						<legend class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-2">{ t(ctx, "settings.provider_config.server") }</legend>
						<div class="flex flex-col gap-1.5">
							<label class="flex items-center gap-2 text-sm cursor-pointer">
								<input
									type="radio"
									name="server_type"
									value="official"
									if serverType == "official" {
										checked
									}
									class="text-blue-600 focus:ring-blue-500"
									onchange={ handleServerSelection(string(pk.Name)) }
								/>
								<span>{ t(ctx, "settings.provider_config.official") }</span>
								<span class="text-xs text-gray-400 dark:text-gray-500">musicbrainz.org (1 req/s)</span>
							</label>
							<label class="flex items-center gap-2 text-sm cursor-pointer">
								<input
									type="radio"
									name="server_type"
									value="beta"
									if serverType == "beta" {
										checked
									}
									class="text-blue-600 focus:ring-blue-500"
									onchange={ handleServerSelection(string(pk.Name)) }
								/>
								<span>{ t(ctx, "settings.provider_config.beta") }</span>
								<span class="text-xs text-gray-400 dark:text-gray-500">beta.musicbrainz.org (same data, 1 req/s)</span>
							</label>
							<label class="flex items-center gap-2 text-sm cursor-pointer">
								<input
									type="radio"
									name="server_type"
									value="custom"
									if serverType == "custom" {
										checked
									}
									class="text-blue-600 focus:ring-blue-500"
									onchange={ handleServerSelection(string(pk.Name)) }
								/>
								<span>{ t(ctx, "settings.provider_config.custom_mirror") }</span>
							</label>
						</div>
					</fieldset>
					<div
						id={ "custom-fields-" + string(pk.Name) }
						class={
							"flex flex-col gap-1.5 ml-6",
							templ.KV("hidden", serverType != "custom"),
						}
					>
						<div class="flex flex-col gap-1.5 sm:flex-row sm:items-end">
							<div class="flex-1">
								<label for={ "custom-base-url-" + string(pk.Name) } class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-0.5">
									Base URL
								</label>
								<input
									id={ "custom-base-url-" + string(pk.Name) }
									type="url"
									name="base_url"
									placeholder="http://192.168.1.100:5000/ws/2"
									if serverType == "custom" && pk.Mirror != nil {
										value={ pk.Mirror.BaseURL }
									}
									if serverType == "custom" {
										required
									}
									autocomplete="off"
									aria-describedby={ "custom-help-" + string(pk.Name) }
									class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
								/>
							</div>
							<div class="w-32">
								<label for={ "custom-rate-limit-" + string(pk.Name) } class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-0.5">
									Rate (req/s)
								</label>
								<input
									id={ "custom-rate-limit-" + string(pk.Name) }
									type="number"
									name="rate_limit"
									placeholder="10"
									if serverType == "custom" && pk.Mirror != nil {
										value={ fmt.Sprintf("%.0f", pk.Mirror.RateLimit) }
									} else {
										value="10"
									}
									min="1"
									max="100"
									step="1"
									class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
								/>
							</div>
						</div>
						<p id={ "custom-help-" + string(pk.Name) } class="text-xs text-gray-400 dark:text-gray-500">
							{ t(ctx, "settings.provider_config.custom_help") }
						</p>
					</div>
					<div class="border-t border-gray-100 dark:border-gray-700 pt-3">
						<div class="flex items-center gap-2">
							<span class="text-xs font-medium text-gray-400 dark:text-gray-500">{ t(ctx, "settings.provider_config.oauth_credentials") }</span>
							<span class="inline-flex items-center rounded-full px-1.5 py-0.5 text-xs font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">
								Coming soon
							</span>
						</div>
						<p class="text-xs text-gray-400 dark:text-gray-500 mt-1 mb-2">
							{ t(ctx, "settings.provider_config.oauth_note") }
						</p>
						<div class="flex flex-col gap-1.5 sm:flex-row sm:items-end opacity-50">
							<div class="flex-1">
								<label class="block text-xs font-medium text-gray-400 dark:text-gray-500 mb-0.5">{ t(ctx, "settings.provider_config.client_id") }</label>
								<input
									type="text"
									disabled
									placeholder={ t(ctx, "settings.provider_config.register_placeholder") }
									class="w-full rounded border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-1.5 text-sm cursor-not-allowed"
									aria-disabled="true"
								/>
							</div>
							<div class="flex-1">
								<label class="block text-xs font-medium text-gray-400 dark:text-gray-500 mb-0.5">{ t(ctx, "settings.provider_config.client_secret") }</label>
								<input
									type="password"
									disabled
									placeholder={ t(ctx, "settings.provider_config.encrypted_placeholder") }
									class="w-full rounded border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-1.5 text-sm cursor-not-allowed"
									aria-disabled="true"
								/>
							</div>
						</div>
					</div>
					<div class="flex gap-2 pt-1">
						<button
							type="button"
							class="text-sm px-3 py-1.5 rounded bg-green-600 text-white hover:bg-green-700 transition-colors"
							onclick={ saveProviderConfig(string(pk.Name)) }
						>
							Save
						</button>
						<button
							type="button"
							class="text-sm px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
							onclick={ toggleProviderConfig(string(pk.Name)) }
						>
							Cancel
						</button>
					</div>
				</form>
			}
			if len(pk.VerbosityOptions) > 0 {
				if pk.RequiresKey || pk.OptionalKey || pk.SupportsBaseURL {
					<div class="border-t border-gray-100 dark:border-gray-700 my-3"></div>
				}
				<div class="flex flex-col gap-3">
					<p class="text-xs font-medium text-gray-600 dark:text-gray-400">{ t(ctx, "settings.provider_config.verbosity_section") }</p>
					<p class="text-xs text-gray-400 dark:text-gray-500">{ t(ctx, "settings.provider_config.verbosity_section.description") }</p>
					for _, fv := range pk.VerbosityOptions {
						{{ currentValue := pk.VerbosityValues[fv.Field] }}
						<div class="flex flex-col gap-1">
							<label
								for={ "verbosity-" + string(pk.Name) + "-" + fv.Field }
								class="text-xs font-medium text-gray-600 dark:text-gray-400"
							>
								{ t(ctx, fv.LabelKey) }
							</label>
							<select
								id={ "verbosity-" + string(pk.Name) + "-" + fv.Field }
								name={ "verbosity_" + fv.Field }
								class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-40"
								hx-put={ "/api/v1/providers/" + string(pk.Name) + "/config" }
								hx-trigger="change"
								hx-target={ "#verbosity-result-" + string(pk.Name) }
								hx-swap="innerHTML"
								hx-include="this"
							>
								for _, opt := range fv.Options {
									<option
										value={ opt.Value }
										if currentValue == opt.Value {
											selected
										}
									>{ t(ctx, opt.LabelKey) }</option>
								}
							</select>
						</div>
					}
					<div id={ "verbosity-result-" + string(pk.Name) } class="text-xs mt-1" role="status" aria-live="polite" aria-atomic="true"></div>
				</div>
			}
		</div>
	}
}

script saveNameSimilarityThreshold() {
	var input = document.getElementById("name_similarity_threshold");
	var raw = input.value.trim();
	var val = Number(raw);
	if (raw === "" || !Number.isInteger(val) || val < 0 || val > 100) {
		var el = document.getElementById("name-similarity-status");
		el.textContent = "Value must be an integer from 0-100";
		el.className = "text-sm text-red-500";
		el.classList.remove("hidden");
		return;
	}
	var basePath = "";
	var meta = document.querySelector('meta[name="htmx-base-path"]');
	if (meta && meta.content) {
		basePath = meta.content;
	}
	var csrfToken = document.cookie.replace(
		/(?:(?:^|.*;\s*)csrf_token\s*=\s*([^;]*).*$)|^.*$/, "$1"
	);
	fetch(basePath + "/api/v1/settings", {
		method: "PUT",
		headers: {
			"Content-Type": "application/json",
			"X-CSRF-Token": csrfToken
		},
		body: JSON.stringify({ "provider.name_similarity_threshold": String(val) })
	}).then(function(r) {
		if (!r.ok) throw new Error("failed");
		var el = document.getElementById("name-similarity-status");
		el.textContent = "Saved";
		el.className = "text-sm text-green-600 dark:text-green-400";
		el.classList.remove("hidden");
		setTimeout(function() { el.classList.add("hidden"); }, 2000);
	}).catch(function() {
		var el = document.getElementById("name-similarity-status");
		el.textContent = "Failed to save";
		el.className = "text-sm text-red-500";
		el.classList.remove("hidden");
	});
}

script toggleProviderConfig(providerName string) {
	const panel = document.getElementById("config-panel-" + providerName);
	if (panel) {
		var closing = !panel.classList.contains("hidden");
		if (closing) {
			var form = document.getElementById("config-form-" + providerName);
			if (form) {
				form.reset();
				var customFields = document.getElementById("custom-fields-" + providerName);
				var selected = form.querySelector('input[name="server_type"]:checked');
				if (customFields && selected) {
					if (selected.value === "custom") {
						customFields.classList.remove("hidden");
					} else {
						customFields.classList.add("hidden");
					}
				}
			}
			var keyForm = document.getElementById("key-form-" + providerName);
			if (keyForm) {
				keyForm.reset();
			}
		}
		panel.classList.toggle("hidden");
		const btn = document.querySelector('[aria-controls="config-panel-' + providerName + '"]');
		if (btn) {
			btn.setAttribute("aria-expanded", !panel.classList.contains("hidden"));
		}
	}
}

script saveProviderConfig(providerName string) {
	var form = document.getElementById("config-form-" + providerName);
	if (!form) return;
	var selected = form.querySelector('input[name="server_type"]:checked');
	if (!selected) return;
	var target = "#provider-card-" + providerName;
	var endpoint = "/api/v1/providers/" + providerName + "/mirror";
	if (selected.value === "official") {
		htmx.ajax("DELETE", endpoint, {target: target, swap: "innerHTML"});
	} else if (selected.value === "beta") {
		htmx.ajax("PUT", endpoint, {
			target: target,
			swap: "innerHTML",
			values: {base_url: "https://beta.musicbrainz.org/ws/2", rate_limit: "1"}
		});
	} else {
		var urlInput = form.querySelector('input[name="base_url"]');
		var rateInput = form.querySelector('input[name="rate_limit"]');
		if (!form.reportValidity()) {
			return;
		}
		htmx.ajax("PUT", endpoint, {
			target: target,
			swap: "innerHTML",
			values: {
				base_url: urlInput ? urlInput.value : "",
				rate_limit: rateInput ? rateInput.value : "10"
			}
		});
	}
}

script handleServerSelection(providerName string) {
	const form = document.getElementById("config-form-" + providerName);
	const customFields = document.getElementById("custom-fields-" + providerName);
	if (!form || !customFields) return;
	const selected = form.querySelector('input[name="server_type"]:checked');
	if (!selected) return;
	if (selected.value === "custom") {
		customFields.classList.remove("hidden");
		const urlInput = customFields.querySelector('input[name="base_url"]');
		if (urlInput) urlInput.required = true;
	} else {
		customFields.classList.add("hidden");
		const urlInput = customFields.querySelector('input[name="base_url"]');
		if (urlInput) urlInput.required = false;
	}
}

templ ProviderTestResult(status string, message string) {
	if status == "ok" {
		<span class="text-green-600 dark:text-green-400">{ t(ctx, "settings.provider_keys.test_success") }</span>
	} else {
		<span class="text-red-600 dark:text-red-400">{ message }</span>
	}
}

// VocabSaveResult renders the inline confirmation shown in the Tag Sources
// form status span after a successful save. handlePutVocab renders this for
// HTMX requests so the user sees a friendly message rather than the raw JSON
// response body.
templ VocabSaveResult() {
	<span class="text-green-600 dark:text-green-400">{ t(ctx, "settings.tag_sources.saved") }</span>
}

// ProviderTestResultWithDot renders the test result plus an OOB swap to update
// the status dot in the provider card without a full page reload.
templ ProviderTestResultWithDot(providerName string, testStatus string, message string, keyStatus string) {
	@ProviderTestResult(testStatus, message)
	@providerStatusDot(providerName, keyStatus, true)
}

// providerStatusDot renders the colored status indicator for a provider card.
// When oob is true, the element includes hx-swap-oob="true" for out-of-band
// HTMX updates.
templ providerStatusDot(name string, status string, oob bool) {
	if oob {
		<div
			id={ "provider-dot-" + name }
			hx-swap-oob="true"
			class={
				"h-2.5 w-2.5 shrink-0 rounded-full",
				templ.KV("bg-green-500", status == "ok" || status == "not_required"),
				templ.KV("bg-yellow-500", status == "untested"),
				templ.KV("bg-red-500", status == "invalid" || status == "error"),
				templ.KV("bg-gray-400 dark:bg-gray-500", status == "unconfigured"),
			}
		></div>
	} else {
		<div
			id={ "provider-dot-" + name }
			class={
				"h-2.5 w-2.5 shrink-0 rounded-full",
				templ.KV("bg-green-500", status == "ok" || status == "not_required"),
				templ.KV("bg-yellow-500", status == "untested"),
				templ.KV("bg-red-500", status == "invalid" || status == "error"),
				templ.KV("bg-gray-400 dark:bg-gray-500", status == "unconfigured"),
			}
		></div>
	}
}

// ProviderTestSaveFailure renders inline error with "Save anyway" when a
// provider key test fails during save. In OOBE mode the fragment preserves
// the card wrapper ID so subsequent swaps can still find the target.
templ ProviderTestSaveFailure(name provider.ProviderName, apiKey string, errMsg string, isOOBE bool) {
	if isOOBE {
		<div id={ "ob-provider-card-" + string(name) } class="rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3">
			@providerTestSaveFailureInner(name, apiKey, errMsg, isOOBE)
		</div>
	} else {
		@providerTestSaveFailureInner(name, apiKey, errMsg, isOOBE)
	}
}

templ providerTestSaveFailureInner(name provider.ProviderName, apiKey string, errMsg string, isOOBE bool) {
	<div class="mt-2 sm:ml-8">
		<div class="rounded-md border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 p-3">
			<p class="text-sm text-red-700 dark:text-red-300 mb-2">
				{ tf(ctx, "settings.provider_keys.test_failed", errMsg) }
			</p>
			<form
				class="flex gap-2"
				hx-put={ "/api/v1/providers/" + string(name) + "/key" }
				if isOOBE {
					hx-target={ "#ob-provider-card-" + string(name) }
					hx-swap="outerHTML"
				} else {
					hx-target={ "#provider-card-" + string(name) }
					hx-swap="innerHTML"
				}
			>
				<input type="hidden" name="api_key" value={ apiKey }/>
				<input type="hidden" name="skip_test" value="true"/>
				<button
					type="submit"
					class="text-sm px-3 py-1.5 rounded bg-amber-600 text-white hover:bg-amber-700 transition-colors"
				>
					Save anyway
				</button>
				<button
					type="button"
					class="text-sm px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
					onclick="window.location.reload()"
				>
					Cancel
				</button>
			</form>
		</div>
	</div>
}

templ PriorityChipRow(pri provider.FieldPriority, keys []provider.ProviderKeyStatus) {
	@priorityChipRowInner(pri, availableProviders(pri, keys))
}

// PriorityChipRows renders the full set of priority chip rows wrapped in the
// container element targeted by the "Restore defaults" button (hx-swap=outerHTML).
templ PriorityChipRows(priorities []provider.FieldPriority, keys []provider.ProviderKeyStatus) {
	<div id="priority-rows" class="space-y-3">
		for _, pri := range priorities {
			@PriorityChipRow(pri, keys)
		}
	</div>
}

templ priorityChipRowInner(pri provider.FieldPriority, available []provider.ProviderName) {
	<div id={ "priority-row-" + pri.Field } class="rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3">
		<div class="flex items-center gap-3 mb-2">
			<span class="text-sm font-medium w-24 shrink-0">{ t(ctx, "field." + pri.Field) }</span>
			<span class="text-xs text-gray-400 dark:text-gray-500">{ t(ctx, "settings.priorities.instructions") }</span>
		</div>
		<div class="flex flex-wrap gap-2" data-sortable-field={ pri.Field }>
			for _, prov := range available {
				if !providerIsDisabled(prov, pri.Disabled) {
					<div
						class={
							"inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-full text-xs font-medium cursor-grab select-none transition-colors border",
							templ.KV("bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border-green-300 dark:border-green-700", !isWebSearchProvider(prov)),
							templ.KV("bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-300 border-dashed border-purple-300 dark:border-purple-700", isWebSearchProvider(prov)),
						}
						data-provider={ string(prov) }
					>
						<span class="drag-handle cursor-grab">
							if isWebSearchProvider(prov) {
								@components.IconBars2("h-3 w-3 text-purple-500 dark:text-purple-400")
							} else {
								@components.IconBars2("h-3 w-3 text-green-500 dark:text-green-400")
							}
						</span>
						<span>{ prov.DisplayName() }</span>
						<button
							type="button"
							class="ml-0.5 text-green-500 dark:text-green-400 hover:text-red-500 dark:hover:text-red-400"
							title={ t(ctx, "settings.priorities.disable_provider") }
							hx-put={ "/api/v1/providers/priorities/" + pri.Field + "/" + string(prov) + "/toggle" }
							hx-target={ "#priority-row-" + pri.Field }
							hx-swap="outerHTML"
						>
							@components.IconCheck("h-3.5 w-3.5")
						</button>
					</div>
				}
			}
		</div>
		for _, prov := range available {
			if providerIsDisabled(prov, pri.Disabled) {
				<div
					class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-full text-xs font-medium select-none transition-colors border bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 border-red-300 dark:border-red-700 opacity-60 mt-2"
					data-disabled-provider={ string(prov) }
				>
					<span>{ prov.DisplayName() }</span>
					<button
						type="button"
						class="ml-0.5 text-red-500 dark:text-red-400 hover:text-green-500 dark:hover:text-green-400"
						title={ t(ctx, "settings.priorities.enable_provider") }
						hx-put={ "/api/v1/providers/priorities/" + pri.Field + "/" + string(prov) + "/toggle" }
						hx-target={ "#priority-row-" + pri.Field }
						hx-swap="outerHTML"
					>
						@components.IconXMark("h-3.5 w-3.5")
					</button>
				</div>
			}
		}
		if len(available) == 0 {
			<p class="text-xs text-gray-400 dark:text-gray-500 italic mt-1">{ t(ctx, "settings.priorities.no_providers") }</p>
		}
	</div>
}

templ WebSearchToggle(ws provider.WebSearchProviderStatus) {
	<div class="flex flex-col gap-2 rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex items-center gap-3">
			<img src={ logoSrc(string(ws.Name)) } alt="" class="h-6 w-6 shrink-0" aria-hidden="true"/>
			<div
				class={
					"h-2.5 w-2.5 shrink-0 rounded-full",
					templ.KV("bg-green-500", ws.Enabled),
					templ.KV("bg-gray-400 dark:bg-gray-500", !ws.Enabled),
				}
			></div>
			<div>
				<div class="font-medium text-sm">{ ws.DisplayName }</div>
				<div class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.provider_keys.no_key_required") }</div>
			</div>
		</div>
		<button
			type="button"
			class={
				"text-sm px-3 py-1.5 rounded border transition-colors",
				templ.KV("border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/40", ws.Enabled),
				templ.KV("border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700", !ws.Enabled),
			}
			hx-put={ "/api/v1/providers/websearch/" + string(ws.Name) + "/toggle" }
			hx-vals={ webSearchToggleJSON(!ws.Enabled) }
			hx-swap="none"
		>
			if ws.Enabled {
				{ t(ctx, "common.enabled") }
			} else {
				{ t(ctx, "common.disabled") }
			}
		</button>
	</div>
}

templ serviceConnectionCard(connType string, displayName string, exampleURL string, conns []connection.Connection) {
	<div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
		<div class="flex items-center gap-3 mb-3">
			if logoSrcSet(connType) != "" {
				<img
					src={ logoSrc(connType) }
					srcset={ logoSrcSet(connType) }
					alt=""
					class="h-8 w-8 shrink-0"
					aria-hidden="true"
				/>
			} else {
				<img
					src={ logoSrc(connType) }
					alt=""
					class="h-8 w-8 shrink-0"
					aria-hidden="true"
				/>
			}
			<div class="flex items-center gap-2">
				<span class="font-medium text-sm">{ displayName }</span>
				<div
					class={
						"h-2 w-2 shrink-0 rounded-full",
						templ.KV("bg-green-500", hasOKConnection(conns)),
						templ.KV("bg-gray-400 dark:bg-gray-500", !hasOKConnection(conns)),
					}
				></div>
			</div>
		</div>
		if len(conns) > 0 {
			<div class="space-y-2 mb-3">
				for _, c := range conns {
					<div id={ "connection-" + c.ID } class="flex flex-col gap-1.5 rounded border border-gray-100 dark:border-gray-700 px-3 py-2 target:ring-2 target:ring-amber-400/60 target:bg-amber-50/40 dark:target:bg-amber-900/10">
						<div class="flex items-center gap-2 min-w-0">
							<div
								class={
									"h-2 w-2 shrink-0 rounded-full",
									templ.KV("bg-green-500", c.Status == "ok"),
									templ.KV("bg-red-500", c.Status == "error"),
									templ.KV("bg-gray-400 dark:bg-gray-500", c.Status != "ok" && c.Status != "error"),
								}
							></div>
							<div class="min-w-0">
								<div class="font-medium text-xs">{ c.Name }</div>
								<div class="text-xs text-gray-500 dark:text-gray-400 truncate">{ c.URL }</div>
							</div>
						</div>
						<div class="flex items-center gap-1.5 shrink-0">
							<button
								type="button"
								class="text-xs p-1 rounded border border-gray-300 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
								onclick={ toggleConnectionFeatures(c.ID) }
								title={ t(ctx, "settings.connections.feature_toggles") }
								aria-label={ t(ctx, "settings.connections.feature_toggles") }
								aria-expanded="false"
								aria-controls={ "features-" + c.ID }
							>
								@components.IconCog6Tooth("h-3.5 w-3.5")
							</button>
							<button
								type="button"
								class="text-xs px-2 py-1 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
								hx-post={ "/api/v1/connections/" + c.ID + "/test" }
								hx-swap="none"
								hx-on::after-request="window.location.reload()"
							>
								Test
							</button>
							if c.Status == "ok" && c.Type != "lidarr" {
								<button
									type="button"
									class="text-xs px-2 py-1 rounded border border-blue-300 dark:border-blue-700 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors"
									hx-get={ "/api/v1/connections/" + c.ID + "/libraries" }
									hx-target={ "#discover-" + c.ID }
									hx-swap="innerHTML"
								>
									Discover Libraries
								</button>
							}
							<button
								type="button"
								class="text-xs px-2 py-1 rounded border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
								onclick={ settingsDeleteConnection(c.ID) }
							>
								Delete
							</button>
						</div>
					</div>
					<div id={ "discover-" + c.ID } class="mt-2"></div>
					<div id={ "features-" + c.ID } class="hidden mt-2 space-y-2">
						<div class="rounded border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 px-3 py-2">
							<div class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-2">{ t(ctx, "settings.connections.sends_heading") }</div>
							<div class="space-y-2">
								if c.Type != "lidarr" {
									@connectionFeatureToggleTT(c.ID, "library_import", t(ctx, "settings.connections.feature_library_import"), c.FeatureLibraryImport, t(ctx, "settings.connections.feature_library_import_tooltip"), "settings-connections-connections-feature-library-import")
								}
								@connectionFeatureToggleTT(c.ID, "nfo_write", t(ctx, "settings.connections.feature_nfo_write"), c.FeatureNFOWrite, t(ctx, "settings.connections.feature_nfo_write_tooltip"), "settings-connections-connections-feature-nfo-write")
								@connectionFeatureToggleTT(c.ID, "image_write", t(ctx, "settings.connections.feature_image_write"), c.FeatureImageWrite, t(ctx, "settings.connections.feature_image_write_tooltip"), "settings-connections-connections-feature-image-write")
							</div>
						</div>
						<div class="rounded border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 px-3 py-2">
							<div class="flex items-center justify-between">
								<div class="min-w-0 pr-3">
									<div class="flex items-center gap-1">
										<span class="text-xs font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.connections.manage_title") }</span>
										@components.ContextHelp("help-managed-"+c.ID, t(ctx, "settings.connections.manage_title"), t(ctx, "settings.connections.manage_title.help"), "settings-connections-connections-manage-title")
									</div>
									<div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
										{ t(ctx, "settings.connections.manage_description") }
									</div>
								</div>
								<button
									id={ "stillwater-managed-" + c.ID }
									type="button"
									class={ ruleToggleBtnClasses(c.FeatureManageServerFiles) }
									role="switch"
									aria-checked={ boolAttr(c.FeatureManageServerFiles) }
									aria-label={ t(ctx, "settings.connections.manage_aria_label") }
									hx-post={ "/api/v1/connections/" + c.ID + "/stillwater-managed" }
									hx-vals={ manageServerFilesPayload(!c.FeatureManageServerFiles) }
									hx-swap="none"
									data-conn-id={ c.ID }
									data-sw-btn-on={ ruleToggleBtnClasses(true) }
									data-sw-btn-off={ ruleToggleBtnClasses(false) }
									data-sw-knob-on={ ruleToggleKnobClasses(true) }
									data-sw-knob-off={ ruleToggleKnobClasses(false) }
									data-sw-error={ t(ctx, "settings.connections.manage_error") }
									hx-on:htmx:after-request={ stillwaterManagedAfterRequest(c.ID) }
								>
									<span class={ ruleToggleKnobClasses(c.FeatureManageServerFiles) }></span>
								</button>
							</div>
						</div>
						<div
							id={ "detected-" + c.ID }
							class="rounded border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 px-3 py-2"
							hx-get={ "/api/v1/connections/" + c.ID + "/conflict-detail" }
							hx-trigger="load"
							hx-swap="innerHTML"
						>
							<div class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.connections.checking_saver_status") }</div>
						</div>
					</div>
				}
			</div>
		} else {
			<p class="text-xs text-gray-500 dark:text-gray-400 italic mb-3">{ t(ctx, "settings.connections.not_configured") }</p>
		}
		<button
			type="button"
			class="text-xs px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
			onclick={ toggleConnectionForm(connType) }
		>
			if len(conns) > 0 {
				Add another
			} else {
				Configure
			}
		</button>
		<div id={ "conn-form-" + connType } class="hidden mt-3">
			<form
				class="space-y-2"
				hx-post="/api/v1/connections"
				hx-target={ "#conn-result-" + connType }
				hx-swap="innerHTML"
			>
				<input type="hidden" name="type" value={ connType }/>
				<input
					name="name"
					placeholder={ displayName + " server" }
					required
					class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
				/>
				<div>
					<div class="flex items-center gap-1 mb-1">
						<label for={ "conn-url-" + connType } class="text-xs font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.connections.base_url") }</label>
						@components.ContextHelp("help-conn-url-"+connType, t(ctx, "settings.connections.base_url"), t(ctx, "settings.connections.base_url.help"), "settings-connections-connections-base-url")
					</div>
					<input
						id={ "conn-url-" + connType }
						name="url"
						type="url"
						placeholder={ "URL (e.g. " + exampleURL + ")" }
						required
						class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
					/>
				</div>
				<div>
					<div class="flex items-center gap-1 mb-1">
						<label for={ "conn-api-key-" + connType } class="text-xs font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.connections.api_key") }</label>
						@components.ContextHelp("help-conn-api-key-"+connType, t(ctx, "settings.connections.api_key"), t(ctx, "settings.connections.api_key.help"), "settings-connections-connections-api-key")
					</div>
					<input
						id={ "conn-api-key-" + connType }
						name="api_key"
						type="text"
						placeholder={ t(ctx, "settings.connections.api_key_placeholder") }
						required
						autocomplete="off"
						data-1p-ignore
						data-lpignore="true"
						class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
					/>
				</div>
				<div class="flex gap-2">
					<button type="submit" class="text-xs px-3 py-1.5 rounded bg-green-600 text-white hover:bg-green-700 transition-colors">{ t(ctx, "actions.save") }</button>
					<button type="button" class="text-xs px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" onclick={ toggleConnectionForm(connType) }>{ t(ctx, "actions.cancel") }</button>
				</div>
			</form>
			<div id={ "conn-result-" + connType } class="mt-2"></div>
		</div>
	</div>
}

// ConnectionTestSaveFailure renders inline error with "Save anyway" when a
// connection test fails during save. The isOOBE flag controls targeting.
templ ConnectionTestSaveFailure(connType string, name string, url string, apiKey string, errMsg string, isOOBE bool) {
	<div class="rounded-md border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 p-3">
		<p class="text-sm text-red-700 dark:text-red-300 mb-2">
			{ tf(ctx, "settings.provider_keys.test_failed", errMsg) }
		</p>
		<form
			class="flex gap-2"
			hx-post="/api/v1/connections"
			if isOOBE {
				hx-target={ "#ob-conn-result-" + connType }
			} else {
				hx-target={ "#conn-result-" + connType }
			}
			hx-swap="innerHTML"
		>
			<input type="hidden" name="type" value={ connType }/>
			<input type="hidden" name="name" value={ name }/>
			<input type="hidden" name="url" value={ url }/>
			<input type="hidden" name="api_key" value={ apiKey }/>
			<input type="hidden" name="skip_test" value="true"/>
			<button
				type="submit"
				class="text-sm px-3 py-1.5 rounded bg-amber-600 text-white hover:bg-amber-700 transition-colors"
			>
				Save anyway
			</button>
			<button
				type="button"
				class="text-sm px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
				onclick="window.location.reload()"
			>
				Cancel
			</button>
		</form>
	</div>
}

script toggleConnectionForm(connType string) {
	var form = document.getElementById("conn-form-" + connType);
	if (form) {
		form.classList.toggle("hidden");
	}
}

// stillwaterManagedAfterRequest runs after the "Let Stillwater manage"
// toggle POSTs. Because the button uses hx-swap="none", its
// aria-checked, Tailwind class list, and hx-vals payload are otherwise
// frozen at render-time. Without syncing them from the server response,
// a second click would re-send the same enabled value and cause
// applyStillwaterManaged to overwrite the peer-config snapshot with
// the already-disabled state, losing restore-ability.
//
// On success it syncs the button from the handler's JSON response
// (the feature_manage_server_files field is authoritative), then
// re-fetches the per-connection conflict-detail fragment and fires
// sse:conflict.changed for the top-of-page banner. On failure it
// writes an inline error into the detail target so the user notices
// without a page reload.
//
// Button class strings are read from data-sw-{btn,knob}-{on,off}
// attributes populated at render time by the ruleToggle*Classes
// helpers, so this script never hardcodes Tailwind utility names and
// stays in sync if those helpers change.

script stillwaterManagedAfterRequest(connID string) {
	var btn = document.getElementById("stillwater-managed-" + connID);
	if (event.detail.successful) {
		try {
			var resp = JSON.parse(event.detail.xhr.responseText || "{}");
			if (btn && typeof resp.feature_manage_server_files === "boolean") {
				var enabled = resp.feature_manage_server_files;
				var knob = btn.querySelector("span");
				btn.setAttribute("aria-checked", String(enabled));
				btn.setAttribute("class", enabled ? btn.dataset.swBtnOn : btn.dataset.swBtnOff);
				btn.setAttribute("hx-vals", JSON.stringify({ enabled: !enabled }));
				if (knob) {
					knob.setAttribute("class", enabled ? btn.dataset.swKnobOn : btn.dataset.swKnobOff);
				}
			}
		} catch (_) {
			// Non-JSON response; leave button state and rely on a subsequent
			// page load to re-sync. The fetch below will still refresh the
			// detail fragment so the user sees the new server-side state.
		}
		htmx.ajax("GET", "/api/v1/connections/" + connID + "/conflict-detail",
			{ target: "#detected-" + connID, swap: "innerHTML" });
		document.body.dispatchEvent(new CustomEvent("sse:conflict.changed"));
	} else {
		var el = document.getElementById("detected-" + connID);
		if (el) {
			// Prefer the render-time translated copy pinned on the button's
			// data-sw-error attribute. The English literal is retained as a
			// last-resort fallback for the pathological case where the
			// button has been removed from the DOM before the request
			// settles (e.g. the features panel was torn down mid-flight).
			el.textContent = (btn && btn.dataset.swError) || "Could not update this server-managed setting. Try again or reload the page.";
		}
	}
}

script toggleConnectionFeatures(connID string) {
	var panel = document.getElementById("features-" + connID);
	if (panel) {
		panel.classList.toggle("hidden");
		var btn = document.querySelector('[aria-controls="features-' + connID + '"]');
		if (btn) {
			btn.setAttribute('aria-expanded', String(!panel.classList.contains('hidden')));
		}
	}
}

// connectionFeatureToggleTT renders a labeled feature toggle for the
// per-connection settings card with a visible "?" help icon adjacent to
// the label. The help icon expands a popover with the precondition
// semantics (e.g. "writes are still gated if the server has NFO saving
// on") and a Read more link to the docs site when docAnchor is set.
//
// An sr-only <span> carrying the same tooltip text remains as the
// aria-describedby target on the toggle button itself; that gives screen
// readers the description on toggle focus without forcing them to
// navigate to the help icon separately.
templ connectionFeatureToggleTT(connID string, feature string, label string, enabled bool, tooltip string, docAnchor string) {
	{{ labelID := connID + "-" + feature + "-label" }}
	{{ ttID := connID + "-" + feature + "-tt" }}
	{{ helpID := connID + "-" + feature + "-help" }}
	<div class="flex items-center justify-between gap-2">
		<span class="inline-flex items-center gap-1 min-w-0">
			<span id={ labelID } class="text-xs text-gray-700 dark:text-gray-300">{ label }</span>
			@components.ContextHelp(helpID, label, tooltip, docAnchor)
		</span>
		<button
			type="button"
			class={ ruleToggleBtnClasses(enabled) }
			role="switch"
			aria-checked={ boolAttr(enabled) }
			aria-labelledby={ labelID }
			aria-describedby={ ttID }
			data-conn-id={ connID }
			data-feature={ feature }
			onclick="toggleConnectionFeature(this)"
		>
			<span class={ ruleToggleKnobClasses(enabled) }></span>
		</button>
		<span id={ ttID } class="sr-only">{ tooltip }</span>
	</div>
}

script settingsDeleteConnection(id string) {
	settingsDeleteConnection_click(id);
}

templ webhookCard(wh webhook.Webhook) {
	<div class="flex flex-col gap-2 rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex items-center gap-3 min-w-0">
			<div
				class={
					"h-2.5 w-2.5 shrink-0 rounded-full",
					templ.KV("bg-green-500", wh.Enabled),
					templ.KV("bg-gray-400 dark:bg-gray-500", !wh.Enabled),
				}
			></div>
			<div class="min-w-0">
				<div class="font-medium text-sm flex items-center gap-2">
					{ wh.Name }
					<span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2 py-0.5 text-xs font-medium text-gray-600 dark:text-gray-300">
						{ wh.Type }
					</span>
				</div>
				<div class="text-xs text-gray-500 dark:text-gray-400">
					if len(wh.Events) > 0 {
						{ joinNames(wh.Events) }
					} else {
						All events
					}
				</div>
			</div>
		</div>
		<div class="flex items-center gap-2 shrink-0">
			<button
				type="button"
				class="text-sm px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors"
				hx-post={ "/api/v1/webhooks/" + wh.ID + "/test" }
				hx-swap="none"
			>
				Test
			</button>
			<button
				type="button"
				class="text-sm px-3 py-1.5 rounded border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
				hx-delete={ "/api/v1/webhooks/" + wh.ID }
				hx-confirm={ t(ctx, "settings.webhooks.confirm_delete") }
				hx-swap="none"
				hx-on::after-request="window.location.reload()"
			>
				Delete
			</button>
		</div>
	</div>
}

// profileNamingRow renders a single image type row in the active profile details.
// For builtin profiles it shows read-only text; for custom profiles it shows
// editable chips with add/remove controls.
templ profileNamingRow(label, imageType string, names []string, readOnly bool) {
	<div>
		<span class="font-medium text-gray-500 dark:text-gray-400">{ label }</span>
		if readOnly {
			<p class="mt-1">{ joinNames(names) }</p>
		} else {
			<div class="mt-1 flex flex-wrap items-center gap-1.5" data-naming-type={ imageType }>
				for _, name := range names {
					<span class="inline-flex items-center gap-1 rounded-full bg-gray-100 dark:bg-gray-700 px-2.5 py-0.5 text-xs font-medium text-gray-700 dark:text-gray-300" data-naming-chip={ name }>
						{ name }
						<button
							type="button"
							class="ml-0.5 text-gray-400 hover:text-red-500 focus:outline-none"
							aria-label={ "Remove " + name }
							onclick="this.closest('[data-naming-chip]').remove()"
						>
							&times;
						</button>
					</span>
				}
				<button
					type="button"
					class="inline-flex items-center rounded-full border border-dashed border-gray-300 dark:border-gray-600 px-2 py-0.5 text-xs text-gray-500 hover:border-gray-400 hover:text-gray-700 dark:hover:text-gray-300 focus:outline-none"
					onclick={ templ.ComponentScript{Call: "addNamingChip(this, '" + imageType + "')"} }
				>
					+ Add
				</button>
			</div>
		}
	</div>
}

templ profileCard(p platform.Profile) {
	<div
		class={
			"relative rounded-lg border-2 p-4 cursor-pointer transition-colors",
			templ.KV("border-blue-500 bg-blue-50 dark:bg-blue-900/20", p.IsActive),
			templ.KV("border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600", !p.IsActive),
		}
		hx-post={ "/api/v1/platforms/" + p.ID + "/activate" }
		hx-swap="none"
		hx-on::after-request="window.location.reload()"
	>
		<div class="flex items-center justify-between">
			<div class="flex items-center gap-2">
				if logoSrcSet(p.ID) != "" {
					<img
						src={ logoSrc(p.ID) }
						srcset={ logoSrcSet(p.ID) }
						alt=""
						class="h-6 w-6 shrink-0"
						aria-hidden="true"
					/>
				} else {
					<img
						src={ logoSrc(p.ID) }
						alt=""
						class="h-6 w-6 shrink-0"
						aria-hidden="true"
					/>
				}
				<h3 class="font-semibold text-sm">{ p.Name }</h3>
			</div>
			if p.IsActive {
				<span class="inline-flex items-center rounded-full bg-blue-100 dark:bg-blue-800 px-2 py-0.5 text-xs font-medium text-blue-700 dark:text-blue-300">
					Active
				</span>
			}
		</div>
		<div class="mt-2 text-xs text-gray-500 dark:text-gray-400 space-y-1">
			<div>
				NFO:
				if p.NFOEnabled {
					<span class="text-green-600 dark:text-green-400">{ t(ctx, "common.enabled") }</span>
				} else {
					<span class="text-gray-400 dark:text-gray-500">{ t(ctx, "common.disabled") }</span>
				}
			</div>
			<div>{ img.ImageTermFor("thumb", p.Name) }: { joinNames(p.ImageNaming.Thumb) }</div>
			<div>{ img.ImageTermFor("fanart", p.Name) }: { joinNames(p.ImageNaming.Fanart) }</div>
		</div>
	</div>
}

templ ruleRow(rl rule.Rule, hasLocalLibrary, showSeverityHelp, showFsHelp bool) {
	// A filesystem-dependent rule is unavailable when no local library exists.
	// In that state, all controls are disabled and a tooltip explains why.
	{{ fsUnavailable := rl.FilesystemDependent && !hasLocalLibrary }}
	<div
		class={
			"py-4 space-y-2",
			templ.KV("opacity-50", fsUnavailable),
		}
		if fsUnavailable {
			title={ t(ctx, "settings.rules.requires_local_tooltip") }
		}
	>
		<div class="flex items-center justify-between gap-4">
			<div class="flex-1 min-w-0">
				<div class="flex items-center gap-2">
					<span class="font-medium text-sm">{ rl.Name }</span>
					<a
						href={ templ.SafeURL(ruleCatalogueURL(rl.Name)) }
						target="_blank"
						rel="noopener"
						class="text-xs text-gray-400 hover:text-blue-600 dark:text-gray-500 dark:hover:text-blue-400 transition-colors"
						aria-label={ t(ctx, "settings.rules.catalogue_link_aria") + ": " + rl.Name }
						title={ t(ctx, "settings.rules.catalogue_link_title") }
					>
						<svg class="h-3.5 w-3.5 inline-block" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
						</svg>
					</a>
					@severityBadge(rl.Config.Severity)
					if showSeverityHelp {
						@components.ContextHelp("help-rules-severity-badge", t(ctx, "common.severity"), t(ctx, "settings.rules.help_severity_badge"), "core-concepts/rules#what-rules-check")
					}
					if fsUnavailable {
						<span
							class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400"
							title={ t(ctx, "settings.rules.requires_local_tooltip_short") }
						>
							{ t(ctx, "settings.rules.requires_local") }
						</span>
						if showFsHelp {
							@components.ContextHelp("help-rules-requires-local-chip", t(ctx, "settings.rules.requires_local"), t(ctx, "settings.rules.help_requires_local_chip"), "core-concepts/rules#filesystem-dependent-rules")
						}
					}
				</div>
				<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{ rl.Description }</p>
			</div>
			<div class="flex items-center gap-3 shrink-0">
				<button
					type="button"
					class="text-xs px-2 py-1 rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
					data-rule-id={ rl.ID }
					data-run-btn
					onclick="runRule(this)"
					disabled?={ !rl.Enabled || fsUnavailable }
					aria-label={ "Run " + rl.Name + " now" }
					title={ t(ctx, "actions.run") }
				>
					Run
				</button>
				<div class="flex items-center gap-1">
					{{ autoModeLabelID := "rule-auto-mode-label-" + rl.ID }}
					<span id={ autoModeLabelID } class="sr-only">{ tf(ctx, "settings.rules.automation_mode_for", rl.Name) }</span>
					<select
						class="text-xs rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500"
						aria-labelledby={ autoModeLabelID }
						data-rule-id={ rl.ID }
						onchange="patchRule(this.dataset.ruleId, {automation_mode: this.value})"
						disabled?={ !rl.Enabled || fsUnavailable }
					>
						<option value="auto" selected?={ rl.AutomationMode == "auto" || rl.AutomationMode == "" }>{ t(ctx, "settings.rules.auto_fix") }</option>
						<option value="manual" selected?={ rl.AutomationMode == "manual" }>{ t(ctx, "settings.rules.manual") }</option>
					</select>
					@components.ContextHelp("help-rule-auto-fix-"+rl.ID, t(ctx, "settings.rules.auto_fix"), t(ctx, "settings.rules.auto_fix.help"), "settings-rules-rules-auto-fix")
				</div>
				<button
					type="button"
					class={ ruleToggleBtnClasses(rl.Enabled) }
					role="switch"
					aria-checked={ boolAttr(rl.Enabled) }
					data-rule-id={ rl.ID }
					onclick="toggleRuleEnabled(this)"
					disabled?={ fsUnavailable }
					aria-label={ "Enable " + rl.Name }
					if fsUnavailable {
						title={ t(ctx, "settings.rules.cannot_enable_tooltip") }
					}
				>
					<span class={ ruleToggleKnobClasses(rl.Enabled) }></span>
				</button>
			</div>
		</div>
		if ruleHasConfig(rl.ID) {
			<div>
				<button
					type="button"
					class="text-xs text-blue-600 dark:text-blue-400 hover:underline"
					onclick={ toggleRuleConfig(rl.ID) }
					aria-expanded="false"
					aria-controls={ "rule-cfg-" + rl.ID }
					aria-label={ "Configure " + rl.Name }
					disabled?={ fsUnavailable }
				>{ t(ctx, "actions.configure") }</button>
				<div id={ "rule-cfg-" + rl.ID } class="hidden mt-2">
					@ruleConfigForm(rl)
				</div>
			</div>
		}
	</div>
}

templ severityBadge(severity string) {
	{{ cls := severityBadgeClasses(severity) }}
	<span class={ "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium", cls }>
		{ severity }
	</span>
}

templ ruleConfigForm(rl rule.Rule) {
	<form
		class="grid grid-cols-2 gap-3 sm:grid-cols-3 items-end"
		data-rule-id={ rl.ID }
		onsubmit="handleRuleConfigSubmit(event)"
	>
		if rl.ID == "thumb_min_res" || rl.ID == "fanart_min_res" || rl.ID == "banner_min_res" || rl.ID == "logo_min_res" {
			<div class="col-span-full">
				<label class="block">
					<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.resolution_preset") }</span>
					<select
						class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
						onchange="applyResPreset(this)"
					>
						@resolutionPresetOptions(rl)
					</select>
				</label>
			</div>
		}
		if rl.ID == "thumb_min_res" || rl.ID == "fanart_min_res" || rl.ID == "banner_min_res" {
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.min_width") }</span>
				<input
					type="number"
					name="min_width"
					min="1"
					value={ intOrDefault(rl.Config.MinWidth, defaultMinWidth(rl.ID)) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.min_height") }</span>
				<input
					type="number"
					name="min_height"
					min="1"
					value={ intOrDefault(rl.Config.MinHeight, defaultMinHeight(rl.ID)) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		if rl.ID == "logo_min_res" {
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.min_width") }</span>
				<input
					type="number"
					name="min_width"
					min="1"
					value={ intOrDefault(rl.Config.MinWidth, 400) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		if rl.ID == "thumb_square" || rl.ID == "fanart_aspect" {
			<div class="col-span-full">
				<label class="block">
					<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.aspect_preset") }</span>
					<select
						class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
						onchange="applyAspectPreset(this)"
					>
						@aspectPresetOptions(rl)
					</select>
				</label>
			</div>
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.aspect_ratio") }</span>
				<input
					type="number"
					name="aspect_ratio"
					step="0.001"
					min="0.1"
					value={ floatOrDefault(rl.Config.AspectRatio, defaultAspectRatio(rl.ID)) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.tolerance") }</span>
				<input
					type="number"
					name="tolerance"
					step="0.01"
					min="0"
					max="0.5"
					value={ floatOrDefault(rl.Config.Tolerance, 0.1) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		if rl.ID == "bio_exists" {
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.min_length") }</span>
				<input
					type="number"
					name="min_length"
					min="1"
					value={ intOrDefault(rl.Config.MinLength, 10) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		if rl.ID == "logo_padding" {
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.threshold_percent") }</span>
				<input
					type="number"
					name="threshold_percent"
					step="0.5"
					min="1"
					max="50"
					value={ floatOrDefault(rl.Config.ThresholdPercent, 15) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
			<label class="block">
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.trim_margin") }</span>
				<input
					type="number"
					name="trim_margin"
					min="0"
					max="20"
					value={ strconv.Itoa(rl.Config.TrimMargin) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		if rl.ID == "discography_populated" {
			<label class="block" title={ t(ctx, "rules.discography.coverage_threshold.help") }>
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "rules.discography.coverage_threshold") }</span>
				<input
					type="number"
					name="coverage_threshold"
					step="5"
					min="1"
					max="100"
					value={ floatOrDefault(rl.Config.CoverageThreshold, 50) }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
			<label class="block col-span-full" title={ t(ctx, "rules.discography.release_types.help") }>
				<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "rules.discography.release_types") }</span>
				<input
					type="text"
					name="release_types"
					placeholder="Album,EP"
					value={ stringOrDefault(rl.Config.ReleaseTypes, "Album,EP") }
					class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
				/>
			</label>
		}
		<label class="block">
			<span class="text-xs text-gray-600 dark:text-gray-400">{ t(ctx, "settings.rules.severity_label") }</span>
			<select
				name="severity"
				class="mt-0.5 w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
			>
				<option value="error" selected?={ rl.Config.Severity == "error" }>{ t(ctx, "common.error") }</option>
				<option value="warning" selected?={ rl.Config.Severity == "warning" }>{ t(ctx, "common.warning") }</option>
				<option value="info" selected?={ rl.Config.Severity == "info" }>{ t(ctx, "common.info") }</option>
			</select>
		</label>
		<div class="flex gap-2 col-span-full">
			<button
				type="submit"
				class="text-xs px-3 py-1.5 rounded bg-green-600 text-white hover:bg-green-700 transition-colors"
			>
				Save
			</button>
			<button
				type="button"
				class="text-xs px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
				onclick={ toggleRuleConfig(rl.ID) }
			>
				Cancel
			</button>
		</div>
	</form>
}

templ resolutionPresetOptions(rl rule.Rule) {
	if rl.ID == "fanart_min_res" {
		{{ key := fanartResPresetKey(rl.Config.MinWidth, rl.Config.MinHeight) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="1280,720" selected?={ key == "720p" }>{ t(ctx, "settings.preset.fanart_720p") }</option>
		<option value="1920,1080" selected?={ key == "1080p" }>{ t(ctx, "settings.preset.fanart_1080p") }</option>
		<option value="2560,1440" selected?={ key == "1440p" }>{ t(ctx, "settings.preset.fanart_1440p") }</option>
		<option value="3840,2160" selected?={ key == "4k" }>{ t(ctx, "settings.preset.fanart_4k") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
	if rl.ID == "thumb_min_res" {
		{{ key := thumbResPresetKey(rl.Config.MinWidth, rl.Config.MinHeight) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="500,500" selected?={ key == "std" }>{ t(ctx, "settings.preset.thumb_standard") }</option>
		<option value="1000,1000" selected?={ key == "hd" }>{ t(ctx, "settings.preset.thumb_hd") }</option>
		<option value="2000,2000" selected?={ key == "ultra" }>{ t(ctx, "settings.preset.thumb_ultra") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
	if rl.ID == "banner_min_res" {
		{{ key := bannerResPresetKey(rl.Config.MinWidth, rl.Config.MinHeight) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="758,140" selected?={ key == "kodi" }>{ t(ctx, "settings.preset.banner_kodi") }</option>
		<option value="1000,185" selected?={ key == "wide" }>{ t(ctx, "settings.preset.banner_wide") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
	if rl.ID == "logo_min_res" {
		{{ key := logoWidthPresetKey(rl.Config.MinWidth) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="400" selected?={ key == "std" }>{ t(ctx, "settings.preset.logo_standard") }</option>
		<option value="800" selected?={ key == "large" }>{ t(ctx, "settings.preset.logo_large") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
}

templ aspectPresetOptions(rl rule.Rule) {
	if rl.ID == "fanart_aspect" {
		{{ key := fanartAspectPresetKey(rl.Config.AspectRatio) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="1.7778" selected?={ key == "16:9" }>{ t(ctx, "settings.preset.aspect_16_9") }</option>
		<option value="1.6" selected?={ key == "16:10" }>{ t(ctx, "settings.preset.aspect_16_10") }</option>
		<option value="2.0" selected?={ key == "2:1" }>{ t(ctx, "settings.preset.aspect_2_1") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
	if rl.ID == "thumb_square" {
		{{ key := thumbAspectPresetKey(rl.Config.AspectRatio) }}
		<option value="">{ t(ctx, "settings.rules.select_preset") }</option>
		<option value="1.0" selected?={ key == "1:1" }>{ t(ctx, "settings.preset.aspect_1_1") }</option>
		<option value="custom" selected?={ key == "custom" }>{ t(ctx, "common.custom") }</option>
	}
}

script toggleRuleConfig(ruleID string) {
	var el = document.getElementById("rule-cfg-" + ruleID);
	if (el) {
		el.classList.toggle("hidden");
		var btn = document.querySelector('[aria-controls="rule-cfg-' + ruleID + '"]');
		if (btn) {
			btn.setAttribute("aria-expanded", String(!el.classList.contains("hidden")));
		}
	}
}

// updaterIntervalOption renders one <option> for the check-interval select.
// The selected attribute is set when value matches the currently-stored
// CheckIntervalHours so the dropdown reflects persisted state on page load.
templ updaterIntervalOption(value, current int, label string) {
	if value == current {
		<option value={ strconv.Itoa(value) } selected>{ label }</option>
	} else {
		<option value={ strconv.Itoa(value) }>{ label }</option>
	}
}

// isKnownInterval reports whether v matches one of the enum values rendered
// by the check-interval <select>. When the persisted CheckIntervalHours is
// outside this set (e.g., set via direct API call to a custom cadence), the
// template renders a sentinel "(custom)" option so a Save without explicit
// interval change does not silently overwrite the persisted value with the
// browser's first-option fallback.
func isKnownInterval(v int) bool {
	switch v {
	case 1, 6, 12, 24, 168:
		return true
	default:
		return false
	}
}

// settingsUpdatesTab renders the Updates tab content.
templ settingsUpdatesTab(data UpdatesTabData, basePath string) {
	// Hidden element carrying translated labels for the updater JS.
	// The JS reads these via dataset.* rather than embedding raw strings.
	<div
		id="updates-i18n"
		class="hidden"
		data-checking={ t(ctx, "settings.updates.state_checking") }
		data-downloading={ t(ctx, "settings.updates.state_downloading") }
		data-applying={ t(ctx, "settings.updates.state_applying") }
		data-error={ t(ctx, "settings.updates.state_error") }
		data-saved={ t(ctx, "settings.updates.state_saved") }
		data-update-available={ t(ctx, "settings.updates.update_available") }
		data-up-to-date={ t(ctx, "settings.updates.up_to_date") }
		data-release-notes={ t(ctx, "settings.updates.release_notes") }
		data-not-checked={ t(ctx, "settings.updates.not_checked") }
		data-restart-required-title={ t(ctx, "settings.updates.restart_required_title") }
		data-restart-required-body={ t(ctx, "settings.updates.restart_required_body") }
		data-restart-required-native-instruction={ t(ctx, "settings.updates.restart_required_native_instruction") }
		data-load-failed-save-blocked={ t(ctx, "settings.updates.load_failed_save_blocked") }
	></div>
	<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
		<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
			<div class="flex items-center gap-2">
				<h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{ t(ctx, "settings.updates.title") }</h2>
				@components.ContextHelp("help-updates", t(ctx, "settings.updates.title"), t(ctx, "settings.updates.help"), "settings-updates-updates")
			</div>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{ t(ctx, "settings.updates.description") }</p>
		</div>
		<div class="px-6 py-4 space-y-5">
			<!-- Version info row -->
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				<div>
					<div class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.updates.current_version") }</div>
					<div class="mt-1 text-sm font-mono text-gray-900 dark:text-gray-100">{ data.CurrentVersion }</div>
				</div>
				<div>
					<div class="text-sm font-medium text-gray-700 dark:text-gray-300">{ t(ctx, "settings.updates.latest_version") }</div>
					<div
						id="updates-latest-version"
						class="mt-1 text-sm font-mono text-gray-900 dark:text-gray-100"
					>
						if data.LatestVersion != "" {
							if data.UpdateAvailable {
								<span class="text-green-600 dark:text-green-400 font-semibold">{ data.LatestVersion }</span>
								<span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">
									{ t(ctx, "settings.updates.update_available") }
								</span>
							} else {
								{ data.LatestVersion }
								<span class="ml-2 text-gray-400 dark:text-gray-500">{ t(ctx, "settings.updates.up_to_date") }</span>
							}
						} else {
							<span class="text-gray-400 dark:text-gray-500 italic">{ t(ctx, "settings.updates.not_checked") }</span>
						}
					</div>
				</div>
			</div>
			<div
				id="updates-last-checked-row"
				class={
					"text-xs text-gray-400 dark:text-gray-500",
					templ.KV("hidden", data.LastChecked == ""),
				}
			>
				{ t(ctx, "settings.updates.last_checked") }: <span id="updates-last-checked">{ data.LastChecked }</span>
			</div>
			<!-- Release notes link: shown on initial render when the server already
			     knows about a newer version, and hydrated by fetchAndPopulateUpdateStatus
			     when /status returns a non-empty release_url. -->
			<div
				id="updates-release-link-row"
				class={
					"text-xs",
					templ.KV("hidden", data.ReleaseURL == ""),
				}
			>
				<a
					id="updates-release-link"
					href={ templ.SafeURL(data.ReleaseURL) }
					target="_blank"
					rel="noopener noreferrer"
					class="text-blue-500 hover:underline"
				>
					{ t(ctx, "settings.updates.release_notes") }
				</a>
			</div>
			<!-- Docker notice -->
			if data.IsDocker {
				<div class="rounded-md bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 px-4 py-3">
					<p class="text-sm text-blue-700 dark:text-blue-300">{ t(ctx, "settings.updates.docker_notice") }</p>
				</div>
			}
			<!-- Status display -->
			<div
				id="updates-status-row"
				class="hidden rounded-md bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 px-4 py-3"
				role="status"
				aria-live="polite"
				aria-atomic="true"
			>
				<div class="flex items-center gap-2">
					<span id="updates-status-spinner" class="hidden animate-spin inline-block w-4 h-4 border-2 border-gray-400 border-t-blue-500 rounded-full" aria-hidden="true"></span>
					<span id="updates-status-text" class="text-sm text-gray-700 dark:text-gray-300"></span>
				</div>
				<div id="updates-error-row" class="hidden mt-1 text-sm text-red-600 dark:text-red-400" role="alert"></div>
			</div>
			<!-- Restart-required banner: shown after a successful Apply has staged
			     the new binary. Always rendered in the DOM so the JS hydrate path
			     can flip its visibility without templating; on first server-render
			     after Apply, .hidden is dropped here so users who navigate back to
			     the tab still see the banner without waiting for the /status
			     fetch. role=status + aria-live=polite is intentionally weaker
			     than role=alert: the message is informational ("here is what
			     happened"), not an error or interruption. -->
			<div
				id="updates-restart-required-row"
				class={
					"rounded-md border px-4 py-3 bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-700",
					templ.KV("hidden", !data.RestartRequired),
				}
				role="status"
				aria-live="polite"
				aria-atomic="true"
			>
				<div class="flex items-start gap-3">
					<svg class="mt-0.5 h-5 w-5 text-amber-600 dark:text-amber-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<div class="flex-1 text-sm">
						<div class="font-semibold text-amber-800 dark:text-amber-200">
							{ t(ctx, "settings.updates.restart_required_title") }
							if data.PendingVersion != "" {
								<span class="ml-1 font-mono font-normal" id="updates-restart-pending-version">{ data.PendingVersion }</span>
							} else {
								<span class="ml-1 font-mono font-normal hidden" id="updates-restart-pending-version"></span>
							}
						</div>
						<div class="mt-1 text-amber-700 dark:text-amber-300" id="updates-restart-required-body">
							{ t(ctx, "settings.updates.restart_required_body") }
						</div>
						// Render an environment-specific restart instruction so
						// Docker users see "recreate the container" while native
						// users see "stop and re-run". Both branches share the
						// same DOM id so any JS or CSS selector continues to
						// match either path.
						if data.IsDocker {
							<div class="mt-1 text-amber-700 dark:text-amber-300" id="updates-restart-required-instruction">
								{ t(ctx, "settings.updates.restart_required_docker_instruction") }
							</div>
						} else {
							<div class="mt-1 text-amber-700 dark:text-amber-300" id="updates-restart-required-instruction">
								{ t(ctx, "settings.updates.restart_required_native_instruction") }
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- Channel, scheduler, and apply-mode settings -->
	<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
		<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
			<div class="flex items-center gap-2">
				<h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{ t(ctx, "settings.updates.config.label") }</h2>
				@components.ContextHelp("help-updates-config", t(ctx, "settings.updates.config.label"), t(ctx, "settings.updates.config.help"), "settings-updates-updates-config")
			</div>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{ t(ctx, "settings.updates.config.description") }</p>
		</div>
		<div class="px-6 py-4 space-y-5">
			<!-- Load-failed banner: shown when the server-side render could
			     not read the persisted updater config. Without this, the
			     controls below show the in-code defaults, which look
			     indistinguishable from a healthy "stable + auto-check off"
			     install. The dismiss button is cosmetic; the underlying
			     LoadFailed condition still gates auto-save in JS so a
			     dismissed banner cannot lead to a destructive write. -->
			if data.LoadFailed {
				<div
					id="updates-load-failed-row"
					data-load-failed="true"
					class="rounded-md border px-4 py-3 bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-700"
					role="alert"
					aria-live="assertive"
					aria-atomic="true"
				>
					<div class="flex items-start gap-3">
						<svg class="mt-0.5 h-5 w-5 text-red-600 dark:text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
						</svg>
						<div class="flex-1 text-sm">
							<div class="font-semibold text-red-800 dark:text-red-200">
								{ t(ctx, "settings.updates.load_failed_title") }
							</div>
							<div class="mt-1 text-red-700 dark:text-red-300">
								{ t(ctx, "settings.updates.load_failed_body") }
							</div>
						</div>
						<button
							type="button"
							onclick="document.getElementById('updates-load-failed-row').classList.add('hidden')"
							class="flex-shrink-0 rounded-md p-1 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 focus:outline-none focus:ring-2 focus:ring-red-500"
							aria-label={ t(ctx, "common.dismiss") }
						>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>
				</div>
			}
			<!-- Top-level Enabled toggle -->
			<div class="flex items-center justify-between gap-4">
				@components.Toggle(
					"updates-enabled",
					"updates_enabled",
					data.Enabled,
					t(ctx, "settings.updates.enabled.label"),
					t(ctx, "settings.updates.enabled.description"),
				)
				@components.ContextHelp("help-updates-enabled", t(ctx, "settings.updates.enabled.label"), t(ctx, "settings.updates.enabled.help"), "settings-updates-updates-enabled")
			</div>
			<!-- Channel selector -->
			<div class="flex items-center justify-between gap-4">
				<div>
					<div class="flex items-center gap-1">
						<div class="text-sm font-medium text-gray-900 dark:text-gray-100">{ t(ctx, "settings.updates.channel.label") }</div>
						@components.ContextHelp("help-updates-channel", t(ctx, "settings.updates.channel.label"), t(ctx, "settings.updates.channel.help"), "settings-updates-updates-channel")
					</div>
					<div class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.updates.channel.description") }</div>
				</div>
				@components.Segmented("updates-channel", "updates_channel",
					[]components.SegmentOption{
						{Value: "stable", Label: t(ctx, "settings.updates.channel_stable")},
						{Value: "prerelease", Label: t(ctx, "settings.updates.channel_prerelease")},
						{Value: "nightly", Label: t(ctx, "settings.updates.channel_nightly")},
					},
					data.Channel,
				)
			</div>
			<!-- Auto-check toggle -->
			<div class="flex items-center justify-between gap-4">
				@components.Toggle(
					"updates-auto-check",
					"updates_auto_check",
					data.AutoCheck,
					t(ctx, "settings.updates.auto_check.label"),
					t(ctx, "settings.updates.auto_check.description"),
				)
				@components.ContextHelp("help-updates-auto-check", t(ctx, "settings.updates.auto_check.label"), t(ctx, "settings.updates.auto_check.help"), "settings-updates-updates-auto-check")
			</div>
			<!-- Auto-update toggle. Hidden in Docker because the scheduler
			     no-ops on Docker hosts (orchestration handles container
			     image refresh); offering the toggle would advertise a
			     capability that does nothing. -->
			if !data.IsDocker {
				<div>
					<div class="flex items-center justify-between gap-4">
						@components.Toggle(
							"updates-auto-update",
							"updates_auto_update",
							data.AutoUpdate,
							t(ctx, "settings.updates.auto_update.label"),
							t(ctx, "settings.updates.auto_update.description"),
						)
						@components.ContextHelp("help-updates-auto-update", t(ctx, "settings.updates.auto_update.label"), t(ctx, "settings.updates.auto_update.help"), "settings-updates-updates-auto-update")
					</div>
					if data.AutoUpdate && data.LastAutoApplied != "" {
						<div class="mt-2 text-xs text-gray-500 dark:text-gray-400" id="updates-last-auto-applied-row">
							{ t(ctx, "settings.updates.last_auto_applied.label") }:
							if data.LastAutoAppliedVersion != "" {
								<span class="font-mono">{ data.LastAutoAppliedVersion }</span>,
							}
							<span class="font-mono">{ data.LastAutoApplied }</span>
						</div>
					}
					<div class="mt-1 text-xs text-gray-500 dark:text-gray-400">
						{ t(ctx, "settings.updates.auto_update.rollback_hint") }
						<a href="https://github.com/sydlexius/stillwater/releases" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">
							{ t(ctx, "settings.updates.auto_update.rollback_link") }
						</a>
					</div>
					if data.UpdateAvailable && data.LatestVersion != "" && !slices.Contains(data.SkippedVersions, data.LatestVersion) {
						<div class="mt-2">
							<button
								type="button"
								id="updates-skip-version-btn"
								data-version={ data.LatestVersion }
								onclick="skipThisVersion()"
								class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-medium bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
							>
								{ tf(ctx, "settings.updates.skip_version.label", data.LatestVersion) }
							</button>
						</div>
					}
					if len(data.SkippedVersions) > 0 {
						<div class="mt-2 text-xs text-gray-500 dark:text-gray-400" id="updates-skipped-versions-row">
							{ t(ctx, "settings.updates.skip_version.list_label") }:
							for i, v := range data.SkippedVersions {
								if i > 0 {
									{ ", " }
								}
								<span class="font-mono">{ v }</span>
							}
						</div>
					}
				</div>
				<!-- First-toggle confirmation modal: shown only when the user
				     turns AutoUpdate on (off -> on). The modal is rendered
				     hidden by default; the auto-save handler intercepts the
				     change event, surfaces the modal, and only persists the
				     toggle when the user confirms. Cancel reverts the
				     checkbox to its previous state. -->
				<div
					id="updates-auto-update-confirm-modal"
					class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center px-4"
					role="dialog"
					aria-modal="true"
					aria-labelledby="updates-auto-update-confirm-title"
				>
					<div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full p-6 space-y-4">
						<h3 id="updates-auto-update-confirm-title" class="text-lg font-semibold text-gray-900 dark:text-gray-100">
							{ t(ctx, "settings.updates.auto_update.confirm_title") }
						</h3>
						<p class="text-sm text-gray-700 dark:text-gray-300">
							{ t(ctx, "settings.updates.auto_update.confirm_body") }
						</p>
						<div class="flex justify-end gap-2">
							<button
								type="button"
								id="updates-auto-update-confirm-cancel"
								class="px-3 py-1.5 rounded-md text-sm font-medium bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500"
							>
								{ t(ctx, "common.cancel") }
							</button>
							<button
								type="button"
								id="updates-auto-update-confirm-accept"
								class="px-3 py-1.5 rounded-md text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
							>
								{ t(ctx, "settings.updates.auto_update.confirm_accept") }
							</button>
						</div>
					</div>
				</div>
			}
			<!-- Check interval selector. The select is a fixed enum to keep
			     the UI simple and keep the request payload small; the API
			     accepts any integer >= 1, so power users can hit the
			     endpoint directly for non-listed cadences. If the persisted
			     CheckIntervalHours is not in the enum, a "(custom)" option
			     is rendered so Save does not silently overwrite it with the
			     browser's first-option fallback. -->
			<div class="flex items-center justify-between gap-4">
				<div>
					<label for="updates-check-interval" class="block text-sm font-medium text-gray-900 dark:text-gray-100">{ t(ctx, "settings.updates.check_interval.label") }</label>
					<div class="text-xs text-gray-500 dark:text-gray-400">{ t(ctx, "settings.updates.check_interval.description") }</div>
				</div>
				<select
					id="updates-check-interval"
					name="updates_check_interval"
					class="block w-44 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
				>
					if !isKnownInterval(data.CheckIntervalHours) {
						<option value={ strconv.Itoa(data.CheckIntervalHours) } selected>{ tf(ctx, "settings.updates.interval_custom", data.CheckIntervalHours) }</option>
					}
					@updaterIntervalOption(1, data.CheckIntervalHours, t(ctx, "settings.updates.interval_1h"))
					@updaterIntervalOption(6, data.CheckIntervalHours, t(ctx, "settings.updates.interval_6h"))
					@updaterIntervalOption(12, data.CheckIntervalHours, t(ctx, "settings.updates.interval_12h"))
					@updaterIntervalOption(24, data.CheckIntervalHours, t(ctx, "settings.updates.interval_24h"))
					@updaterIntervalOption(168, data.CheckIntervalHours, t(ctx, "settings.updates.interval_7d"))
				</select>
			</div>
		</div>
	</div>
	<!-- Actions -->
	<div class="sw-card bg-white dark:bg-gray-800 shadow rounded-lg">
		<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
			<h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{ t(ctx, "settings.updates.actions_title") }</h2>
		</div>
		<div class="px-6 py-4 flex flex-wrap gap-3">
			<button
				type="button"
				id="updates-check-btn"
				onclick="checkForUpdates()"
				class="inline-flex items-center px-4 py-2 rounded-md text-sm font-medium bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
			>
				{ t(ctx, "settings.updates.check_now") }
			</button>
			if !data.IsDocker {
				<button
					type="button"
					id="updates-apply-btn"
					onclick="applyUpdate()"
					disabled?={ !data.Enabled || !data.UpdateAvailable || data.RestartRequired }
					class="inline-flex items-center px-4 py-2 rounded-md text-sm font-medium bg-green-600 hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed text-white focus:outline-none focus:ring-2 focus:ring-green-500 transition-colors"
				>
					{ t(ctx, "settings.updates.apply_update") }
				</button>
			}
		</div>
	</div>
}
