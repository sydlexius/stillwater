package templates

// isTabActive returns true when the current path matches the tab's route.
// currentPath should have the base path already stripped.
func isTabActive(currentPath, tabPath string) bool {
	if tabPath == "/" {
		return currentPath == "/" || currentPath == ""
	}
	// Prefix match for sub-pages (e.g. /reports/compliance matches /reports).
	if len(currentPath) >= len(tabPath) && currentPath[:len(tabPath)] == tabPath {
		// Ensure we match at a boundary: exact or followed by '/'.
		if len(currentPath) == len(tabPath) || currentPath[len(tabPath)] == '/' {
			return true
		}
	}
	return false
}

// BottomTabs renders a fixed bottom navigation bar for mobile viewports.
// bp is the server base path (e.g. "/stillwater"), empty at root.
// currentPath is the request path with the base path stripped.
// isAdmin controls visibility of the Settings tab.
templ BottomTabs(bp string, currentPath string, isAdmin bool) {
	<nav
		aria-label="Mobile navigation"
		class="sw-bottom-tabs"
	>
		@bottomTab(bp, "/", currentPath, "Dashboard", dashboardIcon())
		@bottomTab(bp, "/artists", currentPath, "Artists", artistsIcon())
		@bottomTab(bp, "/reports/compliance", currentPath, "Reports", reportsIcon())
		if isAdmin {
			@bottomTab(bp, "/settings", currentPath, "Settings", settingsIcon())
		}
	</nav>
}

// bottomTab renders a single tab link in the bottom navigation bar.
templ bottomTab(bp string, tabPath string, currentPath string, label string, icon templ.Component) {
	<a
		href={ templ.SafeURL(bp + tabPath) }
		class={ "sw-bottom-tab", templ.KV("sw-bottom-tab-active", isTabActive(currentPath, tabPath)) }
		if isTabActive(currentPath, tabPath) {
			aria-current="page"
		}
	>
		@icon
		<span class="sw-bottom-tab-label">{ label }</span>
	</a>
}

// -- Tab icons (24x24 Heroicons outline) ------------------------------------

templ dashboardIcon() {
	<svg class="sw-bottom-tab-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"></path>
	</svg>
}

