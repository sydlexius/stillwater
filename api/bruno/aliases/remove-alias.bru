meta {
  name: Remove Alias
  type: http
  seq: 3
}

delete {
  url: {{apiBase}}/artists/{{artistId}}/aliases/{{aliasId}}
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("returns 404 for sentinel artistId/aliasId", function() {
    expect(res.status).to.equal(404);
  });

  test("response carries error envelope", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.error).to.be.a("string");
  });
}
