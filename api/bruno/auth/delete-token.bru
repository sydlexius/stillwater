meta {
  name: Delete API Token (Revoke)
  type: http
  seq: 6
}

delete {
  url: {{apiBase}}/auth/tokens/{{tokenId}}
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("response carries the revoked status sentinel", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.status).to.equal("revoked");
  });
}
