meta {
  name: Delete Connection
  type: http
  seq: 5
}

delete {
  url: {{apiBase}}/connections/{{connectionId}}
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("returns 404 for sentinel connectionId", function() {
    expect(res.status).to.equal(404);
  });

  test("error envelope mentions connection not found", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.error).to.include("connection not found");
  });
}
