meta {
  name: Run Rule
  type: http
  seq: 3
}

post {
  url: {{apiBase}}/rules/{{ruleId}}/run
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("returns 404 for sentinel ruleId", function() {
    expect(res.status).to.equal(404);
  });

  test("error envelope reports rule not found", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.error).to.equal("rule not found");
  });
}
