meta {
  name: Re-identify Artist (clear IDs)
  type: http
  seq: 5
}

post {
  url: {{apiBase}}/artists/{{artistId}}/reidentify
  body: formUrlEncoded
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

body:form-urlencoded {
  clear_ids: true
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should confirm IDs were cleared", function() {
    var body = res.json();
    expect(body.message).to.include("cleared");
  });
}
