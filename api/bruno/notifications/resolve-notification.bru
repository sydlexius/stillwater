meta {
  name: Resolve Notification
  type: http
  seq: 4
}

post {
  url: {{apiBase}}/notifications/{{notificationId}}/resolve
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("resolve is idempotent and returns 200 even for unknown ids", function() {
    expect(res.status).to.equal(200);
  });

  test("response surfaces resolved sentinel", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.status).to.equal("resolved");
  });
}
