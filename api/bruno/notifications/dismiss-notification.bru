meta {
  name: Dismiss Notification
  type: http
  seq: 3
}

post {
  url: {{apiBase}}/notifications/{{notificationId}}/dismiss
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("dismiss is idempotent and returns 200 even for unknown ids", function() {
    expect(res.status).to.equal(200);
  });
}
