meta {
  name: Activate Platform
  type: http
  seq: 6
}

post {
  url: {{apiBase}}/platforms/{{platformId}}/activate
  body: none
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

tests {
  test("should return 200 for the built-in 'custom' platform", function() {
    expect(res.status).to.equal(200);
  });

  test("response surfaces the active sentinel", function() {
    expect(res.body).to.be.an("object");
    expect(res.body.status).to.equal("active");
  });
}
