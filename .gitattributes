# Default: auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Go source
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Web / templates
*.templ text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.ts text eol=lf

# Config / CI
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
*.env text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.golangci.yml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# SQL migrations
*.sql text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.sqlite binary

# Generated files. linguist-generated collapses them in GitHub PR diffs and is
# honored by review bots (CodeRabbit, Copilot) so they skip the churn; Codoki
# (no repo config) is covered the same way. Regenerate via `make generate` /
# `make generate-docs` -- never hand-edit these.
*_templ.go linguist-generated=true
web/static/css/styles.css linguist-generated=true
docs/_generated/** linguist-generated=true
**/_doc-anchors.txt linguist-generated=true
**/_settings-anchors.txt linguist-generated=true
docs/site/src/reference/environment-variables.md linguist-generated=true
docs/site/src/reference/rules-catalogue.md linguist-generated=true
docs/site/src/reference/providers.md linguist-generated=true
docs/site/src/reference/cli.md linguist-generated=true
docs/site/src/reference/preferences.md linguist-generated=true
docs/site/src/reference/settings-by-tab.md linguist-generated=true
